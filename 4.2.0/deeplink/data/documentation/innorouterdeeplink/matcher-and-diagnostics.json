{"sections":[],"primaryContentSections":[{"content":[{"type":"heading","anchor":"Pattern-model","level":2,"text":"Pattern model"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Patterns support:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"literal segments"}]}]},{"content":[{"inlineContent":[{"text":"named parameters such as ","type":"text"},{"code":":id","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"terminal wildcard "},{"type":"codeVoice","code":"*"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This keeps matching simple and predictable for app routing."}]},{"type":"paragraph","inlineContent":[{"text":"Wildcards are terminal-only. A pattern like ","type":"text"},{"code":"\/api\/*\/users","type":"codeVoice"},{"text":" is invalid:","type":"text"},{"text":" ","type":"text"},{"text":"it produces a ","type":"text"},{"code":".nonTerminalWildcard(pattern:index:)","type":"codeVoice"},{"text":" diagnostic and does","type":"text"},{"text":" ","type":"text"},{"text":"not match runtime paths.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Captured values stay available as strings through "},{"type":"codeVoice","code":"firstValue(forName:)"},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"codeVoice","code":"values(forName:)"},{"type":"text","text":". For common scalar types, use the typed overloads:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["let id = parameters.firstValue(forName: \"id\", as: UUID.self)","let page = parameters.firstValue(forName: \"page\", as: Int.self)","let selectedTags = parameters.values(forName: \"tag\", as: String.self)"]},{"type":"heading","anchor":"Match-precedence","level":2,"text":"Match precedence"},{"type":"paragraph","inlineContent":[{"text":"Match precedence remains declaration-order based.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"That means:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"earlier patterns win","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"diagnostics do not change runtime behavior"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"ordering is still part of the matcher contract"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Diagnostics","level":2,"text":"Diagnostics"},{"type":"paragraph","inlineContent":[{"code":"DeepLinkMatcherConfiguration","type":"codeVoice"},{"type":"text","text":" can surface diagnostics for common authoring mistakes:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"duplicate patterns"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"wildcard shadowing","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"non-terminal wildcards","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"invalid parameter names; parameter names must match"},{"type":"text","text":" "},{"code":"^[A-Za-z_][A-Za-z0-9_]*$","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"text":"parameter-heavy patterns that subsume more specific later patterns","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Diagnostics are available on both push-only and flow matchers. They","type":"text"},{"text":" ","type":"text"},{"text":"are intended to catch ambiguous authoring early without changing the","type":"text"},{"text":" ","type":"text"},{"text":"matcher’s runtime semantics.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For release-readiness gates, use the throwing strict initializers:"},{"type":"text","text":" "},{"code":"DeepLinkMatcher(strict:)","type":"codeVoice"},{"type":"text","text":" for push-only mappings and"},{"type":"text","text":" "},{"code":"FlowDeepLinkMatcher(strict:)","type":"codeVoice"},{"type":"text","text":" for mappings that expand into a"},{"type":"text","text":" "},{"code":"FlowPlan","type":"codeVoice"},{"type":"text","text":". Strict initializers throw "},{"code":"DeepLinkMatcherStrictError","type":"codeVoice"},{"type":"text","text":" with"},{"type":"text","text":" "},{"type":"text","text":"the full diagnostic list instead of only logging warnings, and accept"},{"type":"text","text":" "},{"type":"text","text":"the same "},{"code":"DeepLinkInputLimits","type":"codeVoice"},{"type":"text","text":" guardrails used by non-strict matchers."}]},{"type":"heading","anchor":"Input-limits","level":2,"text":"Input limits"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"DeepLinkInputLimits"},{"text":" guards runtime URLs before matching. Configure it","type":"text"},{"text":" ","type":"text"},{"text":"on ","type":"text"},{"type":"codeVoice","code":"DeepLinkMatcherConfiguration"},{"text":", ","type":"text"},{"type":"codeVoice","code":"DeepLinkPipeline"},{"text":", or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"FlowDeepLinkPipeline"},{"text":" to cap absolute URL length, path segment count,","type":"text"},{"text":" ","type":"text"},{"text":"and query item count. Direct matcher calls still return ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" because","type":"text"},{"text":" ","type":"text"},{"text":"their public contract is optional. Pipeline and effect-handler paths","type":"text"},{"text":" ","type":"text"},{"text":"surface limit violations as typed","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"DeepLinkRejectionReason.inputLimitExceeded"},{"text":" rejections instead of","type":"text"},{"text":" ","type":"text"},{"text":"“no match” outcomes.","type":"text"}]}],"kind":"content"}],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterDeepLink\/Matcher-and-Diagnostics"},"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"codeVoice","code":"DeepLinkMatcher"},{"type":"text","text":" and "},{"type":"codeVoice","code":"FlowDeepLinkMatcher"},{"type":"text","text":" are the URL-pattern front doors for deep-link routing."}],"metadata":{"modules":[{"name":"InnoRouterTesting"}],"roleHeading":"Article","role":"article","title":"Matcher and diagnostics"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/innorouterdeeplink\/matcher-and-diagnostics"]}],"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterDeepLink\/InnoRouterDeepLink"]]},"references":{"doc://com.innosquad.innorouter.docs.deeplink/documentation/InnoRouterTesting":{"url":"\/documentation\/innoroutertesting","abstract":[],"role":"collection","kind":"symbol","identifier":"doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterTesting","type":"topic","title":"InnoRouterTesting"},"doc://com.innosquad.innorouter.docs.deeplink/documentation/InnoRouterDeepLink/InnoRouterDeepLink":{"identifier":"doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterDeepLink\/InnoRouterDeepLink","role":"collectionGroup","url":"\/documentation\/innorouterdeeplink\/innorouterdeeplink","kind":"article","abstract":[{"type":"text","text":"Pattern matching, pipeline planning, and pending deep-link handling for InnoRouter."}],"title":"InnoRouterDeepLink","type":"topic"}}}