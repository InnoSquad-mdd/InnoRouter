{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/innorouterdeeplink\/tutorial-flowdeeplinkpipeline"]}],"abstract":[{"type":"text","text":"Map a URL to a "},{"code":"FlowPlan","type":"codeVoice"},{"type":"text","text":" with push prefix and optional modal"},{"type":"text","text":" "},{"type":"text","text":"terminal step, run it through authentication gating, and replay the"},{"type":"text","text":" "},{"type":"text","text":"deferred link through "},{"code":"FlowDeepLinkEffectHandler","type":"codeVoice"},{"type":"text","text":" — all in one"},{"type":"text","text":" "},{"type":"text","text":"atomic "},{"code":"FlowStore.apply(_:)","type":"codeVoice"},{"type":"text","text":"."}],"metadata":{"role":"article","roleHeading":"Article","modules":[{"name":"InnoRouterTesting"}],"title":"Rehydrating Composite Flows from a URL"},"primaryContentSections":[{"content":[{"anchor":"Scenario","type":"heading","level":2,"text":"Scenario"},{"inlineContent":[{"type":"codeVoice","code":"myapp:\/\/app\/home\/detail\/42"},{"type":"text","text":" should land the user on the order detail"},{"type":"text","text":" "},{"type":"text","text":"for order 42. "},{"type":"codeVoice","code":"myapp:\/\/app\/onboarding\/privacy"},{"type":"text","text":" should open a privacy"},{"type":"text","text":" "},{"type":"text","text":"sheet over the current screen. Authenticated routes like"},{"type":"text","text":" "},{"type":"codeVoice","code":"myapp:\/\/app\/secure"},{"type":"text","text":" defer until sign-in completes, then replay."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Push-only pipelines ("},{"code":"DeepLinkPipeline","type":"codeVoice"},{"type":"text","text":" → "},{"code":"NavigationPlan<R>","type":"codeVoice"},{"type":"text","text":") can’t"},{"type":"text","text":" "},{"type":"text","text":"express a URL that terminates on a modal. "},{"code":"FlowDeepLinkPipeline","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"solves that by emitting "},{"code":"FlowPlan","type":"codeVoice"},{"type":"text","text":" — a single value holding both"},{"type":"text","text":" "},{"type":"text","text":"the navigation prefix and the tail sheet\/cover."}],"type":"paragraph"},{"anchor":"Routes","type":"heading","level":2,"text":"Routes"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["enum AppRoute: Route {","    case home","    case detail(id: String)","    case comments(id: String)","    case privacyPolicy","    case secure","}"]},{"anchor":"Defining-the-matcher","type":"heading","level":2,"text":"Defining the matcher"},{"inlineContent":[{"code":"FlowDeepLinkMapping","type":"codeVoice"},{"text":" handlers return a ","type":"text"},{"inlineContent":[{"type":"text","text":"complete"}],"type":"strong"},{"text":" ","type":"text"},{"code":"FlowPlan","type":"codeVoice"},{"text":" so","type":"text"},{"text":" ","type":"text"},{"text":"multi-segment URLs expand atomically. Pattern syntax matches","type":"text"},{"text":" ","type":"text"},{"code":"DeepLinkMapping","type":"codeVoice"},{"text":": ","type":"text"},{"code":":parameter","type":"codeVoice"},{"text":" for captures, terminal ","type":"text"},{"code":"*","type":"codeVoice"},{"text":" wildcard,","type":"text"},{"text":" ","type":"text"},{"text":"path-only (host and scheme are filtered separately by the pipeline).","type":"text"},{"text":" ","type":"text"},{"text":"Non-terminal wildcards such as ","type":"text"},{"code":"\/store\/*\/receipt","type":"codeVoice"},{"text":" are invalid and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"surface diagnostics instead of matching."}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["let matcher = FlowDeepLinkMatcher<AppRoute> {","    FlowDeepLinkMapping(\"\/home\") { _ in","        FlowPlan(steps: [.push(.home)])","    }","    FlowDeepLinkMapping(\"\/home\/detail\/:id\") { params in","        guard let id = params.firstValue(forName: \"id\") else { return nil }","        return FlowPlan(steps: [.push(.home), .push(.detail(id: id))])","    }","    FlowDeepLinkMapping(\"\/home\/detail\/:id\/comments\/:cid\") { params in","        guard let id = params.firstValue(forName: \"id\"),","              let cid = params.firstValue(forName: \"cid\") else { return nil }","        return FlowPlan(steps: [","            .push(.home),","            .push(.detail(id: id)),","            .push(.comments(id: cid))","        ])","    }","    FlowDeepLinkMapping(\"\/onboarding\/privacy\") { _ in","        FlowPlan(steps: [.sheet(.privacyPolicy)])","    }","    FlowDeepLinkMapping(\"\/secure\") { _ in","        FlowPlan(steps: [.push(.secure)])","    }","}"]},{"anchor":"Wiring-the-pipeline","type":"heading","level":2,"text":"Wiring the pipeline"},{"inlineContent":[{"type":"codeVoice","code":"FlowDeepLinkPipeline"},{"type":"text","text":" composes scheme\/host validation,"},{"type":"text","text":" "},{"type":"codeVoice","code":"DeepLinkAuthenticationPolicy"},{"type":"text","text":" (reused from the push-only surface),"},{"type":"text","text":" "},{"type":"text","text":"and the matcher:"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["let pipeline = FlowDeepLinkPipeline<AppRoute>(","    allowedSchemes: [\"myapp\"],","    allowedHosts: [\"app\"],","    matcher: matcher,","    authenticationPolicy: .required(","        shouldRequireAuthentication: { route in","            if case .secure = route { return true }","            return false","        },","        isAuthenticated: { SessionStore.shared.isAuthenticated }","    )",")"]},{"inlineContent":[{"text":"For unguarded apps pass ","type":"text"},{"type":"codeVoice","code":".notRequired"},{"text":" (the default) and skip the","type":"text"},{"text":" ","type":"text"},{"text":"policy closure entirely.","type":"text"}],"type":"paragraph"},{"anchor":"Applying-through-FlowStore","type":"heading","level":2,"text":"Applying through FlowStore"},{"inlineContent":[{"type":"codeVoice","code":"FlowDeepLinkEffectHandler"},{"type":"text","text":" bridges the pipeline output into any"},{"type":"text","text":" "},{"type":"codeVoice","code":"FlowPlanApplier"},{"type":"text","text":". It also owns the pending slot, so keep the handler"},{"type":"text","text":" "},{"type":"text","text":"in a stable owner rather than rebuilding it inside a SwiftUI body."},{"type":"text","text":" "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":" already conforms:"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["import Foundation","import SwiftUI","import InnoRouter","import InnoRouterDeepLinkEffects","","private final class SessionStore {","    static let shared = SessionStore()","","    private let lock = NSLock()","    private var signedIn = false","","    var isAuthenticated: Bool {","        lock.withLock { signedIn }","    }","","    func markAuthenticated() {","        lock.withLock { signedIn = true }","    }","}","","@MainActor","private final class DeepLinkCoordinator {","    let flow: FlowStore<AppRoute>","    let handler: FlowDeepLinkEffectHandler<AppRoute>","    private let session: SessionStore","","    init(session: SessionStore = .shared) {","        self.session = session","        let flow = FlowStore<AppRoute>()","        self.flow = flow","","        let matcher = FlowDeepLinkMatcher<AppRoute> {","            FlowDeepLinkMapping(\"\/home\") { _ in","                FlowPlan(steps: [.push(.home)])","            }","            FlowDeepLinkMapping(\"\/onboarding\/privacy\") { _ in","                FlowPlan(steps: [.sheet(.privacyPolicy)])","            }","            FlowDeepLinkMapping(\"\/secure\") { _ in","                FlowPlan(steps: [.push(.secure)])","            }","        }","        let pipeline = FlowDeepLinkPipeline(","            allowedSchemes: [\"myapp\"],","            allowedHosts: [\"app\"],","            matcher: matcher,","            authenticationPolicy: .required(","                shouldRequireAuthentication: { route in","                    if case .secure = route { return true }","                    return false","                },","                isAuthenticated: { session.isAuthenticated }","            )","        )","        self.handler = FlowDeepLinkEffectHandler(","            pipeline: pipeline,","            applier: flow","        )","    }","","    func userDidSignIn() {","        session.markAuthenticated()","        _ = handler.resumePendingDeepLink()","    }","}","","@main","struct DemoApp: App {","    @State private var coordinator = DeepLinkCoordinator()","","    var body: some Scene {","        WindowGroup {","            FlowHost(","                store: coordinator.flow,","                destination: { route in","                    switch route {","                    case .home:","                        Text(\"Home\")","                    case .detail(let id):","                        Text(\"Detail \\(id)\")","                    case .comments(let id):","                        Text(\"Comments \\(id)\")","                    case .privacyPolicy:","                        Text(\"Privacy\")","                    case .secure:","                        Text(\"Secure\")","                    }","                },","                root: { Text(\"Root\") }","            )","            .onOpenURL { url in","                _ = coordinator.handler.handle(url)","            }","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"A single "},{"code":"handler.handle(url)","type":"codeVoice"},{"type":"text","text":" call:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Runs scheme\/host validation."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Walks the matcher for a ","type":"text"},{"type":"codeVoice","code":"FlowPlan"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Runs the authentication policy across the plan until it finds the","type":"text"},{"text":" ","type":"text"},{"text":"first protected route.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Either applies the plan through ","type":"text"},{"type":"codeVoice","code":"flow.apply(_:)"},{"text":" or stores it as","type":"text"},{"text":" ","type":"text"},{"text":"a ","type":"text"},{"type":"codeVoice","code":"FlowPendingDeepLink"},{"text":".","type":"text"}]}]}],"type":"orderedList"},{"anchor":"Replaying-after-sign-in","type":"heading","level":2,"text":"Replaying after sign-in"},{"inlineContent":[{"type":"text","text":"Once the user signs in, resume the pending deep link:"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["func userDidSignIn() {","    coordinator.userDidSignIn()","}"]},{"inlineContent":[{"type":"text","text":"The handler re-consults the authentication policy (now returning"},{"type":"text","text":" "},{"type":"codeVoice","code":"true"},{"type":"text","text":"), drops the pending reference, and applies the plan atomically."},{"type":"text","text":" "},{"type":"text","text":"For an async gate (e.g. token refresh), use:"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["await coordinator.handler.resumePendingDeepLinkIfAllowed { pending in","    \/\/ Return true once the refresh has produced a live session.","    await AuthService.shared.refreshTokenIfNeeded()","}"]},{"inlineContent":[{"type":"text","text":"The handler keeps a single pending slot:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"a newly deferred URL replaces the older pending link","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"clearPendingDeepLink()"},{"type":"text","text":" drops the slot explicitly"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"stale pending links (ones the user replaced by opening a different"},{"type":"text","text":" "},{"type":"text","text":"URL) are therefore dropped automatically"}]}]}],"type":"unorderedList"},{"anchor":"Observing-the-chain","type":"heading","level":2,"text":"Observing the chain"},{"inlineContent":[{"type":"text","text":"All three authorities surface on "},{"type":"codeVoice","code":"FlowStore.events"},{"type":"text","text":" as one"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncStream"},{"type":"text","text":". A single subscriber sees the batch execution on the"},{"type":"text","text":" "},{"type":"text","text":"navigation store, the modal presentation (if any), and the"},{"type":"text","text":" "},{"type":"text","text":"settled FlowStore-level event as one chain. "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":" wraps inner"},{"type":"text","text":" "},{"type":"text","text":"navigation \/ modal callbacks synchronously before emitting the"},{"type":"text","text":" "},{"type":"text","text":"flow-level event, so one subscriber can assert the same ordering the"},{"type":"text","text":" "},{"type":"text","text":"matching configuration callbacks observe."}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["Task {","    for await event in flow.events {","        switch event {","        case .navigation(.batchExecuted(let result)):","            analytics.track(\"deep_link_applied\", [","                \"routes\": result.stateAfter.path.map(String.init(describing:))","            ])","        case .modal(.presented(let presentation)):","            analytics.track(\"deep_link_opened_modal\", [","                \"route\": String(describing: presentation.route)","            ])","        case .pathChanged(_, let new):","            analytics.track(\"flow_path\", [","                \"steps\": new.map(String.init(describing:))","            ])","        default:","            continue","        }","    }","}"]},{"anchor":"Host-less-testing","type":"heading","level":2,"text":"Host-less testing"},{"inlineContent":[{"type":"codeVoice","code":"FlowTestStore"},{"type":"text","text":" wraps the same "},{"type":"codeVoice","code":"flowStore.apply"},{"type":"text","text":" path:"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["@Test","@MainActor","func multiSegmentURLRehydrates() {","    let store = FlowTestStore<AppRoute>()","    let handler = FlowDeepLinkEffectHandler(pipeline: pipeline, applier: store.store)","","    _ = handler.handle(URL(string: \"myapp:\/\/app\/home\/detail\/42\")!)","","    store.receiveNavigation { event in","        if case .batchExecuted = event { return true }","        return false","    }","    store.receivePathChanged { _, new in","        new == [.push(.home), .push(.detail(id: \"42\"))]","    }","}"]},{"anchor":"Next-steps","type":"heading","level":2,"text":"Next steps"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"See the push-only "},{"type":"codeVoice","code":"Tutorial-DeepLinkReconciliation"},{"type":"text","text":" "},{"type":"text","text":"walk-through in the "},{"type":"codeVoice","code":"InnoRouterSwiftUI"},{"type":"text","text":" catalog for apps that"},{"type":"text","text":" "},{"type":"text","text":"don’t yet need modal-terminal URLs."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Read the ","type":"text"},{"code":"Tutorial-LoginOnboarding","type":"codeVoice"},{"text":" guide in the","type":"text"},{"text":" ","type":"text"},{"code":"InnoRouterSwiftUI","type":"codeVoice"},{"text":" documentation catalog to see how the","type":"text"},{"text":" ","type":"text"},{"text":"authenticated-replay loop fits a greenfield flow that uses","type":"text"},{"text":" ","type":"text"},{"code":"ChildCoordinator","type":"codeVoice"},{"text":" for a sign-up sheet.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterDeepLink\/Tutorial-FlowDeepLinkPipeline"},"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterDeepLink\/InnoRouterDeepLink"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"kind":"article","references":{"doc://com.innosquad.innorouter.docs.deeplink/documentation/InnoRouterTesting":{"url":"\/documentation\/innoroutertesting","abstract":[],"role":"collection","kind":"symbol","identifier":"doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterTesting","type":"topic","title":"InnoRouterTesting"},"doc://com.innosquad.innorouter.docs.deeplink/documentation/InnoRouterDeepLink/InnoRouterDeepLink":{"identifier":"doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterDeepLink\/InnoRouterDeepLink","role":"collectionGroup","url":"\/documentation\/innorouterdeeplink\/innorouterdeeplink","kind":"article","abstract":[{"type":"text","text":"Pattern matching, pipeline planning, and pending deep-link handling for InnoRouter."}],"title":"InnoRouterDeepLink","type":"topic"}}}