{"metadata":{"modules":[{"name":"InnoRouterTesting"}],"roleHeading":"Article","title":"Event Stream Backpressure","role":"article"},"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"paths":["\/documentation\/innoroutercore\/event-stream-backpressure"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/InnoRouterCore"]]},"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"Every ","type":"text"},{"code":"NavigationStore","type":"codeVoice"},{"text":", ","type":"text"},{"code":"ModalStore","type":"codeVoice"},{"text":", ","type":"text"},{"code":"FlowStore","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"SceneStore","type":"codeVoice"},{"text":" ","type":"text"},{"text":"publishes an ","type":"text"},{"code":"events: AsyncStream","type":"codeVoice"},{"type":"text","text":" that fans every observation event"},{"type":"text","text":" "},{"type":"text","text":"out to every subscriber. The fan-out is implemented as a per-subscriber"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncStream.Continuation"},{"type":"text","text":", which means a slow or cancelled subscriber"},{"type":"text","text":" "},{"type":"text","text":"that never drains its stream would otherwise retain every event"},{"type":"text","text":" "},{"type":"text","text":"indefinitely — behaving as an unbounded leak when the broadcaster"},{"text":" ","type":"text"},{"text":"outlives all consumers.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To bound that growth, every store accepts an","type":"text"},{"text":" ","type":"text"},{"code":"EventBufferingPolicy","type":"codeVoice"},{"text":" in its configuration.","type":"text"}]},{"text":"Default policy","type":"heading","anchor":"Default-policy","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default is "},{"type":"codeVoice","code":"EventBufferingPolicy.default"},{"type":"text","text":", which is"},{"type":"text","text":" "},{"type":"codeVoice","code":".bufferingNewest(1024)"},{"type":"text","text":". The number is sized for realistic navigation"},{"type":"text","text":" "},{"type":"text","text":"bursts (a few hundred events for the longest deep-link replay we have"},{"type":"text","text":" "},{"type":"text","text":"measured) while keeping the retained working set bounded so a stuck"},{"type":"text","text":" "},{"type":"text","text":"subscriber cannot balloon memory in production."}]},{"text":"Choosing a policy","type":"heading","anchor":"Choosing-a-policy","level":2},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Policy"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Behaviour"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"When to use"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".bufferingNewest(N)"}]}],[{"inlineContent":[{"text":"Retain at most ","type":"text"},{"code":"N","type":"codeVoice"},{"text":" most-recently-broadcast events per subscriber, dropping older events when the buffer fills.","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Production code that prefers loss-of-history over memory growth under contention. The default."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".bufferingOldest(N)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Retain at most "},{"type":"codeVoice","code":"N"},{"type":"text","text":" oldest-broadcast events per subscriber, dropping newer events when the buffer fills."}]}],[{"type":"paragraph","inlineContent":[{"text":"Audit pipelines that care about the ","type":"text"},{"inlineContent":[{"text":"first","type":"text"}],"type":"emphasis"},{"text":" burst more than the latest tail (rare).","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".unbounded","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Buffer every event until the subscriber drains it."}]}],[{"type":"paragraph","inlineContent":[{"text":"Test harnesses or short-lived subscribers where you control lifetime and require deterministic, lossless ordering.","type":"text"}]}]]],"type":"table"},{"text":"Configuring per store","type":"heading","anchor":"Configuring-per-store","level":2},{"type":"paragraph","inlineContent":[{"text":"The policy is set per store at construction time via its configuration:","type":"text"}]},{"code":["let store = try NavigationStore<HomeRoute>(","    initialPath: [.list],","    configuration: NavigationStoreConfiguration(","        eventBufferingPolicy: .bufferingNewest(2048)","    )",")"],"type":"codeListing","syntax":"swift skip doc-fragment"},{"type":"paragraph","inlineContent":[{"text":"Modal and Flow stores expose the same knob, with one policy per","type":"text"},{"text":" ","type":"text"},{"text":"published stream:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NavigationStoreConfiguration.eventBufferingPolicy"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"ModalStoreConfiguration.eventBufferingPolicy"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"FlowStoreConfiguration.eventBufferingPolicy"},{"type":"text","text":" for the flow-level"},{"type":"text","text":" "},{"type":"codeVoice","code":"FlowStore.events"},{"type":"text","text":" fan-out"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"FlowStoreConfiguration.navigation.eventBufferingPolicy","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"FlowStoreConfiguration.modal.eventBufferingPolicy","type":"codeVoice"},{"text":" for the wrapped","type":"text"},{"text":" ","type":"text"},{"text":"inner store streams","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Drop-semantics-under-load","type":"heading","level":2,"text":"Drop semantics under load"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Under sustained backpressure, the store keeps emitting events. Whether"},{"type":"text","text":" "},{"type":"text","text":"the event reaches a slow subscriber depends on the policy chosen for"},{"type":"text","text":" "},{"type":"text","text":"that subscriber’s store:"}]},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":".bufferingNewest(N)"},{"text":": oldest events are dropped silently. The","type":"text"},{"text":" ","type":"text"},{"text":"subscriber sees a contiguous tail of the most recent N events the","type":"text"},{"text":" ","type":"text"},{"text":"store emitted.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":".bufferingOldest(N)","type":"codeVoice"},{"text":": newer events are dropped silently after the","type":"text"},{"text":" ","type":"text"},{"text":"buffer fills. The subscriber sees the first N events emitted after","type":"text"},{"text":" ","type":"text"},{"text":"it started subscribing.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":".unbounded","type":"codeVoice"},{"type":"text","text":": nothing is dropped, but the per-subscriber queue can"},{"type":"text","text":" "},{"type":"text","text":"grow without bound while the subscriber falls behind."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Drops are not surfaced as an event. If your analytics pipeline must"},{"type":"text","text":" "},{"type":"text","text":"distinguish “no event happened” from “an event was buffered out”, use"},{"type":"text","text":" "},{"type":"codeVoice","code":".unbounded"},{"type":"text","text":" for that subscriber and rely on your own pacing rather"},{"type":"text","text":" "},{"type":"text","text":"than the broadcaster."}]},{"anchor":"Lifetime-contract","type":"heading","level":2,"text":"Lifetime contract"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each subscriber owns one "},{"type":"codeVoice","code":"AsyncStream"},{"type":"text","text":". When the subscriber’s"},{"type":"text","text":" "},{"type":"text","text":"iterator goes out of scope, "},{"type":"codeVoice","code":"AsyncStream.Continuation.onTermination"},{"type":"text","text":" "},{"type":"text","text":"fires and the broadcaster releases its slot. Stores also finish all"},{"type":"text","text":" "},{"type":"text","text":"outstanding continuations on "},{"type":"codeVoice","code":"isolated deinit"},{"type":"text","text":", so "},{"type":"codeVoice","code":"for await"},{"type":"text","text":" loops"},{"type":"text","text":" "},{"type":"text","text":"terminate naturally when their store is released — no manual cleanup"},{"type":"text","text":" "},{"type":"text","text":"required."}]},{"level":2,"type":"heading","anchor":"Related","text":"Related"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/Middleware-and-Cancellation","type":"reference","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/Rejection-Reasons","isActive":true,"type":"reference"}]}]}],"type":"unorderedList"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/Event-Stream-Backpressure"},"abstract":[{"type":"text","text":"How the "},{"type":"codeVoice","code":"events"},{"type":"text","text":" stream of every store handles slow or stuck subscribers."}],"kind":"article","sections":[],"references":{"doc://com.innosquad.innorouter.docs.core/documentation/InnoRouterCore/InnoRouterCore":{"type":"topic","identifier":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/InnoRouterCore","url":"\/documentation\/innoroutercore\/innoroutercore","role":"collectionGroup","kind":"article","abstract":[{"type":"text","text":"State, command, result, and execution primitives for InnoRouter."}],"title":"InnoRouterCore"},"doc://com.innosquad.innorouter.docs.core/documentation/InnoRouterCore/Middleware-and-Cancellation":{"url":"\/documentation\/innoroutercore\/middleware-and-cancellation","kind":"article","role":"article","title":"Middleware and cancellation","type":"topic","abstract":[{"type":"text","text":"Middleware is the cross-cutting policy layer for navigation execution."}],"identifier":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/Middleware-and-Cancellation"},"doc://com.innosquad.innorouter.docs.core/documentation/InnoRouterCore/Rejection-Reasons":{"type":"topic","identifier":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/Rejection-Reasons","title":"Rejection Reasons catalog","url":"\/documentation\/innoroutercore\/rejection-reasons","kind":"article","role":"article","abstract":[{"type":"text","text":"One-stop reference for every rejection \/ cancellation \/ failure"},{"type":"text","text":" "},{"type":"text","text":"taxonomy in the InnoRouter stack — when each case fires, where it"},{"type":"text","text":" "},{"type":"text","text":"originates, and how to handle it."}]},"doc://com.innosquad.innorouter.docs.core/documentation/InnoRouterTesting":{"type":"topic","identifier":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterTesting","kind":"symbol","role":"collection","title":"InnoRouterTesting","abstract":[],"url":"\/documentation\/innoroutertesting"}}}