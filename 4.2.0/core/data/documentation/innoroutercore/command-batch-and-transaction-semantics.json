."}]},{"type":"paragraph","inlineContent":[{"text":"That means:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"commands execute left-to-right","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"earlier successful steps stay applied even if a later step fails","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"later steps still run unless the sequence itself has no more elements","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"the final result is ","type":"text"},{"code":"NavigationResult.multiple(_:)","type":"codeVoice"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":".sequence"},{"type":"text","text":" when partial success is acceptable and the command stream itself is the point."}]},{"level":2,"anchor":"Fallback-semantics","type":"heading","text":"Fallback semantics"},{"type":"paragraph","inlineContent":[{"code":".whenCancelled(primary, fallback:)","type":"codeVoice"},{"text":" is also command algebra.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"That means:"}]},{"items":[{"content":[{"inlineContent":[{"code":"primary","type":"codeVoice"},{"text":" runs first","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"if "},{"type":"codeVoice","code":"primary"},{"type":"text","text":" reports anything other than success, the store restores the snapshot and runs "},{"type":"codeVoice","code":"fallback"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"both legs still pass through middleware recursively"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"single-command execution only emits the committed state change","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"transaction execution keeps public middleware observation commit-only, while discarded preview legs run internal cleanup","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"code":".whenCancelled","type":"codeVoice"},{"type":"text","text":" when rollback-to-fallback semantics belong to one logical command."}]},{"level":2,"anchor":"Batch-semantics","type":"heading","text":"Batch semantics"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NavigationBatchExecutor.executeBatch(_:stopOnFailure:)"},{"text":" is for observation batching.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Batch execution still runs commands one step at a time, but it lets higher layers coalesce observation:"}]},{"items":[{"content":[{"inlineContent":[{"text":"step middleware still runs","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"stopOnFailure: false","type":"codeVoice"},{"text":" keeps later commands running after a failure","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"stopOnFailure: true"},{"text":" stops the batch after the first failed step","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the store can emit one aggregated callback"}]}]},{"content":[{"inlineContent":[{"text":"the caller gets a structured ","type":"text"},{"code":"NavigationBatchResult","type":"codeVoice"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use batch execution when the caller wants one “transition event” while still preserving per-step execution."}]},{"level":2,"anchor":"Transaction-semantics","type":"heading","text":"Transaction semantics"},{"type":"paragraph","inlineContent":[{"code":"NavigationTransactionExecutor.executeTransaction(_:)","type":"codeVoice"},{"text":" is the atomic option.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Transactions:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"preview commands on a shadow stack"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"abort on the first failure or cancellation"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"leave the real state unchanged on failure"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"commit the final state all at once on success","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"surface public ","type":"text"},{"code":"didExecute","type":"codeVoice"},{"text":" \/ transaction observation only for committed leaves","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"run internal discard cleanup for previewed leaves that never commit"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Use transactions when all-or-nothing semantics are required.","type":"text"}]},{"anchor":"Typed-failures","type":"heading","level":2,"text":"Typed failures"},{"type":"paragraph","inlineContent":[{"text":"Core legality failures stay in typed results instead of exceptions:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"NavigationResult.emptyStack"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"NavigationResult.invalidPopCount(_:)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"NavigationResult.insufficientStackDepth(requested:available:)","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"NavigationResult.routeNotFound(_:)","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"NavigationResult.cancelled(_:)"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This keeps navigation failure in normal control flow and makes pol