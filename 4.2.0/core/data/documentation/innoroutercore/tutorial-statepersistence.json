{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/innoroutercore\/tutorial-statepersistence"]}],"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"InnoRouterTesting"}],"title":"State Persistence and Restoration"},"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/InnoRouterCore"]]},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"codeVoice","code":"StatePersistence"},{"type":"text","text":" is a thin helper that serializes "},{"type":"codeVoice","code":"FlowPlan"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"RouteStack"},{"type":"text","text":" values to "},{"type":"codeVoice","code":"Data"},{"type":"text","text":" for launch-time restoration. It deliberately"},{"type":"text","text":" "},{"type":"text","text":"stops at the value boundary so apps keep full control over where — and"},{"type":"text","text":" "},{"type":"text","text":"when — snapshots are written."}],"kind":"article","primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"InnoRouter models a running flow as a single value (","type":"text"},{"code":"FlowPlan<R>","type":"codeVoice"},{"text":" \/","type":"text"},{"text":" ","type":"text"},{"code":"RouteStack<R>","type":"codeVoice"},{"text":"). When both the routes (","type":"text"},{"code":"R","type":"codeVoice"},{"text":") and the containing types","type":"text"},{"text":" ","type":"text"},{"text":"are ","type":"text"},{"code":"Codable","type":"codeVoice"},{"text":", the entire state can round-trip through JSON. That is","type":"text"},{"text":" ","type":"text"},{"text":"enough for state restoration, deep-link payloads, and offline replay.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"StatePersistence<R>","type":"codeVoice"},{"text":" bundles a ","type":"text"},{"code":"JSONEncoder","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"JSONDecoder","type":"codeVoice"},{"text":" so","type":"text"},{"text":" ","type":"text"},{"text":"call sites don’t have to redeclare them:","type":"text"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["let persistence = StatePersistence<AppRoute>()","","\/\/ At checkpoint time (e.g. scene will deactivate):","let plan = try FlowPlan(validating: flowStore.path)","let data = try persistence.encode(plan)","try data.write(to: restorationURL, options: .atomic)","","\/\/ At launch time:","if let data = try? Data(contentsOf: restorationURL) {","    let restored = try persistence.decode(data)","    flowStore.apply(restored)","}"]},{"inlineContent":[{"text":"SwiftUI apps can wrap the value-level helper with","type":"text"},{"text":" ","type":"text"},{"code":"StateRestorationAdapter","type":"codeVoice"},{"text":" from ","type":"text"},{"code":"InnoRouterSwiftUI","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["let adapter = StateRestorationAdapter<AppRoute> { failure in","    diagnostics.record(failure)","}","","try adapter.snapshotNavigationStack(from: navigationStore)","_ = adapter.restoreFlowPlan(from: data, into: flowStore)"]},{"inlineContent":[{"type":"text","text":"The adapter supports navigation-stack and flow-plan snapshots. Decode"},{"type":"text","text":" "},{"type":"text","text":"or apply failures are reported through the restoration failure callback"},{"type":"text","text":" "},{"type":"text","text":"and leave the existing store state untouched instead of falling back to"},{"type":"text","text":" "},{"type":"text","text":"an empty path."}],"type":"paragraph"},{"level":2,"text":"Validation on decode","anchor":"Validation-on-decode","type":"heading"},{"inlineContent":[{"type":"text","text":"A "},{"code":"FlowPlan","type":"codeVoice"},{"type":"text","text":" always satisfies the FlowStore invariants:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"At most one modal step.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A modal step only at the tail of "},{"type":"codeVoice","code":"steps"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"All other steps are "},{"type":"codeVoice","code":".push"},{"type":"text","text":"."}]}]}],"type":"unorderedList"},{"inlineContent":[{"code":"FlowPlan(validating:)","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"FlowPlan.validate(_:)","type":"codeVoice"},{"text":" enforce these","type":"text"},{"text":" ","type":"text"},{"text":"invariants up front and throw ","type":"text"},{"code":"FlowPlanValidationError","type":"codeVoice"},{"text":" on","type":"text"},{"text":" ","type":"text"},{"text":"violation. Codable decode runs the same validator and converts a","type":"text"},{"text":" ","type":"text"},{"text":"violation into ","type":"text"},{"code":"DecodingError.dataCorruptedError","type":"codeVoice"},{"text":", so a","type":"text"},{"text":" ","type":"text"},{"code":"FlowPlan","type":"codeVoice"},{"text":" round-tripped through disk or network can no longer","type":"text"},{"text":" ","type":"text"},{"text":"silently produce a value that ","type":"text"},{"code":"apply(_:)","type":"codeVoice"},{"text":" will reject later. If","type":"text"},{"text":" ","type":"text"},{"text":"the snapshot format on disk drifts (older builds, hand-edited","type":"text"},{"text":" ","type":"text"},{"text":"JSON, schema migration mid-flight), the decode call surfaces the","type":"text"},{"text":" ","type":"text"},{"text":"error at restoration time — not at the next user action.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The permissive "},{"type":"codeVoice","code":"FlowPlan(steps:)"},{"type":"text","text":" initializer remains available"},{"type":"text","text":" "},{"type":"text","text":"for internal builders that already trust the origin of "},{"type":"codeVoice","code":"steps"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"text":"Scope","anchor":"Scope","type":"heading"},{"inlineContent":[{"type":"text","text":"The helper intentionally covers only the typed "},{"type":"codeVoice","code":"Data ↔ value"},{"type":"text","text":" bridge."},{"type":"text","text":" "},{"type":"text","text":"Out of scope, by design:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Where the encoded bytes live (","type":"text"},{"code":"UserDefaults","type":"codeVoice"},{"text":", a file URL, iCloud,","type":"text"},{"text":" ","type":"text"},{"text":"a database) — that is app policy.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"When snapshots are taken — tie the call into ","type":"text"},{"code":"ScenePhase","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"UIScene","type":"codeVoice"},{"text":" lifecycle, or a custom trigger.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Version-aware migration from older snapshot formats — add a","type":"text"},{"text":" ","type":"text"},{"text":"wrapper struct around ","type":"text"},{"code":"FlowPlan","type":"codeVoice"},{"text":" if the underlying routes evolve.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Selective field redaction — encode only the fragments the app is","type":"text"},{"text":" ","type":"text"},{"text":"willing to persist.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Customising the encoder","anchor":"Customising-the-encoder","type":"heading"},{"inlineContent":[{"type":"text","text":"Any "},{"type":"codeVoice","code":"JSONEncoder"},{"type":"text","text":" and "},{"type":"codeVoice","code":"JSONDecoder"},{"type":"text","text":" are acceptable inputs. Pass a"},{"type":"text","text":" "},{"type":"text","text":"preconfigured pair to the initializer for deterministic output, date"},{"type":"text","text":" "},{"type":"text","text":"strategies, or custom key coding:"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["let encoder = JSONEncoder()","encoder.outputFormatting = [.sortedKeys, .prettyPrinted]","","let decoder = JSONDecoder()","decoder.dateDecodingStrategy = .iso8601","","let persistence = StatePersistence<AppRoute>(encoder: encoder, decoder: decoder)"]},{"level":2,"text":"Error surface","anchor":"Error-surface","type":"heading"},{"inlineContent":[{"text":"Both ","type":"text"},{"code":"encode(_:)","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"decode(_:)","type":"codeVoice"},{"text":" re-throw the underlying","type":"text"},{"text":" ","type":"text"},{"code":"EncodingError","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"DecodingError","type":"codeVoice"},{"text":" so call sites keep the diagnostic","type":"text"},{"text":" ","type":"text"},{"text":"context needed to distinguish schema drift from I\/O failures.","type":"text"}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/Tutorial-StatePersistence","interfaceLanguage":"swift"},"references":{"doc://com.innosquad.innorouter.docs.core/documentation/InnoRouterTesting":{"type":"topic","identifier":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterTesting","kind":"symbol","role":"collection","title":"InnoRouterTesting","abstract":[],"url":"\/documentation\/innoroutertesting"},"doc://com.innosquad.innorouter.docs.core/documentation/InnoRouterCore/InnoRouterCore":{"type":"topic","identifier":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/Inno