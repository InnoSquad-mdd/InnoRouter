":"text","text":" (or no modifier)"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"internal"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"fileprivate enum Foo"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"fileprivate"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"private enum Foo"}]}],[{"type":"paragraph","inlineContent":[{"code":"fileprivate","type":"codeVoice"},{"text":" (lowest level the macro can emit while still letting same-file ","type":"text"},{"code":"is(_:)","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"subscript(case:)","type":"codeVoice"},{"text":" callers reach the cases)","type":"text"}]}]]],"header":"row"},{"type":"paragraph","inlineContent":[{"text":"Each case ","type":"text"},{"type":"codeVoice","code":"static let"},{"text":" also receives any ","type":"text"},{"type":"codeVoice","code":"@available(...)"},{"text":" ","type":"text"},{"text":"attribute attached to the enum case, so a case gated on an OS","type":"text"},{"text":" ","type":"text"},{"text":"version no longer produces a CasePath member with a wider","type":"text"},{"text":" ","type":"text"},{"text":"availability than the underlying case.","type":"text"}]},{"type":"heading","level":2,"text":"Compatibility for pre-OSS snapshots","anchor":"Compatibility-for-pre-OSS-snapshots"},{"type":"paragraph","inlineContent":[{"text":"Before the 4.0.0 OSS release, internal macro snapshots always emitted","type":"text"},{"text":" ","type":"text"},{"code":"public","type":"codeVoice"},{"text":". Teams that tested those snapshots should check three","type":"text"},{"text":" ","type":"text"},{"text":"patterns:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Enum and CasePath usage already match."}],"type":"strong"},{"text":" No action — the","type":"text"},{"text":" ","type":"text"},{"text":"generated members tighten to ","type":"text"},{"code":"internal","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"fileprivate","type":"codeVoice"},{"text":" \/","type":"text"},{"text":" ","type":"text"},{"code":"fileprivate","type":"codeVoice"},{"text":" matching the enum and the consumer code keeps","type":"text"},{"text":" ","type":"text"},{"text":"compiling because it was within the same module already.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Enum is not "},{"type":"codeVoice","code":"public"},{"type":"text","text":" but a sibling module reads the"},{"type":"text","text":" "},{"type":"text","text":"generated CasePath members."}],"type":"strong"},{"text":" Mark the enum ","type":"text"},{"type":"codeVoice","code":"public"},{"text":". The","type":"text"},{"text":" ","type":"text"},{"text":"pre-OSS behaviour was effectively widening the surface for you;","type":"text"},{"text":" ","type":"text"},{"text":"4.0.0 makes the boundary explicit.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Enum cases are gated on "},{"code":"@available(...)","type":"codeVoice"},{"type":"text","text":"."}],"type":"strong"},{"type":"text","text":" The generated"},{"type":"text","text":" "},{"type":"text","text":"CasePath members now carry the same availability. If a"},{"type":"text","text":" "},{"type":"text","text":"downstream call site compiled under a wider availability"},{"type":"text","text":" "},{"type":"text","text":"window before, narrow the enclosing function or branch on"},{"type":"text","text":" "},{"type":"codeVoice","code":"if #available(...)"},{"type":"text","text":" to match."}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Why `private` enums emit `fileprivate`","anchor":"Why-private-enums-emit-fileprivate"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Swift does not let an extension method (the macro emits"},{"type":"text","text":" "},{"