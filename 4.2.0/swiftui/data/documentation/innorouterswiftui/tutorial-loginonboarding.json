{"metadata":{"title":"Building a Login Onboarding Flow","role":"article","roleHeading":"Article","modules":[{"name":"InnoRouterTesting"}]},"identifier":{"url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-LoginOnboarding","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"Compose push, sheet, and cover steps into a single serializable flow with "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":", then scope the signup sub-flow through a "},{"type":"codeVoice","code":"ChildCoordinator"},{"type":"text","text":" and await its result inline."}],"kind":"article","primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Scenario","anchor":"Scenario","level":2},{"inlineContent":[{"type":"text","text":"The app launches on a welcome screen. Tapping "},{"type":"emphasis","inlineContent":[{"text":"Continue","type":"text"}]},{"type":"text","text":" pushes a"},{"type":"text","text":" "},{"type":"text","text":"pre-auth detail screen. Tapping "},{"type":"emphasis","inlineContent":[{"text":"Create account","type":"text"}]},{"type":"text","text":" presents a signup"},{"type":"text","text":" "},{"type":"text","text":"sheet. When the signup finishes (or is cancelled) the parent flow"},{"type":"text","text":" "},{"type":"text","text":"resumes — either navigating to "},{"code":".home(user)","type":"codeVoice"},{"text":" or staying put.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Modeling this with raw ","type":"text"},{"code":"NavigationStore","type":"codeVoice"},{"text":" + ","type":"text"},{"code":"ModalStore","type":"codeVoice"},{"text":" means two","type":"text"},{"text":" ","type":"text"},{"text":"authority objects, two view-layer hosts, and hand-rolled","type":"text"},{"text":" ","type":"text"},{"text":"continuation plumbing to surface the sheet result back to the","type":"text"},{"text":" ","type":"text"},{"text":"parent. ","type":"text"},{"code":"FlowStore","type":"codeVoice"},{"text":" + ","type":"text"},{"code":"ChildCoordinator","type":"codeVoice"},{"text":" collapse this to a single","type":"text"},{"text":" ","type":"text"},{"text":"store and one ","type":"text"},{"code":"await","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Routes","anchor":"Routes","level":2},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["enum AppRoute: Route {","    case welcome","    case preAuth","    case signup","    case home(UserID)","}"]},{"type":"heading","text":"Wiring the flow host","anchor":"Wiring-the-flow-host","level":2},{"inlineContent":[{"code":"FlowHost","type":"codeVoice"},{"text":" composes an inner ","type":"text"},{"code":"ModalHost","type":"codeVoice"},{"text":" over a ","type":"text"},{"code":"NavigationHost","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"text":"exposes both authorities through a single ","type":"text"},{"code":"FlowStore","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["@main","struct DemoApp: App {","    @State private var flow = FlowStore<AppRoute>(initial: [.push(.welcome)])","","    var body: some Scene {","        WindowGroup {","            FlowHost(","                store: flow,","                destination: destination,","                root: { WelcomeRootView() }","            )","        }","    }","","    @ViewBuilder","    private func destination(_ route: AppRoute) -> some View {","        switch route {","        case .welcome:","            WelcomeRootView()","        case .preAuth:","            PreAuthDetailView()","        case .signup:","            SignUpView()","        case .home(let id):","            HomeView(userID: id)","        }","    }","}"]},{"type":"heading","text":"Emitting intents from views","anchor":"Emitting-intents-from-views","level":2},{"inlineContent":[{"text":"Views never mutate ","type":"text"},{"type":"codeVoice","code":"FlowStore.path"},{"text":" directly; they emit","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"FlowIntent"},{"text":" values through the environment dispatcher so","type":"text"},{"text":" ","type":"text"},{"text":"middleware and telemetry observe every step:","type":"text"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["struct WelcomeRootView: View {","    @EnvironmentFlowIntent<AppRoute> private var flow","","    var body: some View {","        VStack {","            Button(\"Continue\") {","                flow.send(.push(.preAuth))","            }","            Button(\"Create account\") {","                flow.send(.presentSheet(.signup))","            }","        }","    }","}"]},{"type":"heading","text":"Awaiting a signup sub-flow","anchor":"Awaiting-a-signup-sub-flow","level":2},{"inlineContent":[{"text":"The signup sheet opens its own ","type":"text"},{"code":"Coordinator","type":"codeVoice"},{"text":" that owns the step","type":"text"},{"text":" ","type":"text"},{"text":"progression (email → password → confirmation). The outer","type":"text"},{"text":" ","type":"text"},{"text":"onboarding coordinator launches it via ","type":"text"},{"code":"push(child:)","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"await","type":"codeVoice"},{"text":"s","type":"text"},{"text":" ","type":"text"},{"text":"the final ","type":"text"},{"code":"UserID","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["@MainActor","final class SignUpCoordinator: ChildCoordinator {","    typealias Result = UserID","    typealias RouteType = AppRoute","","    \/\/ ...step state + methods omitted","","    func userDidCreateAccount(_ userID: UserID) {","        onFinish(userID)   \/\/ emits the result back to the parent","    }","","    func userCancelled() {","        onCancel()          \/\/ parent sees nil","    }","}","","@MainActor","final class OnboardingCoordinator: Coordinator {","    typealias RouteType = AppRoute","    let navigationStore: NavigationStore<AppRoute>","","    func startSignUpFlow() async {","        let result = await push(child: SignUpCoordinator())","        if let userID = result {","            navigationStore.send(.go(.home(userID)))","        }","    }","}"]},{"inlineContent":[{"type":"codeVoice","code":"push(child:)"},{"type":"text","text":" installs the child’s "},{"type":"codeVoice","code":"onFinish"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"onCancel"},{"type":"text","text":" "},{"type":"text","text":"callbacks synchronously, so the child can emit a result at any"},{"type":"text","text":" "},{"type":"text","text":"point — even before the parent’s "},{"type":"codeVoice","code":"await"},{"type":"text","text":" suspends — without a"},{"type":"text","text":" "},{"type":"codeVoice","code":"@MainActor"},{"type":"text","text":" re-entrancy deadlock. See"},{"type":"text","text":" "},{"type":"reference","identifier":"..\/..\/..\/..\/..\/Docs\/design-child-coordinator-handoff.md","isActive":true},{"type":"text","text":" "},{"type":"text","text":"for the design rationale."}],"type":"paragraph"},{"type":"heading","text":"Verifying the flow host-lessly","anchor":"Verifying-the-flow-host-lessly","level":2},{"inlineContent":[{"type":"codeVoice","code":"FlowTestStore"},{"type":"text","text":" (in "},{"type":"codeVoice","code":"InnoRouterTesting"},{"type":"text","text":") exercises the full chain"},{"type":"text","text":" "},{"type":"text","text":"in a unit test without mounting any SwiftUI host:"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["@Test","@MainActor","func signUpCompletesOnboarding() {","    let store = FlowTestStore<AppRoute>(initial: [.push(.welcome)])","","    store.send(.presentSheet(.signup))","    store.receiveModal { if case .presented = $0 { return true }; return false }","    store.receiveModal { if case .commandIntercepted = $0 { return true }; return false }","    store.receivePathChanged()","","    store.send(.dismiss)","    store.receiveModal { if case .dismissed = $0 { return true }; return false }","    store.receiveModal { if case .commandIntercepted = $0 { return true }; return false }","    store.receivePathChanged()","}"]},{"type":"heading","text":"Next steps","anchor":"Next-steps","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Read ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-MiddlewareComposition","type":"reference"},{"text":" to add analytics and","type":"text"},{"text":" ","type":"text"},{"text":"authentication gating to the same flow.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Read ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-DeepLinkReconciliation"},{"text":" to extend the host so a","type":"text"},{"text":" ","type":"text"},{"text":"push-notification URL can drop the user directly into ","type":"text"},{"type":"codeVoice","code":".home"},{"text":" ","type":"text"},{"text":"state on launch.","type":"text"}],"type":"paragraph"}]}]}]}],"sections":[],"variants":[{"paths":["\/documentation\/innorouterswiftui\/tutorial-loginonboarding"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"references":{"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterTesting":{"abstract":[],"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","type":"topic","title":"InnoRouterTesting","kind":"symbol","role":"collection","url":"\/documentation\/innoroutertesting"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/InnoRouterSwiftUI":{"url":"\/documentation\/innorouterswiftui\/innorouterswiftui","type":"topic","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI","role":"collectionGroup","title":"InnoRouterSwiftUI","abstract":[{"type":"text","text":"SwiftUI hosts, stores, modal routing, coordinators, and environment intent dispatch for InnoRouter."}],"kind":"article"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/Tutorial-MiddlewareComposition":{"url":"\/documentation\/innorouterswiftui\/tutorial-middlewarecomposition","role":"article","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-MiddlewareComposition","type":"topic","kind":"article","title":"Composing Middleware Across Navigation and Modal","abstract":[{"type":"text","text":"Install logging, entitlement gating, and analytics middleware on"},{"type":"text","text":" "},{"type":"text","text":"both "},{"type":"codeVoice","code":"NavigationStore"},{"type":"text","text":" and "},{"type":"codeVoice","code":"ModalStore"},{"type":"text","text":". Inspect the participant"},{"type":"text","text":" "},{"type":"text","text":"discipline that guarantees "},{"type":"codeVoice","code":"didExecute"},{"type":"text","text":" only runs for middlewares"},{"type":"text","text":" "},{"type":"text","text":"that accepted the command."}]},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/Tutorial-DeepLinkReconciliation":{"role":"article","url":"\/documentation\/innorouterswiftui\/tutorial-deeplinkreconciliation","abstract":[{"type":"text","text":"Match a URL, apply an authentication policy, and produce a"},{"type":"text","text":" "},{"code":"NavigationPlan","type":"codeVoice"},{"type":"text","text":" that "},{"code":"NavigationStore.executeBatch","type":"codeVoice"},{"type":"text","text":" applies in one"},{"type":"text","text":" "},{"type":"text","text":"observable step. Queue the deep link while the user is signed out,"},{"type":"text","text":" "},{"type":"text","text":"replay it after sign-in, and surface cancellation reasons through"},{"type":"text","text":" "},{"type":"text","text":"typed outcomes."}],"title":"Reconciling Deep Links End-to-End","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-DeepLinkReconciliation","kind":"article","type":"topic"},"../../../../../Docs/design-child-coordinator-handoff.md":{"title":"Docs\/design-child-coordinator-handoff.md","type":"link","identifier":"..\/..\/..\/..\/..\/Docs\/design-child-coordinator-handoff.md","titleInlineContent":[{"code":"Docs\/design-child-coordinator-handoff.md","type":"codeVoice"}],"url":"..\/..\/..\/..\/..\/Docs\/design-child-coordinator-handoff.md"}}}