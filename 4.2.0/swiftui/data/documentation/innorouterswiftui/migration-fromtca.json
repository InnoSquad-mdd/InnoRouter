{"abstract":[{"text":"This guide walks a TCA project through replacing its navigation","type":"text"},{"text":" ","type":"text"},{"text":"layer with InnoRouter while keeping the rest of the architecture","type":"text"},{"text":" ","type":"text"},{"text":"(reducers, effects, state) intact. InnoRouter is ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"not"}]},{"text":" a","type":"text"},{"text":" ","type":"text"},{"text":"replacement for TCA’s reducer composition — it replaces the","type":"text"},{"text":" ","type":"text"},{"text":"parts of TCA that own ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"navigation state","type":"text"}]},{"text":" and ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"modal authority"}]},{"text":".","type":"text"}],"variants":[{"paths":["\/documentation\/innorouterswiftui\/migration-fromtca"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Why-this-migration","level":2,"text":"Why this migration","type":"heading"},{"inlineContent":[{"type":"text","text":"TCA’s navigation surface ("},{"type":"codeVoice","code":"StackState<Element>"},{"type":"text","text":", "},{"type":"codeVoice","code":"@Presents"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"NavigationStackStore"},{"type":"text","text":") bundles three responsibilities:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"State authority","type":"text"}]},{"type":"text","text":" — what is on the stack, what modal is up."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Action plumbing"}]},{"type":"text","text":" — "},{"type":"codeVoice","code":"Action.path(.push(...))"},{"type":"text","text":", "},{"type":"codeVoice","code":"delegate"},{"type":"text","text":" "},{"type":"text","text":"actions, "},{"type":"codeVoice","code":".dismiss"},{"type":"text","text":" from the parent."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"View binding"}]},{"text":" — ","type":"text"},{"type":"codeVoice","code":"NavigationStackStore"},{"text":" translates child","type":"text"},{"text":" ","type":"text"},{"text":"stores into ","type":"text"},{"type":"codeVoice","code":"NavigationLink"},{"text":"s.","type":"text"}]}]}],"type":"orderedList"},{"inlineContent":[{"text":"InnoRouter takes ownership of (1) and (3) and replaces (2)","type":"text"},{"text":" ","type":"text"},{"text":"with a typed ","type":"text"},{"type":"codeVoice","code":"NavigationIntent"},{"text":" enum that flows through the","type":"text"},{"text":" ","type":"text"},{"text":"SwiftUI environment. The reducer surface shrinks because the","type":"text"},{"text":" ","type":"text"},{"text":"parent reducer no longer needs to forward navigation actions","type":"text"},{"text":" ","type":"text"},{"text":"into ","type":"text"},{"type":"codeVoice","code":"StackState"},{"text":" mutations.","type":"text"}],"type":"paragraph"},{"anchor":"The-minimal-swap","level":2,"text":"The minimal swap","type":"heading"},{"inlineContent":[{"text":"A canonical TCA navigation feature looks like this:","type":"text"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","code":["@Reducer","struct AppFeature {","    @ObservableState","    struct State: Equatable {","        var path = StackState<Path.State>()","    }","","    enum Action {","        case path(StackActionOf<Path>)","    }","","    @Reducer","    struct Path {","        enum State: Equatable { case detail(DetailFeature.State) }","        enum Action { case detail(DetailFeature.Action) }","        var body: some ReducerOf<Self> {","            Scope(state: \\.detail, action: \\.detail) { DetailFeature() }","        }","    }","","    var body: some ReducerOf<Self> {","        Reduce { state, action in \/* business logic *\/ }","            .forEach(\\.path, action: \\.path) { Path() }","    }","}","","struct AppView: View {","    @Bindable var store: StoreOf<AppFeature>","","    var body: some View {","        NavigationStackStore(store.scope(state: \\.path, action: \\.path)) {","            RootView(store: store)","        } destination: { store in","            switch store.state {","            case .detail:","                if let detail = store.scope(state: \\.detail, action: \\.detail) {","                    DetailView(store: detail)","                }","            }","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"After migration:","type":"text"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","code":["@Routable","enum AppRoute: Route {","    case detail(DetailFeature.State.ID)","}","","@Reducer","struct AppFeature {","    @ObservableState","    struct State: Equatable { \/* business state only *\/ }","","    enum Action { \/* business actions only *\/ }","","    var body: some ReducerOf<Self> {","        Reduce { state, action in \/* business logic *\/ }","    }","}","","struct AppView: View {","    @Bindable var store: StoreOf<AppFeature>","    @State private var navigationStore = NavigationStore<AppRoute>()","","    var body: some View {","        NavigationHost(store: navigationStore) {","            RootView(store: store)","        } destination: { route in","            switch route {","            case .detail(let id):","                DetailView(\/* hydrate from id *\/)","            }","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Three things changed:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The reducer’s "},{"code":"path: StackState<Path.State>","type":"codeVoice"},{"type":"text","text":" is gone — the"},{"type":"text","text":" "},{"type":"text","text":"parent reducer no longer carries navigation state."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The parent action enum no longer routes"},{"type":"text","text":" "},{"type":"codeVoice","code":"case path(StackActionOf<Path>)"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The view uses ","type":"text"},{"code":"NavigationHost","type":"codeVoice"},{"text":" + ","type":"text"},{"code":"NavigationStore<AppRoute>","type":"codeVoice"},{"text":" ","type":"text"},{"text":"in place of ","type":"text"},{"code":"NavigationStackStore","type":"codeVoice"},{"text":" + ","type":"text"},{"code":"Path","type":"codeVoice"},{"text":" reducer","type":"text"},{"text":" ","type":"text"},{"text":"composition.","type":"text"}]}]}],"type":"orderedList"},{"type":"heading","text":"Modal presentation (`@Presents` → `ModalStore`)","anchor":"Modal-presentation-Presents-%E2%86%92-ModalStore","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"TCA’s "},{"code":"@Presents","type":"codeVoice"},{"type":"text","text":" is conceptually equivalent to a "},{"code":"ModalStore","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"slot. Replace:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@ObservableState","struct State {","    @Presents var sheet: SheetFeature.State?","}","","enum Action {","    case sheet(PresentationAction<SheetFeature.Action>)","}","","\/\/ View",".sheet(item: $store.scope(state: \\.sheet, action: \\.sheet)) { … }"]},{"type":"paragraph","inlineContent":[{"text":"with:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["\/\/ State + Action no longer carry the modal slot.","","\/\/ View","ModalHost(store: modalStore) { route in","    switch route { case .sheet: SheetView(…) }","}"]},{"type":"paragraph","inlineContent":[{"text":"The reducer no longer fires ","type":"text"},{"type":"codeVoice","code":"Action.sheet(.presented(…))"},{"text":"; the","type":"text"},{"text":" ","type":"text"},{"text":"view dispatches ","type":"text"},{"type":"codeVoice","code":"flowStore.send(.presentSheet(.sheet))"},{"text":" directly","type":"text"},{"text":" ","type":"text"},{"text":"through ","type":"text"},{"type":"codeVoice","code":"@EnvironmentFlowIntent"},{"text":".","type":"text"}]},{"type":"heading","text":"Stack + modal as one value (`StackState` + `@Presents` → `FlowStore`)","anchor":"Stack-+-modal-as-one-value-StackState-+-Presents-%E2%86%92-FlowStore","level":2},{"type":"paragraph","inlineContent":[{"text":"If a feature uses both navigation and modal authority, replace","type":"text"},{"text":" ","type":"text"},{"text":"both with a single ","type":"text"},{"code":"FlowStore<Route>","type":"codeVoice"},{"text":" and observe ","type":"text"},{"code":"path: [RouteStep<Route>]","type":"codeVoice"},{"text":" as the single source of truth. The","type":"text"},{"text":" ","type":"text"},{"code":"FlowPlan","type":"codeVoice"},{"text":" value type makes the entire flow state Codable for","type":"text"},{"text":" ","type":"text"},{"text":"deep-link rehydration and state restoration.","type":"text"}]},{"type":"heading","text":"Testing — `TestStore` → `NavigationTestStore` \/ `FlowTestStore`","anchor":"Testing-TestStore-%E2%86%92-NavigationTestStore--FlowTestStore","level":2},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"InnoRouterTesting"},{"type":"text","text":" ships host-less test stores that mirror"},{"type":"text","text":" "},{"type":"text","text":"TCA’s strict-exhaustivity ergonomics. Swap:"}]},{"syntax":"swift skip doc-fragment","code":["let testStore = TestStore(initialState: AppFeature.State()) { AppFeature() }","await testStore.send(.path(.push(id: 0, state: .detail(...))))"],"type":"codeListing"},{"inlineContent":[{"text":"with:","type":"text"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","code":["let test = NavigationTestStore<AppRoute>()","test.execute(.push(.detail(id)))","test.expect(state: [.detail(id)])"],"type":"codeListing"},{"inlineContent":[{"text":"The test store keeps any analytics \/ diagnostic callbacks the","type":"text"},{"text":" ","type":"text"},{"text":"production store wired through ","type":"text"},{"code":"NavigationStoreConfiguration","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"so the test asserts production telemetry without","type":"text"},{"text":" ","type":"text"},{"code":"@testable import","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"text":"What stays in TCA","anchor":"What-stays-in-TCA","type":"heading"},{"inlineContent":[{"text":"InnoRouter explicitly does ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"not"}]},{"text":" replace:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Business logic reducers ("},{"type":"codeVoice","code":"Reduce { state, action in … }"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Side effects ("},{"code":"Effect.send","type":"codeVoice"},{"type":"text","text":", "},{"code":"Effect.run","type":"codeVoice"},{"type":"text","text":")"}]}]},{"content":[{"inlineContent":[{"text":"Dependency injection (","type":"text"},{"type":"codeVoice","code":"@Dependency"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cross-feature coordination (parent ⇄ child reducer composition"},{"type":"text","text":" "},{"type":"text","text":"for non-navigation concerns)"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"A typical migrated codebase keeps every reducer in place; the"},{"type":"text","text":" "},{"type":"text","text":"delta is the state slots and actions removed because navigation"},{"type":"text","text":" "},{"type":"text","text":"no longer needs reducer-level modeling."}],"type":"paragraph"},{"level":2,"text":"Migration sequence","anchor":"Migration-sequence","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Start with a leaf feature whose navigation state lives only"},{"type":"text","text":" "},{"type":"text","text":"in the parent reducer’s "},{"type":"codeVoice","code":"StackState"},{"type":"text","text":". Replace its view-layer"},{"type":"text","text":" "},{"type":"text","text":"wiring with "},{"type":"codeVoice","code":"NavigationHost"},{"type":"text","text":" + "},{"type":"codeVoice","code":"NavigationStore"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Strip the matching "},{"type":"codeVoice","code":"path"},{"type":"text","text":" slot and "},{"type":"codeVoice","code":"Path"},{"type":"text","text":" reducer from the"},{"type":"text","text":" "},{"type":"text","text":"parent reducer. Verify the existing tests still pass against"},{"type":"text","text":" "},{"type":"text","text":"the trimmed reducer state."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Repeat per feature. The blast radius per migration is"},{"type":"text","text":" "},{"type":"text","text":"contained because each "},{"type":"codeVoice","code":"NavigationStore"},{"type":"text","text":" is independent."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Tackle modal authority feature-by-feature once the navigation"},{"type":"text","text":" "},{"type":"text","text":"stacks are ported. "},{"type":"codeVoice","code":"@Presents"},{"type":"text","text":" is the cheapest swap."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"For features with both stack and modal authority, migrate","type":"text"},{"text":" ","type":"text"},{"text":"them last by lifting the combined state into ","type":"text"},{"code":"FlowStore","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"text":"capturing the deep-link flow through ","type":"text"},{"code":"FlowPlan","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"level":2,"text":"Common pitfalls","anchor":"Common-pitfalls","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Action forwarding instinct.","type":"text"}]},{"type":"text","text":" TCA users habitually plumb"},{"type":"text","text":" "},{"type":"text","text":"navigation through actions even when the feature doesn’t need"},{"type":"text","text":" "},{"type":"text","text":"it. With "},{"code":"@EnvironmentNavigationIntent","type":"codeVoice"},{"type":"text","text":", the view dispatches"},{"type":"text","text":" "},{"type":"text","text":"intents directly; the reducer never sees a navigation action"},{"type":"text","text":" "},{"type":"text","text":"unless you explicitly want to gate one through middleware."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Strict concurrency floor."}],"type":"strong"},{"text":" InnoRouter requires iOS 18 \/","type":"text"},{"text":" ","type":"text"},{"text":"Swift 6.2. If the project still targets iOS 13–17, plan the","type":"text"},{"text":" ","type":"text"},{"text":"platform bump as a separate PR before the navigation","type":"text"},{"text":" ","type":"text"},{"text":"migration.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"@Bindable store"},{"type":"text","text":" ergonomics."}],"type":"strong"},{"text":" ","type":"text"},{"code":"NavigationStore","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"code":"@Observable","type":"codeVoice"},{"text":" and works with ","type":"text"},{"code":"@Bindable","type":"codeVoice"},{"text":" directly — no","type":"text"},{"text":" ","type":"text"},{"code":"bindable","type":"codeVoice"},{"text":" modifier or scoped binding helpers are needed.","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"text":"Reference","anchor":"Reference","type":"heading"},{"items":[{"content":[{"inlineContent":[{"code":"NavigationStore","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"NavigationHost","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"ModalStore","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"ModalHost","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"FlowStore","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"FlowHost","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"FlowPlan","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"code":"InnoRouterTesting","type":"codeVoice"},{"type":"text","text":" ("},{"code":"NavigationTestStore","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"ModalTestStore","type":"codeVoice"},{"type":"text","text":", "},{"code":"FlowTestStore","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"kind":"article","hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"metadata":{"roleHeading":"Article","role":"article","title":"Migrating navigation from TCA to InnoRouter","modules":[{"name":"InnoRouterTesting"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Migration-FromTCA"},"sections":[],"references":{"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/InnoRouterSwiftUI":{"url":"\/documentation\/innorouterswiftui\/innorouterswiftui","type":"topic","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoR