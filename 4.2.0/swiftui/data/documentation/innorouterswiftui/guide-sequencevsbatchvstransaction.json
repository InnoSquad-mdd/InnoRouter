{"variants":[{"paths":["\/documentation\/innorouterswiftui\/guide-sequencevsbatchvstransaction"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Guide-SequenceVsBatchVsTransaction","interfaceLanguage":"swift"},"sections":[],"metadata":{"title":"Choosing Between `.sequence`, `executeBatch`, and `executeTransaction`","roleHeading":"Article","modules":[{"name":"InnoRouterTesting"}],"role":"article"},"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"kind":"article","abstract":[{"text":"Three ways to apply more than one navigation command in a row.","type":"text"},{"text":" ","type":"text"},{"text":"They are not interchangeable — pick the one whose contract matches","type":"text"},{"text":" ","type":"text"},{"text":"the call site.","type":"text"}],"primaryContentSections":[{"content":[{"type":"heading","text":"Decision matrix","anchor":"Decision-matrix","level":2},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"You want…"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Reach for"}]}],[{"type":"paragraph","inlineContent":[{"text":"Why","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"One observable change for multiple commands, best-effort"}]}],[{"type":"paragraph","inlineContent":[{"code":"NavigationStore.executeBatch(_:stopOnFailure:)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Per-step results, exactly one "},{"code":"onChange","type":"codeVoice"},{"type":"text","text":" \/ "},{"code":"events","type":"codeVoice"},{"type":"text","text":" notification, optional fail-fast"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"All-or-nothing atomic apply with rollback on failure"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NavigationStore.executeTransaction(_:)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Shadow-state preview, journal-based discard, single "},{"type":"codeVoice","code":"onTransactionExecuted"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Express the composite as one ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"command"}]},{"text":" that the engine can validate, plan, or rebuild","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"NavigationCommand.sequence([...])","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Pure value composition; flows through ","type":"text"},{"code":"NavigationEngine","type":"codeVoice"},{"text":" as a single command unit","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Schedule a single command after a quiet window"}]}],[{"type":"paragraph","inlineContent":[{"code":"DebouncingNavigator","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Async wrapping navigator, "},{"type":"codeVoice","code":"Clock"},{"type":"text","text":"-injectable"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Rate-limit per key"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ThrottleNavigationMiddleware"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Synchronous interception, last-accept timestamp"}]}]]]},{"type":"heading","text":"Mental model","anchor":"Mental-model","level":2},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".sequence"},{"type":"text","text":" is a "},{"type":"strong","inlineContent":[{"text":"value","type":"text"}]},{"type":"text","text":". It is just another "},{"type":"codeVoice","code":"NavigationCommand"},{"type":"text","text":" "},{"type":"text","text":"case, so it has the same semantics as any single command:"},{"type":"text","text":" "},{"type":"text","text":"deep-link planners can produce it, middleware can match against"},{"type":"text","text":" "},{"type":"text","text":"it, the engine evaluates it left-to-right and reports the"},{"type":"text","text":" "},{"type":"text","text":"component results as "},{"type":"codeVoice","code":".multiple([...])"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"executeBatch"},{"type":"text","text":" is an "},{"type":"strong","inlineContent":[{"text":"execution mode","type":"text"}]},{"type":"text","text":". The store iterates the"},{"type":"text","text":" "},{"type":"text","text":"commands, accepts partial success unless "},{"type":"codeVoice","code":"stopOnFailure: true"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and coalesces observation: the SwiftUI state stays correct after"},{"type":"text","text":" "},{"type":"text","text":"each step but only one "},{"type":"codeVoice","code":"onChange"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"events"},{"type":"text","text":" event surfaces at the"},{"type":"text","text":" "},{"type":"text","text":"end. Use it for analytics-clean compound actions (“complete"},{"type":"text","text":" "},{"type":"text","text":"checkout: replace stack + dismiss modal”)."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"executeTransaction"},{"type":"text","text":" is an "},{"inlineContent":[{"text":"atomicity mode","type":"text"}],"type":"strong"},{"type":"text","text":". The store applies"},{"type":"text","text":" "},{"type":"text","text":"each command to a shadow stack, journals what middleware accepted"},{"type":"text","text":" "},{"type":"text","text":"or rejected, and only commits if every step succeeds. On failure,"},{"type":"text","text":" "},{"type":"text","text":"the journal walks back through the discarded acceptances so"},{"type":"text","text":" "},{"type":"text","text":"middleware see consistent before\/after states. Use it for"},{"type":"text","text":" "},{"type":"text","text":"correctness-critical compound actions (“if any step rejects, the"},{"type":"text","text":" "},{"type":"text","text":"user sees no half-applied state”)."}]},{"type":"heading","text":"Worked examples","anchor":"Worked-examples","level":2},{"type":"heading","text":"Compose a single command that drives a deep link plan","anchor":"Compose-a-single-command-that-drives-a-deep-link-plan","level":3},{"type":"codeListing","code":["let plan = NavigationPlan<AppRoute>(commands: [","    .replace([.home]),","    .push(.detail(id))","])","\/\/ Pass the plan to a single .sequence — the engine evaluates each","\/\/ component and reports `.multiple([...])` results.","let result = store.execute(.sequence(plan.commands))"],"syntax":"swift skip doc-fragment"},{"type":"paragraph","inlineContent":[{"text":"Use when the deep-link planner already represents the path as a","type":"text"},{"text":" ","type":"text"},{"text":"sequence of ","type":"text"},{"code":"NavigationCommand","type":"codeVoice"},{"text":"s and you want the planner output","type":"text"},{"text":" ","type":"text"},{"text":"to flow through the same code path as a single command.","type":"text"}]},{"type":"heading","text":"Apply a checkout flow as one observable step","anchor":"Apply-a-checkout-flow-as-one-observable-step","level":3},{"type":"codeListing","code":["let batch = store.executeBatch([","    .replace([.home]),","    .push(.orderConfirmation),","], stopOnFailure: false)","\/\/ Exactly one `events` emission of `.batchExecuted(batch)`.","analytics.track(batch.events) \/\/ snapshot, no per-step amplification"],"syntax":"swift skip doc-fragment"},{"type":"paragraph","inlineContent":[{"text":"Use when partial success is acceptable but every step must show","type":"text"},{"text":" ","type":"text"},{"text":"up in the same analytics event.","type":"text"}]},{"type":"heading","text":"KYC step requiring all-or-nothing","anchor":"KYC-step-requiring-all-or-nothing","level":3},{"type":"codeListing","code":["let transaction = store.executeTransaction([","    .replace([.kycRoot]),","    .push(.kycDocumentUpload),","    .push(.kycReview),","])","guard transaction.isCommitted else {","    \/\/ Stack is back to its pre-transaction state; show error.","    return","}"],"syntax":"swift skip doc-fragment"},{"type":"paragraph","inlineContent":[{"text":"Use when leaving the user on a half-rolled-out screen would be","type":"text"},{"text":" ","type":"text"},{"text":"worse than showing a “please retry” message.","type":"text"}]},{"type":"heading","text":"Async debounce on a search field","anchor":"Async-debounce-on-a-search-field","level":3},{"type":"codeListing","code":["let debouncing = DebouncingNavigator(","    wrapping: store,","    interval: .milliseconds(300)",")","\/\/ Each keystroke calls debouncedExecute; only the latest survives.","await debouncing.debouncedExecute(.replace([.searchResults(query: q)]))"],"syntax":"swift skip doc-fragment"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use when the user is generating commands faster than the"},{"type":"text","text":" "},{"type":"text","text":"navigation surface should react."}]},{"type":"heading","text":"Anti-patterns","anchor":"Anti-patterns","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Wrapping "},{"type":"codeVoice","code":"executeBatch"},{"type":"text","text":" in another "},{"type":"codeVoice","code":"executeBatch"},{"type":"text","text":" to “compose”"},{"type":"text","text":" "},{"type":"text","text":"events."}],"type":"strong"},{"type":"text","text":" Use "},{"code":".sequence","type":"codeVoice"},{"type":"text","text":" inside one batch instead."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Calling "},{"type":"codeVoice","code":"executeTransaction"},{"type":"text","text":" for analytics-clean grouping."}]},{"type":"text","text":" "},{"type":"text","text":"The shadow-state cost is wasted; reach for "},{"type":"codeVoice","code":"executeBatch"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Driving a debounce window from a middleware."}],"type":"strong"},{"text":" Middleware","type":"text"},{"text":" ","type":"text"},{"text":"cannot reliably re-dispatch the deferred command; that is what","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"DebouncingNavigator"},{"text":" exists for.","type":"text"}]}]}]},{"type":"heading","text":"See also","anchor":"See-also","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NavigationStore"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"NavigationCommand"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ThrottleNavigationMiddleware"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"DebouncingNavigator"}]}]}]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/InnoRouterSwiftUI":{"url":"\/documentation\/innorouterswiftui\/innorouterswiftui","type":"topic","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI","role":"collectionGroup","title":"InnoRouterSwiftUI","abstract":[{"type":"text","text":"SwiftUI hosts, stores, modal routing, coordinators, and environment intent dispatch for InnoRouter."}],"kind":"article"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterTesting":{"abstract":[],"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","type":"topic","title