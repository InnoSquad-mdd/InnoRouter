{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Scenario","anchor":"Scenario","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"An analytics adapter wants to react to every navigation change,"},{"type":"text","text":" "},{"type":"text","text":"modal present, and flow path rewrite. Writing three "},{"type":"codeVoice","code":"for await"},{"type":"text","text":" "},{"type":"text","text":"loops, one per store, reads noisy. "},{"type":"codeVoice","code":"StoreObserver"},{"type":"text","text":" lets the adapter"},{"type":"text","text":" "},{"type":"text","text":"implement three typed "},{"type":"codeVoice","code":"handle(_:)"},{"type":"text","text":" methods and subscribe once per"},{"type":"text","text":" "},{"type":"text","text":"store."}]},{"type":"heading","text":"Implementation","anchor":"Implementation","level":2},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@MainActor","final class AnalyticsObserver: StoreObserver {","    typealias RouteType = AppRoute","","    func handle(_ event: NavigationEvent<AppRoute>) {","        if case .changed(_, let to) = event {","            Analytics.track(\"nav_change\", [\"path\": to.path.description])","        }","    }","","    func handle(_ event: ModalEvent<AppRoute>) {","        if case .presented(let presentation) = event {","            Analytics.track(\"modal_open\", [\"route\": \"\\(presentation.route)\"])","        }","    }","","    func handle(_ event: FlowEvent<AppRoute>) {","        if case .intentRejected(_, let reason) = event {","            Analytics.track(\"flow_rejected\", [\"reason\": \"\\(reason)\"])","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any subset of the three "},{"type":"codeVoice","code":"handle(_:)"},{"type":"text","text":" methods is fine — the others"},{"type":"text","text":" "},{"type":"text","text":"default to no-ops via a protocol extension."}]},{"type":"heading","text":"Attaching","anchor":"Attaching","level":2},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["let observer = AnalyticsObserver()","let navSubscription = navigationStore.observe(observer)","let modalSubscription = modalStore.observe(observer)","let flowSubscription = flowStore.observe(observer)"]},{"type":"paragraph","inlineContent":[{"text":"Each ","type":"text"},{"code":"observe(_:)","type":"codeVoice"},{"text":" returns a ","type":"text"},{"code":"StoreObserverSubscription","type":"codeVoice"},{"text":". Keep it","type":"text"},{"text":" ","type":"text"},{"text":"around for the observer’s lifetime; when the","type":"text"},{"text":" ","type":"text"},{"code":"StoreObserverSubscription","type":"codeVoice"},{"text":" itself is deinitialized it auto-cancels","type":"text"},{"text":" ","type":"text"},{"text":"via ","type":"text"},{"code":"isolated deinit","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To stop observing early:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["navSubscription.cancel()"]},{"type":"paragraph","inlineContent":[{"text":"Subsequent store events are not delivered to the observer.","type":"text"}]},{"type":"heading","text":"FlowStore routing","anchor":"FlowStore-routing","level":2},{"type":"paragraph","inlineContent":[{"code":"FlowStore.observe(_:)","type":"codeVoice"},{"text":" is special: it iterates the flow’s","type":"text"},{"text":" ","type":"text"},{"code":"events","type":"codeVoice"},{"text":" stream (which already wraps inner navigation \/ modal","type":"text"},{"text":" ","type":"text"},{"text":"emissions) and routes them through the observer’s matching typed","type":"text"},{"text":" ","type":"text"},{"code":"handle(_:)","type":"codeVoice"},{"text":" overload. One subscription covers all three authorities","type":"text"},{"text":" ","type":"text"},{"text":"on a flow surface.","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["let flowSubscription = flowStore.observe(observer)","\/\/ observer.handle(.navigation(.changed(…))) → observer.handle(_:NavigationEvent)","\/\/ observer.handle(.modal(.presented(…)))    → observer.handle(_:ModalEvent)","\/\/ observer.handle(.pathChanged(…))          → observer.handle(_:FlowEvent)"]},{"type":"heading","text":"When to reach for `for await` instead","anchor":"When-to-reach-for-for-await-instead","level":2},{"type":"paragraph","inlineContent":[{"text":"Use the raw ","type":"text"},{"code":"events","type":"codeVoice"},{"text":" stream when:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"cancellation flow needs to compose with other async sequences"},{"type":"text","text":" "},{"type":"text","text":"(combine, merge, retry, …)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"the handler body wants to "},{"code":"await","type":"codeVoice"},{"type":"text","text":" inside an event (e.g. log to"},{"type":"text","text":" "},{"type":"text","text":"a remote service and gate subsequent events on the response)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"events feed a structured concurrency pipeline with explicit task","type":"text"},{"text":" ","type":"text"},{"text":"lifetimes","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"code":"StoreObserver","type":"codeVoice"},{"type":"text","text":" when:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the adapter is a long-lived object (analytics, crash reporting)"},{"type":"text","text":" "},{"type":"text","text":"and protocol methods read clearer than an iterator loop"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"multiple stores feed the same observer with typed dispatch"}]}]}]},{"type":"heading","text":"Multiple observers","anchor":"Multiple-observers","level":2},{"type":"paragraph","inlineContent":[{"text":"Every ","type":"text"},{"code":"observe(_:)","type":"codeVoice"},{"text":" call creates an independent subscription, so","type":"text"},{"text":" ","type":"text"},{"text":"multiple observers on the same store all receive the same events.","type":"text"},{"text":" ","type":"text"},{"text":"Fan-out is free — the underlying ","type":"text"},{"code":"events","type":"codeVoice"},{"text":" ","type":"text"},{"code":"AsyncStream","type":"codeVoice"},{"text":" multicasts","type":"text"},{"text":" ","type":"text"},{"text":"through ","type":"text"},{"code":"EventBroadcaster","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"heading","text":"Next steps","anchor":"Next-steps","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-Throttling"},{"text":" for one more use case — observing","type":"text"},{"text":" ","type":"text"},{"text":"throttle cancellations through the same protocol dispatch.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-MiddlewareComposition"},{"type":"text","text":" for pre-execution hooks"},{"type":"text","text":" "},{"type":"text","text":"that complement post-execution observation."}]}]}]}]}],"variants":[{"paths":["\/documentation\/innorouterswiftui\/tutorial-storeobserver"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"InnoRouterTesting"}],"role":"article","title":"Observing Stores via Protocol Adapters","roleHeading":"Article"},"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-StoreObserver"},"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"sections":[],"kind":"article","abstract":[{"code":"StoreObserver","type":"codeVoice"},{"type":"text","text":" is a thin protocol adapter over the "},{"code":"events","type":"codeVoice"},{"type":"text","text":" "},{"code":"AsyncStream","type":"codeVoice"},{"type":"text","text":" that every InnoRouter store publishes. Use it when"},{"type":"text","text":" "},{"type":"text","text":"protocol dispatch reads clearer than a "},{"code":"for await","type":"codeVoice"},{"type":"text","text":" loop — typically"},{"type":"text","text":" "},{"type":"text","text":"in AppDelegate wiring, analytics adapters, or anywhere you want"},{"type":"text","text":" "},{"type":"text","text":"static methods instead of iterator plumbing."}],"references":{"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/Tutorial-MiddlewareComposition":{"url":"\/documentation\/innorouterswiftui\/tutorial-middlewarecomposition","role":"article","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-MiddlewareComposition","type":"topic","kind":"article","title":"Composing Middleware Across Navigation and Modal","abstract":[{"type":"text","text":"Install logging, entitlement gating, and analytics middleware on"},{"type":"text","text":" "},{"type":"text","text":"both "},{"type":"codeVoice","code":"NavigationStore"},{"type":"text","text":" and "},{"type":"codeVoice","code":"ModalStore"},{"type":"text","text":". Inspect the participant"},{"type":"text","text":" "},{"type":"text","text":"discipline that guarantees "},{"type":"codeVoice","code":"didExecute"},{"type":"text","text":" only runs for middlewares"},{"type":"text","text":" "},{"type":"text","text":"that accepted the command."}]},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/Tutorial-Throttling":{"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-Throttling","kind":"article","abstract":[{"text":"Rate-limit navigation commands without threading timestamps through","type":"text"},{"text":" ","type":"text"},{"text":"every call site. ","type":"text"},{"code":"ThrottleNavigationMiddleware","type":"codeVoice"},{"text":" cancels commands that","type":"text"},{"text":" ","type":"text"},{"text":"arrive within a minimum interval of a previously accepted command","type":"text"},{"text":" ","type":"text"},{"text":"sharing the same key.","type":"text"}],"type":"topic","url":"\/documentation\/innorouterswiftui\/tutorial-throttling","role":"article","title":"Throttling Rapid Navigation Taps"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/InnoRouterSwiftUI":{"url":"\/documentation\/innorouterswiftui\/innorouterswiftui","type":"topic","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI","role":"collectionGroup","title":"InnoRouterSwiftUI","abstract":[{"type":"text","text":"SwiftUI hosts, stores, modal routing, coordinators, and environment intent dispatch for InnoRouter."}],"kind":"article"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterTesting":{"abstract":[],"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","type":"topic","title":"InnoRouterTesting","kind":"symbol","role":"collection","url":"\/documentation\/innoroutertesting"}}}