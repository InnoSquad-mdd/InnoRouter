":"text"},{"code":"sheet","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Modal routing intentionally stays separate from stack routing:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"modal intent uses ","type":"text"},{"type":"codeVoice","code":"ModalIntent"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"stack intent uses "},{"type":"codeVoice","code":"NavigationIntent"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"modal queue state lives in "},{"type":"codeVoice","code":"ModalStore"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"stack state lives in "},{"code":"NavigationStore","type":"codeVoice"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Modal queue rules are intentionally small:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"present"},{"type":"text","text":" shows immediately when no modal is active."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"present","type":"codeVoice"},{"type":"text","text":" appends to "},{"code":"queuedPresentations","type":"codeVoice"},{"type":"text","text":" when another modal is"},{"type":"text","text":" "},{"type":"text","text":"active."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"dismissCurrent","type":"codeVoice"},{"type":"text","text":" dismisses the active modal and promotes the first"},{"type":"text","text":" "},{"type":"text","text":"queued presentation, if one exists."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"dismissAll"},{"type":"text","text":" clears both the active modal and the queue."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"replaceCurrent"},{"type":"text","text":" swaps only the active presentation and leaves the"},{"ty