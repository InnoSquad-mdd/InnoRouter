{"abstract":[{"text":"Coordinate visionOS spatial presentations through ","type":"text"},{"code":"SceneStore","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"code":"SceneHost","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"innoRouterOrnament","type":"codeVoice"},{"text":".","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/innorouterswiftui\/tutorial-visionosscenes"]}],"metadata":{"modules":[{"name":"InnoRouterTesting"}],"role":"article","title":"visionOS: windows, volumetric scenes, immersive spaces, and ornaments","roleHeading":"Article"},"identifier":{"url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-VisionOSScenes","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"primaryContentSections":[{"content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"visionOS exposes three distinct “scene” primitives that are not","type":"text"},{"text":" ","type":"text"},{"text":"modelled by ","type":"text"},{"code":"NavigationStore","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"ModalStore","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"a regular window, declared with "},{"code":"WindowGroup(id:for:)","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"a volumetric window, declared with "},{"type":"codeVoice","code":"WindowGroup(id:for:).windowStyle(.volumetric)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"an immersive space, declared with "},{"code":"ImmersiveSpace(id:)","type":"codeVoice"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"SwiftUI’s openers for these ("},{"code":"@Environment(\\.openWindow)","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"@Environment(\\.openImmersiveSpace)","type":"codeVoice"},{"type":"text","text":", "},{"code":"@Environment(\\.dismissImmersiveSpace)","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"@Environment(\\.dismissWindow)","type":"codeVoice"},{"type":"text","text":") are only reachable from a view’s"},{"type":"text","text":" "},{"code":"body","type":"codeVoice"},{"type":"text","text":". InnoRouter provides a thin "},{"code":"SceneStore","type":"codeVoice"},{"type":"text","text":" \/ "},{"code":"SceneHost","type":"codeVoice"},{"type":"text","text":" pair"},{"type":"text","text":" "},{"type":"text","text":"that mirrors the "},{"code":"NavigationStore","type":"codeVoice"},{"type":"text","text":" \/ "},{"code":"NavigationHost","type":"codeVoice"},{"type":"text","text":" discipline:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the store owns the desired scene state and publishes intents"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"the host sits in the view tree and translates intents into the","type":"text"},{"text":" ","type":"text"},{"text":"matching environment action","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"subscribers observe outcomes through "},{"type":"codeVoice","code":"SceneStore.events"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Declaring scenes in your App","level":2,"anchor":"Declaring-scenes-in-your-App","type":"heading"},{"syntax":"swift skip doc-fragment","code":["import SwiftUI","","import InnoRouter","import InnoRouterMacros","","@Routable","enum SpatialRoute {","    case main","    case theatre","}","","private let spatialScenes = SceneRegistry<SpatialRoute>(","    .window(.main, id: \"main\"),","    .immersive(.theatre, id: \"theatre\", style: .mixed)",")","","@main","struct MyApp: App {","    @State private var sceneStore = SceneStore<SpatialRoute>()","","    var body: some Scene {","        \/\/ Host-owned scene: SceneHost only. Do NOT also attach a","        \/\/ SceneAnchor here — the host already reconciles its own","        \/\/ scene's lifecycle, and a redundant anchor registers a","        \/\/ fallback dispatcher on the scene the host already owns.","        WindowGroup(id: \"main\", for: UUID.self) { $sceneID in","            ContentView()","                .innoRouterSceneHost(","                    sceneStore,","                    scenes: spatialScenes,","                    attachedTo: .main,","                    instanceID: sceneID","                )","        } defaultValue: {","            UUID()","        }","","        \/\/ Non-host scene: SceneAnchor only. Keeps the store's","        \/\/ inventory in sync with system-driven appear\/disappear and","        \/\/ can temporarily serve dismissals if the host scene is gone;","        \/\/ fallback opens are still limited to the same scene.","        ImmersiveSpace(id: \"theatre\") {","            TheatreView()","                .innoRouterSceneAnchor(","                    sceneStore,","                    scenes: spatialScenes,","                    attachedTo: .theatre","                )","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The shared "},{"type":"codeVoice","code":"SceneRegistry"},{"type":"text","text":" keeps route-to-id mapping and declaration"},{"type":"text","text":" "},{"type":"text","text":"metadata in one place."}],"type":"paragraph"},{"text":"Which modifier goes where?","level":3,"anchor":"Which-modifier-goes-where","type":"heading"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Scene declaration"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Attach "},{"type":"codeVoice","code":"SceneHost"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Attach "},{"type":"codeVoice","code":"SceneAnchor"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"The app’s primary ","type":"text"},{"code":"WindowGroup","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✅ exactly once"}]}],[{"type":"paragraph","inlineContent":[{"text":"❌ redundant","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Secondary ","type":"text"},{"code":"WindowGroup","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"❌"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"✅"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ImmersiveSpace"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"❌"}]}],[{"type":"paragraph","inlineContent":[{"text":"✅","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Any scene that isn’t the host’s scene","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"❌","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"✅","type":"text"}]}]]],"header":"row","type":"table"},{"inlineContent":[{"type":"text","text":"A mnemonic: "},{"type":"strong","inlineContent":[{"type":"text","text":"“one host per store, one anchor per non-host scene”"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"code":"SceneHost","type":"codeVoice"},{"type":"text","text":" is the single primary dispatcher; "},{"code":"SceneAnchor","type":"codeVoice"},{"type":"text","text":" is a"},{"type":"text","text":" "},{"type":"text","text":"lifecycle reconciler that also serves as a restricted fallback"},{"type":"text","text":" "},{"type":"text","text":"dispatcher for its own scene. Fallback anchors are deliberately"},{"type":"text","text":" "},{"type":"text","text":"limited to same-scene opens and any dismissal — a cross-scene open"},{"type":"text","text":" "},{"type":"text","text":"arriving while the host is gone is rejected with"},{"type":"text","text":" "},{"code":"SceneRejectionReason.fallbackCannotDispatch","type":"codeVoice"},{"type":"text","text":" so the queue advances"},{"type":"text","text":" "},{"type":"text","text":"rather than silently succeeding on a scene the anchor can’t reach."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Window and volumetric host or anchor scenes use the "},{"code":"UUID","type":"codeVoice"},{"type":"text","text":" supplied by"},{"type":"text","text":" "},{"type":"text","text":"a value-based "},{"code":"WindowGroup","type":"codeVoice"},{"type":"text","text":"; immersive spaces keep the route-only"},{"type":"text","text":" "},{"type":"text","text":"overloads."}],"type":"paragraph"},{"text":"Opening and dismissing scenes","level":2,"anchor":"Opening-and-dismissing-scenes","type":"heading"},{"inlineContent":[{"text":"From anywhere that holds a reference to the store:","type":"text"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","code":["\/\/ In the main window:","let mainWindow = sceneStore.openWindow(.main)","sceneStore.openImmersive(.theatre, style: .mixed)","","\/\/ Somewhere else later:","sceneStore.dismissWindow(mainWindow)","sceneStore.dismissImmersive()"],"type":"codeListing"},{"inlineContent":[{"type":"codeVoice","code":"VolumetricSize"},{"type":"text","text":" and "},{"type":"codeVoice","code":"ImmersiveStyle"},{"type":"text","text":" are declaration-backed metadata,"},{"type":"text","text":" "},{"type":"text","text":"not dynamic environment parameters. If a request’s kind, size, or"},{"type":"text","text":" "},{"type":"text","text":"style does not match the registry entry, the host emits"},{"type":"text","text":" "},{"type":"codeVoice","code":"SceneEvent.rejected(.open(...), reason: .sceneDeclarationMismatch)"},{"type":"text","text":" "},{"type":"text","text":"and leaves the active scene inventory untouched."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"SceneHost"},{"type":"text","text":" modifier is the preferred primary dispatcher: it"},{"type":"text","text":" "},{"type":"text","text":"observes pending request tokens, claims work, dispatches through the"},{"type":"text","text":" "},{"type":"text","text":"SwiftUI environment, and reports success back into the store."},{"type":"text","text":" "},{"type":"codeVoice","code":"SceneAnchor"},{"type":"text","text":" mirrors that dispatch loop as a fallback only when no"},{"type":"text","text":" "},{"text":"explicit host is currently alive. If ","type":"text"},{"code":"openImmersiveSpace","type":"codeVoice"},{"text":" returns","type":"text"},{"text":" ","type":"text"},{"code":".userCancelled","type":"codeVoice"},{"text":" or ","type":"text"},{"code":".error","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"the host emits a","type":"text"},{"text":" ","type":"text"},{"code":"SceneEvent.rejected(.open(.immersive(...)), reason: .environmentReturnedFailure)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"and leaves the active scene inventory untouched. ","type":"text"},{"code":"currentScene","type":"codeVoice"},{"text":" remains","type":"text"},{"text":" ","type":"text"},{"text":"a recency-ordered summary of that inventory, while ","type":"text"},{"code":"activeScenes","type":"codeVoice"},{"text":" ","type":"text"},{"text":"exposes the full inventory. Calling ","type":"text"},{"code":"dismissImmersive()","type":"codeVoice"},{"text":" without an active","type":"text"},{"text":" ","type":"text"},{"text":"immersive scene emits","type":"text"},{"text":" ","type":"text"},{"code":"SceneEvent.rejected(.dismissImmersive, reason: .nothingActive)","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"code":"SceneAnchor","type":"codeVoice"},{"text":" still never emits public lifecycle events; it reconciles","type":"text"},{"text":" ","type":"text"},{"text":"inventory when the system opens or closes a scene outside the store’s","type":"text"},{"text":" ","type":"text"},{"text":"explicit command path and can temporarily forward commands while the","type":"text"},{"text":" ","type":"text"},{"text":"preferred host scene is gone.","type":"text"}],"type":"paragraph"},{"text":"Observing lifecycle through `events`","level":2,"anchor":"Observing-lifecycle-through-events","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"SceneStore.events"},{"type":"text","text":" is an "},{"type":"codeVoice","code":"AsyncStream<SceneEvent<R>>"},{"type":"text","text":" that mirrors"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"events"},{"type":"text","text":" channel shipped by "},{"type":"codeVoice","code":"NavigationStore"},{"type":"text","text":" and "},{"type":"codeVoice","code":"ModalStore"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","code":["Task {","    for await event in sceneStore.events {","        analytics.record(event)","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The event taxonomy ("},{"type":"codeVoice","code":"presented"},{"type":"text","text":", "},{"type":"codeVoice","code":"dismissed"},{"type":"text","text":", "},{"type":"codeVoice","code":"rejected"},{"type":"text","text":") is"},{"type":"text","text":" "},{"type":"text","text":"deliberately minimal. Rejections carry the original "},{"type":"codeVoice","code":"SceneIntent"},{"type":"text","text":" so"},{"type":"text","text":" "},{"type":"text","text":"subscribers can distinguish undeclared routes, declaration mismatches,"},{"type":"text","text":" "},{"type":"text","text":"stale window handles, and environment failures without synthesising"},{"type":"text","text":" "},{"type":"text","text":"placeholder routes."}],"type":"paragraph"},{"text":"Ornaments on any platform","level":2,"anchor":"Ornaments-on-any-platform","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"View.innoRouterOrnament(_:content:)"},{"type":"text","text":" attaches an ornament on"},{"type":"text","text":" "},{"type":"text","text":"visionOS (delegating to SwiftUI’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"ornament(attachmentAnchor:contentAlignment:ornament:)"},{"type":"text","text":") and"},{"type":"text","text":" "},{"type":"text","text":"degrades to a no-op on every other platform. That keeps call sites"},{"type":"text","text":" "},{"type":"text","text":"unconditional:"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","code":["ContentView()","    .innoRouterOrnament(OrnamentAnchor(anchor: .bottom, alignment: .center)) {","        ControlBar()","    }"],"type":"codeListing"},{"inlineContent":[{"type":"codeVoice","code":"OrnamentAnchor"},{"type":"text","text":" lives in "},{"type":"codeVoice","code":"InnoRouterCore"},{"type":"text","text":" so ornament placement is"},{"type":"text","text":" "},{"type":"text","text":"serialisable and testable on platforms that never materialise the"},{"type":"text","text":" "},{"type":"text","text":"visual effect."}],"type":"paragraph"},{"text":"Composing with `FlowStore`","level":2,"anchor":"Composing-with-FlowStore","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"SceneStore"},{"type":"text","text":" is intentionally "},{"type":"strong","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" composed into "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"codeVoice","code":"RouteStep"},{"type":"text","text":" captures transitions inside a single scene (push \/ sheet"},{"type":"text","text":" "},{"type":"text","text":"\/ cover); spatial presentations are multi-scene events and would"},{"type":"text","text":" "},{"type":"text","text":"break the "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":" contract. Apps that need both simply own a"},{"type":"text","text":" "},{"type":"codeVoice","code":"FlowStore<R>"},{"type":"text","text":" and a "},{"type":"codeVoice","code":"SceneStore<R>"},{"type":"text","text":" side-by-side — the "},{"type":"codeVoice","code":"R"},{"type":"text","text":" can be"},{"type":"text","text":" "},{"type":"text","text":"the same route enum or two distinct enums, depending on whether the"},{"type":"text","text":" "},{"type":"text","text":"spatial surface shares routes with the primary flow."}],"type":"paragraph"}],"kind":"content"}],"kind":"article","references":{"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterTesting":{"abstract":[],"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","type":"topic","title":"InnoRouterTesting","kind":"symbol","role":"collection","url":"\/documentation\/innoroutertesting"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/InnoRouterSwiftUI":{"url":"\/documentation\/innorouterswiftui\/innorouterswiftui","type":"topic","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI","role":"collectionGroup","title":"InnoRouterSwiftUI","abstract":[{"type":"text","text":"SwiftUI hosts, stores, modal routing, coordinators, and environment intent dispatch for InnoRouter."}],"kind":"article"}}}