{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/innorouterswiftui\/tutorial-throttling"]}],"primaryContentSections":[{"content":[{"text":"Scenario","type":"heading","level":2,"anchor":"Scenario"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Users double-tap a “Buy” button. The first tap pushes the purchase"},{"type":"text","text":" "},{"type":"text","text":"screen; the second should be silently dropped. Rolling that logic"},{"type":"text","text":" "},{"type":"text","text":"into every button is noise — middleware is the right layer."}]},{"text":"Installation","type":"heading","level":2,"anchor":"Installation"},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["let store = NavigationStore<AppRoute>(","    configuration: NavigationStoreConfiguration(","        middlewares: [","            .init(","                middleware: AnyNavigationMiddleware(","                    ThrottleNavigationMiddleware<AppRoute>(","                        interval: .milliseconds(300)","                    )","                ),","                debugName: \"throttle\"","            )","        ]","    )",")"]},{"type":"paragraph","inlineContent":[{"text":"The default initializer uses ","type":"text"},{"type":"codeVoice","code":"ContinuousClock"},{"text":" and groups all","type":"text"},{"text":" ","type":"text"},{"text":"commands under a single global window. Within 300 ms of a previous","type":"text"},{"text":" ","type":"text"},{"text":"successfully executed command, the next one is cancelled. If the","type":"text"},{"text":" ","type":"text"},{"text":"middleware is registered with ","type":"text"},{"type":"codeVoice","code":"debugName: \"throttle\""},{"text":", the surfaced","type":"text"},{"text":" ","type":"text"},{"text":"reason becomes ","type":"text"},{"type":"codeVoice","code":".cancelled(.middleware(debugName: \"throttle\", command: …))"},{"text":".","type":"text"}]},{"text":"Per-command keys","type":"heading","level":2,"anchor":"Per-command-keys"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Group throttle windows by the command’s identity or shape:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["AnyNavigationMiddleware(","    ThrottleNavigationMiddleware<AppRoute>(interval: .milliseconds(300)) { command in","        if case .push(let route) = command {","            return \"push-\\(route)\"   \/\/ each push route gets its own window","        }","        return nil                    \/\/ other commands pass through","    }",")"]},{"type":"paragraph","inlineContent":[{"text":"Return ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" to opt a command out of throttling entirely.","type":"text"}]},{"text":"Testing with an injected clock","type":"heading","level":2,"anchor":"Testing-with-an-injected-clock"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The middleware is generic over "},{"code":"Clock","type":"codeVoice"},{"type":"text","text":", so tests can drive time"},{"type":"text","text":" "},{"type":"text","text":"deterministically:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["let clock = TestClock()","let throttle = ThrottleNavigationMiddleware<AppRoute, TestClock>(","    interval: .milliseconds(300),","    clock: clock,","    key: { _ in \"all\" }",")","store.addMiddleware(AnyNavigationMiddleware(throttle), debugName: \"throttle\")","","store.send(.go(.home))","clock.advance(by: .milliseconds(50))","store.send(.go(.detail))         \/\/ cancelled — within window","","clock.advance(by: .milliseconds(400))","store.send(.go(.settings))       \/\/ accepted — beyond window"]},{"text":"Composing with `.whenCancelled`","type":"heading","level":2,"anchor":"Composing-with-whenCancelled"},{"type":"paragraph","inlineContent":[{"text":"A throttle cancel surfaces as ","type":"text"},{"code":".cancelled","type":"codeVoice"},{"text":", so","type":"text"},{"text":" ","type":"text"},{"code":".whenCancelled(primary, fallback:)","type":"codeVoice"},{"text":" treats a throttled command the","type":"text"},{"text":" ","type":"text"},{"text":"same as any other cancelled command:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["store.execute(","    .whenCancelled(","        .push(.detail),","        fallback: .push(.home)","    )",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the throttle middleware cancels the "},{"type":"codeVoice","code":".push(.detail)"},{"type":"text","text":", the"},{"type":"text","text":" "},{"type":"text","text":"fallback "},{"type":"codeVoice","code":".push(.home)"},{"type":"text","text":" is attempted next. "},{"type":"codeVoice","code":"NavigationStore"},{"type":"text","text":" "},{"type":"text","text":"routes that fallback back through the full middleware chain, so a"},{"type":"text","text":" "},{"type":"text","text":"global throttle key can cancel the fallback too if it still lands"},{"type":"text","text":" "},{"type":"text","text":"inside the same throttle window."}]},{"text":"Debounce?","type":"heading","level":2,"anchor":"Debounce"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Debounce semantics — “wait N ms, then fire the latest” — live in"},{"type":"text","text":" "},{"type":"codeVoice","code":"DebouncingNavigator"},{"type":"text","text":", not in "},{"type":"codeVoice","code":"NavigationCommand"},{"type":"text","text":". That keeps the"},{"type":"text","text":" "},{"type":"text","text":"engine synchronous while the async wrapper owns the timer,"},{"type":"text","text":" "},{"type":"text","text":"cancellation, and "},{"type":"codeVoice","code":"Clock"},{"type":"text","text":" injection needed for deterministic tests."},{"type":"text","text":" "},{"type":"text","text":"Use throttle middleware for synchronous “reject too soon” behavior"},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"codeVoice","code":"DebouncingNavigator"},{"type":"text","text":" for delayed “latest wins” behavior."}]},{"text":"Next steps","type":"heading","level":2,"anchor":"Next-steps"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-StoreObserver"},{"text":" for a protocol-style adapter","type":"text"},{"text":" ","type":"text"},{"text":"that can observe throttle cancellations via","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NavigationStore.events"},{"text":" without threading callbacks.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-MiddlewareComposition","isActive":true},{"type":"text","text":" for the broader"},{"type":"text","text":" "},{"type":"text","text":"middleware composition story (logging, entitlement gating,"},{"type":"text","text":" "},{"type":"text","text":"analytics)."}],"type":"paragraph"}]}]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-Throttling"},"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"sections":[],"metadata":{"title":"Throttling Rapid Navigation Taps","modules":[{"name":"InnoRouterTesting"}],"roleHeading":"Article","role":"article"},"abstract":[{"type":"text","text":"Rate-limit navigation commands without threading timestamps through"},{"type":"text","text":" "},{"type":"text","text":"every call site. "},{"type":"codeVoice","cod