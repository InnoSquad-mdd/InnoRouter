{"abstract":[{"text":"Install logging, entitlement gating, and analytics middleware on","type":"text"},{"text":" ","type":"text"},{"text":"both ","type":"text"},{"code":"NavigationStore","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"ModalStore","type":"codeVoice"},{"text":". Inspect the participant","type":"text"},{"text":" ","type":"text"},{"text":"discipline that guarantees ","type":"text"},{"code":"didExecute","type":"codeVoice"},{"text":" only runs for middlewares","type":"text"},{"text":" ","type":"text"},{"text":"that accepted the command.","type":"text"}],"identifier":{"url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-MiddlewareComposition","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"variants":[{"paths":["\/documentation\/innorouterswiftui\/tutorial-middlewarecomposition"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Scenario","text":"Scenario","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Every "},{"type":"codeVoice","code":"NavigationCommand"},{"type":"text","text":" and "},{"type":"codeVoice","code":"ModalCommand"},{"type":"text","text":" should be logged"},{"type":"text","text":" "},{"type":"text","text":"before it executes. A feature-flagged screen must be gated behind"},{"type":"text","text":" "},{"type":"text","text":"an entitlement check. An analytics call must fire after the"},{"type":"text","text":" "},{"type":"text","text":"command commits — but only for middlewares that actually"},{"text":" ","type":"text"},{"text":"participated in the ","type":"text"},{"type":"codeVoice","code":"willExecute"},{"text":" decision.","type":"text"}],"type":"paragraph"},{"anchor":"Modeling-routes","text":"Modeling routes","type":"heading","level":2},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["enum AppRoute: Route {","    case home","    case premiumDetail","    case paywall","}"]},{"anchor":"Logging-middleware","text":"Logging middleware","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Reuse the "},{"type":"codeVoice","code":"AnyNavigationMiddleware"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"AnyModalMiddleware"},{"type":"text","text":" "},{"type":"text","text":"closure initializers so a minimal shared logger composes without"},{"type":"text","text":" "},{"type":"text","text":"boilerplate:"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["@MainActor","func loggingNavigationMiddleware() -> AnyNavigationMiddleware<AppRoute> {","    AnyNavigationMiddleware(","        willExecute: { command, _ in","            Log.debug(\"navigation command: \\(command)\")","            return .proceed(command)","        },","        didExecute: { command, _, result in","            Log.debug(\"navigation committed: \\(command) -> \\(result)\")","            return result","        }","    )","}","","@MainActor","func loggingModalMiddleware() -> AnyModalMiddleware<AppRoute> {","    AnyModalMiddleware(","        willExecute: { command, _, _ in","            Log.debug(\"modal command: \\(command)\")","            return .proceed(command)","        },","        didExecute: { command, _, _ in","            Log.debug(\"modal committed: \\(command)\")","        }","    )","}"]},{"anchor":"Entitlement-gating","text":"Entitlement gating","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The gate is itself a middleware; denying a command is just"},{"type":"text","text":" "},{"type":"text","text":"returning "},{"type":"codeVoice","code":".cancel(reason)"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["@MainActor","func entitlementGateNavigation(hasPremium: @escaping @MainActor () -> Bool) -> AnyNavigationMiddleware<AppRoute> {","    AnyNavigationMiddleware(willExecute: { command, _ in","        guard case .push(.premiumDetail) = command, !hasPremium() else {","            return .proceed(command)","        }","        return .cancel(.middleware(debugName: \"entitlement-gate\", command: command))","    })","}"]},{"inlineContent":[{"type":"text","text":"The cancellation surfaces through"},{"type":"text","text":" "},{"code":"onCommandIntercepted(.cancelled(...))","type":"codeVoice"},{"type":"text","text":" on the store and through"},{"type":"text","text":" "},{"code":"FlowRejectionReason.middlewareRejected(debugName: \"entitlement-gate\")","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"when used from "},{"code":"FlowStore","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Wiring-it-all","text":"Wiring it all","type":"heading","level":2},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["let navStore = NavigationStore<AppRoute>(","    configuration: .init(","        middlewares: [","            .init(middleware: loggingNavigationMiddleware(), debugName: \"logging\"),","            .init(middleware: entitlementGateNavigation(hasPremium: { EntitlementStore.shared.hasPremium }), debugName: \"entitlement-gate\"),","        ]","    )",")","","let modalStore = ModalStore<AppRoute>(","    configuration: .init(","        middlewares: [","            .init(middleware: loggingModalMiddleware(), debugName: \"logging\"),","        ]","    )",")"]},{"anchor":"Participant-discipline","text":"Participant discipline","type":"heading","level":2},{"inlineContent":[{"text":"When a middleware cancels a command, only the middlewares that","type":"text"},{"text":" ","type":"text"},{"text":"already returned ","type":"text"},{"code":".proceed","type":"codeVoice"},{"text":" observe ","type":"text"},{"code":"didExecute","type":"codeVoice"},{"text":". The ones that","type":"text"},{"text":" ","type":"text"},{"text":"either didn’t run yet (because a predecessor cancelled) or that","type":"text"},{"text":" ","type":"text"},{"text":"themselves cancelled are not consulted.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"That guarantee is why the logger safely appears "},{"type":"emphasis","inlineContent":[{"type":"text","text":"before"}]},{"type":"text","text":" the"},{"type":"text","text":" "},{"type":"text","text":"entitlement gate — the logger’s "},{"type":"codeVoice","code":"didExecute"},{"type":"text","text":" fires even if the"},{"type":"text","text":" "},{"type":"text","text":"gate cancels, so the cancellation is still recorded. Reordering"},{"type":"text","text":" "},{"type":"text","text":"to "},{"type":"codeVoice","code":"[entitlement-gate, logging]"},{"type":"text","text":" would skip the logger’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"didExecute"},{"type":"text","text":" on cancellation."}],"type":"paragraph"},{"anchor":"Observing-a-cancellation-end-to-end","text":"Observing a cancellation end-to-end","type":"heading","level":2},{"inlineContent":[{"type":"codeVoice","code":"ModalStore.events"},{"text":" surfaces ","type":"text"},{"type":"codeVoice","code":".commandIntercepted(.cancelled(...))"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"type":"codeVoice","code":"NavigationStore.events"},{"text":" surfaces the same through","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":".pathMismatch"},{"text":" (if the rewrite triggered a policy) plus the","type":"text"},{"text":" ","type":"text"},{"text":"direct cancellation. For a ","type":"text"},{"type":"codeVoice","code":"FlowStore"},{"text":" in particular,","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"FlowStore.events"},{"text":" wraps both in ","type":"text"},{"type":"codeVoice","code":".navigation(...)"},{"text":" \/ ","type":"text"},{"type":"codeVoice","code":".modal(...)"},{"text":" ","type":"text"},{"text":"cases so one subscriber sees the whole picture.","type":"text"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["Task {","    for await event in flowStore.events {","        if case .modal(.commandIntercepted(_, .cancelled(let reason))) = event {","            Log.info(\"modal cancelled: \\(reason)\")","        }","        if case .intentRejected(_, .middlewareRejected(let name)) = event {","            Log.info(\"flow intent rejected by: \\(name ?? \"nil\")\")","        }","    }","}"]},{"anchor":"Testing-middleware-with-FlowTestStore","text":"Testing middleware with FlowTestStore","type":"heading","level":2},{"inlineContent":[{"code":"FlowTestStore","type":"codeVoice"},{"text":" (in ","type":"text"},{"code":"InnoRouterTesting","type":"codeVoice"},{"text":") asserts the cancellation","type":"text"},{"text":" ","type":"text"},{"text":"chain without mounting SwiftUI:","type":"text"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["@Test","@MainActor","func entitlementGateBlocksPremiumPush() {","    let store = FlowTestStore<AppRoute>(","        configuration: .init(","            navigation: .init(middlewares: [","                .init(middleware: entitlementGateNavigation(hasPremium: { false }), debugName: \"gate\")","            ])","        )","    )","","    store.send(.push(.premiumDetail))","","    store.receiveIntentRejected(","        intent: .push(.premiumDetail),","        reason: .middlewareRejected(debugName: \"gate\")","    )","    store.expectNoMoreEvents()","}"]},{"anchor":"Next-steps","text":"Next steps","type":"heading","level":2},{"items":[{"content":[{"inlineContent":[{"text":"Read ","type":"text"},{"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-LoginOnboarding","isActive":true,"type":"reference"},{"text":" to see how middleware","type":"text"},{"text":" ","type":"text"},{"text":"interacts with a multi-step flow plus a child coordinator.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Read the "},{"type":"codeVoice","code":"Tutorial-TestingFlows"},{"type":"text","text":" guide in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"InnoRouterTesting"},{"type":"text","text":" documentation catalog for the full host-less"},{"type":"text","text":" "},{"type":"text","text":"test harness tour."}]}]}],"type":"unorderedList"}]}],"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"role":"article","modules":[{"name":"InnoRouterTesting"}],"title":"Composing Middleware Across Navigation and Modal","roleHeading":"Article"},"references":{"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/Tutorial-LoginOnboarding":{"role":"article","abstract":[{"text":"Compose push, sheet, and cover steps into a single serializable flow with ","type":"text"},{"code":"FlowStore","type":"codeVoice"},{"text":", then scope the signup sub-flow through a ","type":"text"},{"code":"ChildCoordinator","type":"codeVoice"},{"text":" and await its result inline.","type":"text"}],"title":"Building a Login Onboarding Flow","kind":"article","url":"\/documentation\/innorouterswiftui\/tutorial-loginonboarding","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-LoginOnboarding","type":"topic"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/InnoRouterSwiftUI":{"url":"\/documentation\/innorouterswiftui\/innorouterswiftui","type":"topic","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI","role":"collectionGroup","title":"InnoRouterSwiftUI","abstract":[{"type":"text","text":"SwiftUI hosts, stores, modal routing, coordinators, and environment intent dispatch for InnoRouter."}],"kind":"article"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterTesting":{"abstract":[],"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","type":"topic","title":"InnoRouterTesting","kind":"symbol","role":"collection","url":"\/documentation\/innoroutertesting"}}}