{"variants":[{"paths":["\/documentation\/innorouterswiftui\/coordinators-and-environment-intent"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"InnoRouterTesting"}],"title":"Coordinators and environment intent","roleHeading":"Article","role":"article"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Coordinator-role","type":"heading","level":2,"text":"Coordinator role"},{"inlineContent":[{"type":"codeVoice","code":"Coordinator"},{"type":"text","text":" exists for cases where view intent should flow through a policy object before it reaches the store."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A coordinator:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"receives ","type":"text"},{"type":"codeVoice","code":"NavigationIntent"}]}]},{"content":[{"inlineContent":[{"text":"decides whether to forward, rewrite, or replace commands","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"maps routes to destinations"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"stays observable for SwiftUI"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"codeVoice","code":"Coordinator"},{"type":"text","text":" remains "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" by design because it is a shared authority object, not ephemeral view state."}],"type":"paragraph"},{"anchor":"Environment-intent","type":"heading","level":2,"text":"Environment intent"},{"inlineContent":[{"type":"codeVoice","code":"EnvironmentNavigationIntent"},{"type":"text","text":" and "},{"type":"codeVoice","code":"EnvironmentModalIntent"},{"type":"text","text":" are the primary view-facing APIs."}],"type":"paragraph"},{"inlineContent":[{"text":"This keeps view code declarative:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"child views do not need a direct store reference"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"fail-fast behavior catches host wiring mistakes early","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"multi-host trees can keep separate routing authorities in the same hierarchy"}]}]}],"type":"unorderedList"},{"anchor":"Sibling-hosts-and-duplicate-registration","type":"heading","level":3,"text":"Sibling hosts and duplicate registration"},{"inlineContent":[{"text":"Each ","type":"text"},{"code":"NavigationHost","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"ModalHost","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"FlowHost","type":"codeVoice"},{"text":" owns its own","type":"text"},{"text":" ","type":"text"},{"code":"*EnvironmentStorage","type":"codeVoice"},{"text":" instance through ","type":"text"},{"code":"@State","type":"codeVoice"},{"text":", so SwiftUI scopes the","type":"text"},{"text":" ","type":"text"},{"text":"handler table to the host’s view subtree. Re-registering the","type":"text"},{"text":" ","type":"text"},{"text":"same routing authority is allowed across SwiftUI updates, even when","type":"text"},{"text":" ","type":"text"},{"text":"the forwarding closure is freshly allocated. A sibling host with a","type":"text"},{"text":" ","type":"text"},{"text":"different authority that registers against the same ","type":"text"},{"code":"Route","type":"codeVoice"},{"text":" type in","type":"text"},{"text":" ","type":"text"},{"text":"the same environment scope is treated as a wiring bug: in Debug","type":"text"},{"text":" ","type":"text"},{"text":"builds the storage setter traps with ","type":"text"},{"code":"assertionFailure","type":"codeVoice"},{"text":", and in","type":"text"},{"text":" ","type":"text"},{"text":"Release it logs an error through the ","type":"text"},{"code":"duplicate-dispatcher","type":"codeVoice"},{"text":" ","type":"text"},{"code":"os_log","type":"codeVoice"},{"text":" category before letting the overwrite proceed (preserving","type":"text"},{"text":" ","type":"text"},{"text":"prior behaviour for production cold-starts).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If two surfaces legitimately need different routing authorities,","type":"text"},{"text":" ","type":"text"},{"text":"either give them distinct ","type":"text"},{"code":"Route","type":"codeVoice"},{"text":" types or scope them with separate","type":"text"},{"text":" ","type":"text"},{"text":"environment subtrees so each host gets its own storage.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Low-level tests or custom integrations that write directly into an"},{"type":"text","text":" "},{"type":"text","text":"environment storage should either assign a handler once per storage"},{"type":"text","text":" "},{"type":"text","text":"instance, or call the explicit owner registration helper with a stable"},{"type":"text","text":" "},{"type":"text","text":"store \/ coordinator identity. The host modifiers do this for normal"},{"type":"text","text":" "},{"type":"codeVoice","code":"NavigationHost"},{"type":"text","text":", "},{"type":"codeVoice","code":"ModalHost"},{"type":"text","text":", and "},{"type":"codeVoice","code":"FlowHost"},{"type":"text","text":" usage."}],"type":"paragraph"},{"anchor":"Flow-and-tab-coordinators","type":"heading","level":2,"text":"Flow and tab coordinators"},{"inlineContent":[{"type":"codeVoice","code":"FlowCoordinator"},{"type":"text","text":" and "},{"type":"codeVoice","code":"TabCoordinator"},{"type":"text","text":" complement "},{"type":"codeVoice","code":"NavigationStore"},{"type":"text","text":"; they do not replace it."}],"type":"paragraph"},{"inlineContent":[{"text":"Recommended mental model:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"NavigationStore"},{"type":"text","text":" owns route-stack authority"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"TabCoordinator"},{"type":"text","text":" owns shell tab state"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"FlowCoordinator"},{"text":" owns local step state inside a destination","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Use composition rather than trying to collapse all three responsibilities into one type.","type":"text"}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"Coordinators in InnoRouter are SwiftUI-adapted reference authorities, not UIKit-era imperative routers."}],"identifier":{"url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Coordinators-and-Environment-Intent","interfaceLanguage":"swift"},"kind":"article","hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterTesting":{"abstract":[],"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","type":"topic","title":"InnoRouterTesting","kind":"symbol","role":"collection","url":"\/documentation\/innoroutertesting"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/InnoRouterSwiftUI":{"url":"\/documentation\/innorouterswiftui\/innorouterswiftui","type":"topic","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI","role":"collectionGroup","title":"InnoRouterSwiftUI","abstract":[{"type":"text","text":"SwiftUI hosts, stores, modal routing, coordinators, and environment intent dispatch for InnoRouter."}],"kind":"article"}}}