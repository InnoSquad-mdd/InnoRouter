{"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"abstract":[{"text":"A representative composition of ","type":"text"},{"code":"FlowStore","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"ChildCoordinator"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"FlowPlan"},{"type":"text","text":", and "},{"type":"codeVoice","code":"NavigationMiddleware"},{"type":"text","text":" for a 12-screen"},{"type":"text","text":" "},{"type":"text","text":"onboarding sequence with conditional branches, deep-link"},{"type":"text","text":" "},{"type":"text","text":"resumption, and entitlement gating."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","sections":[],"identifier":{"url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/CaseStudy-OnboardingFlow","interfaceLanguage":"swift"},"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"aside","style":"note","content":[{"inlineContent":[{"text":"This is a synthesized case study against the public InnoRouter","type":"text"},{"text":" ","type":"text"},{"text":"surface (v4.0). It does not represent a specific shipped app","type":"text"},{"text":" ","type":"text"},{"text":"but is structured to match the shape of recurring requests","type":"text"},{"text":" ","type":"text"},{"text":"from teams evaluating the framework.","type":"text"}],"type":"paragraph"}],"name":"Note"},{"type":"heading","level":2,"anchor":"The-brief","text":"The brief"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The flow:"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Launch screen.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Welcome + region picker."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Phone-number entry."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"SMS verification (modal sheet).","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Profile photo (skippable).","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Display name."}]}]},{"content":[{"inlineContent":[{"text":"Permission primer (one screen per permission requested).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Notification opt-in (system prompt, conditional next step).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Home location (skippable)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Work location (skippable).","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Subscription pitch (modal sheet, conditional).","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Welcome-home with feature tour."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Constraints:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Auth state is owned by an existing "},{"code":"AuthClient","type":"codeVoice"},{"type":"text","text":". The flow"},{"type":"text","text":" "},{"type":"text","text":"reads it but doesn’t own it."}]}]},{"content":[{"inlineContent":[{"text":"Step ordering depends on user input (region → which","type":"text"},{"text":" ","type":"text"},{"text":"permissions to request, region → subscription eligibility).","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The user can deep-link in via ","type":"text"},{"type":"codeVoice","code":"inno:\/\/onboarding\/profile"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"text":"resume mid-flow with prior steps already validated.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Analytics fires on every step entry. A push from outside the"},{"type":"text","text":" "},{"type":"text","text":"flow (e.g. a referral landing) shouldn’t double-fire entry"},{"type":"text","text":" "},{"type":"text","text":"events."}],"type":"paragraph"}]}]},{"type":"heading","level":2,"anchor":"The-composition","text":"The composition"},{"code":["@Routable","enum OnboardingRoute: Route, Codable {","    case launch","    case welcome","    case phoneNumber","    case profilePhoto","    case displayName","    case permissionPrimer(Permission)","    case homeLocation","    case workLocation","    case smsVerification(phoneNumber: String)","    case subscription(plan: SubscriptionPlan)","    case welcomeHome","}"],"type":"codeListing","syntax":"swift skip doc-fragment"},{"type":"paragraph","inlineContent":[{"text":"One route type covers both push destinations and modal-only","type":"text"},{"text":" ","type":"text"},{"text":"destinations. ","type":"text"},{"code":"FlowStore<OnboardingRoute>","type":"codeVoice"},{"text":" exposes ","type":"text"},{"code":"path: [RouteStep<OnboardingRoute>]","type":"codeVoice"},{"text":": ","type":"text"},{"code":".push(...)","type":"codeVoice"},{"text":" steps drive the","type":"text"},{"text":" ","type":"text"},{"text":"navigation stack, while ","type":"text"},{"code":".sheet(...)","type":"codeVoice"},{"text":" and ","type":"text"},{"code":".cover(...)","type":"codeVoice"},{"text":" steps","type":"text"},{"text":" ","type":"text"},{"text":"drive modal presentation. Because the single route type is","type":"text"},{"text":" ","type":"text"},{"code":"Codable","type":"codeVoice"},{"text":", the entire flow state is serializable to a","type":"text"},{"text":" ","type":"text"},{"code":"FlowPlan","type":"codeVoice"},{"text":".","type":"text"}]},{"code":["store.send(.presentSheet(.smsVerification(phoneNumber: phoneNumber)))","","let rehydrationPlan: FlowPlan<OnboardingRoute> = .init(steps: [","    .push(.launch),","    .push(.welcome),","    .sheet(.subscription(plan: subscriptionPlan)),","])"],"type":"codeListing","syntax":"swift skip doc-fragment"},{"type":"heading","level":2,"anchor":"The-driver","text":"The driver"},{"code":["@MainActor","final class OnboardingDriver: ChildCoordinator {","    typealias Route = OnboardingRoute","    typealias Result = OnboardingResult","","    let store: FlowStore<OnboardingRoute>","    private let auth: AuthClient","    private let analytics: AnalyticsClient","","    init(auth: AuthClient, analytics: AnalyticsClient) {","        self.auth = auth","        self.analytics = analytics","        self.store = FlowStore(","            configuration: FlowStoreConfiguration(","                navigation: NavigationStoreConfiguration(","                    middlewares: [","                        .init(middleware: AnalyticsMiddleware(analytics: analytics),","                              debugName: \"analytics\"),","                        .init(middleware: EntitlementGate(auth: auth),","                              debugName: \"entitlement\"),","                    ]","                ),","                onPathChanged: { [analytics] _, new in","                    analytics.record(.flowPathChanged(new))","                },","                queueCoalescePolicy: .dropQueued","            )","        )","    }","","    func start() {","        store.send(.replaceStack([.launch, .welcome]))","    }","","    func handleDeepLink(_ url: URL) async {","        guard let plan = OnboardingDeepLink.plan(from: url, auth: auth) else {","            store.send(.push(.welcome))","            return","        }","        _ = store.apply(plan)","    }","}"],"type":"codeListing","syntax":"swift skip doc-fragment"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ChildCoordinator"},{"text":" returns an ","type":"text"},{"code":"OnboardingResult","type":"codeVoice"},{"text":" to the parent","type":"text"},{"text":" ","type":"text"},{"text":"when the flow finishes:","type":"text"}]},{"code":["enum OnboardingResult {","    case completed(profile: Profile)","    case abandoned(at: OnboardingRoute)","}"],"type":"codeListing","syntax":"swift skip doc-fragment"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The parent calls"},{"type":"text","text":" "},{"type":"codeVoice","code":"parent.push(child: onboardingDriver) -> Task<OnboardingResult?>"},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"codeVoice","code":"await"},{"type":"text","text":"s the inline result, which threads cancellation back"},{"type":"text","text":" "},{"type":"text","text":"through "},{"type":"codeVoice","code":"parentDidCancel()"},{"type":"text","text":" if the user pulls down on the"},{"type":"text","text":" "},{"type":"text","text":"sheet shell."}]},{"type":"heading","level":2,"anchor":"What-the-middlewares-earn","text":"What the middlewares earn"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"AnalyticsMiddleware"},{"text":" records ","type":"text"},{"type":"codeVoice","code":".willExecute"},{"text":" and ","type":"text"},{"type":"codeVoice","code":".didExecute"},{"text":" ","type":"text"},{"text":"events for every navigation command, deduplicated against the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"onPathChanged"},{"text":" callback. Because middleware fires ","type":"text"},{"inlineContent":[{"text":"before","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"text":"state mutates, the analytics event always carries the intended","type":"text"},{"text":" ","type":"text"},{"text":"target route, not the post-cancellation snapshot.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"EntitlementGate"},{"text":" reads ","type":"text"},{"type":"codeVoice","code":"auth.isEligible(for: route)"},{"text":" for each","type":"text"},{"text":" ","type":"text"},{"text":"navigation prefix. If the user is not yet eligible for a","type":"text"},{"text":" ","type":"text"},{"text":"branch, navigation middleware cancels the ","type":"text"},{"type":"codeVoice","code":".replaceStack"},{"text":" \/","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":".reset"},{"text":" command with a typed reason; the flow falls back to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":".dropQueued"},{"text":" policy, dismissing any speculative modal state","type":"text"},{"text":" ","type":"text"},{"text":"that was queued behind the rejected navigation rewrite.","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"onIntentRejected"},{"text":" records a structured","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":".middlewareRejected(debugName: \"entitlement\")"},{"text":" event so the","type":"text"},{"text":" ","type":"text"},{"text":"analytics layer can correlate with the same span ID.","type":"text"}]},{"type":"heading","level":2,"anchor":"What-FlowPlan-earns","text":"What `FlowPlan` earns"},{"inlineContent":[{"type":"text","text":"A deep link "},{"code":"inno:\/\/onboarding\/profile","type":"codeVoice"},{"type":"text","text":" deserializes into:"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["let plan: FlowPlan<OnboardingRoute> = .init(","    steps: [","        .push(.launch),","        .push(.welcome),","        .push(.phoneNumber),","        .push(.profilePhoto),","    ]",")"]},{"inlineContent":[{"type":"codeVoice","code":"store.apply(plan)"},{"type":"text","text":" is atomic: every step previews against"},{"type":"text","text":" "},{"type":"text","text":"middleware in order, and the entire plan rolls back if any"},{"type":"text","text":" "},{"type":"text","text":"preview rejects. The user never sees a half-applied flow even"},{"type":"text","text":" "},{"type":"text","text":"if the entitlement gate decides one of the intermediate steps"},{"type":"text","text":" "},{"type":"text","text":"is currently unreachable."}],"type":"paragraph"},{"inlineContent":[{"text":"Because ","type":"text"},{"code":"OnboardingRoute","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"Codable","type":"codeVoice"},{"text":", the same ","type":"text"},{"code":"FlowPlan","type":"codeVoice"},{"text":" can","type":"text"},{"text":" ","type":"text"},{"text":"be persisted to ","type":"text"},{"code":"UserDefaults","type":"codeVoice"},{"text":" on ","type":"text"},{"code":"scenePhase: .background","type":"codeVoice"},{"text":" ","type":"text"},{"text":"and restored on the next cold launch via","type":"text"},{"text":" ","type":"text"},{"code":"FlowPlan(validating:)","type":"codeVoice"},{"text":" — the validating constructor rejects","type":"text"},{"text":" ","type":"text"},{"text":"invariant violations (e.g. two modal steps) before the","type":"text"},{"text":" ","type":"text"},{"text":"authority sees them.","type":"text"}],"type":"paragraph"},{"anchor":"What-InnoRouterTesting-earns","type":"heading","text":"What `InnoRouterTesting` earns","level":2},{"code":["@Test","func onboardingResumesFromProfile() async throws {","    let auth = AuthClient.signedIn(region: .us)","    let analytics = RecordingAnalytics()","    let test = FlowTestStore<OnboardingRoute>(","        configuration: .init(","            navigation: .init(middlewares: [","                .init(middleware: EntitlementGate(auth: auth)),","            ])","        )","    )","","    test.send(.push(.launch))","    test.expect(navigation: [.launch])","    try await test.apply(","        FlowPlan(steps: [","            .push(.launch),","            .push(.welcome),","            .push(.phoneNumber),","            .push(.profilePhoto),","        ])","    )","    test.expect(navigation: [.launch, .welcome, .phoneNumber, .profilePhoto])","    test.expect(modal: nil)","}"],"syntax":"swift skip doc-fragment","type":"codeListing"},{"inlineContent":[{"text":"No SwiftUI host in scope. The exact same store configuration —","type":"text"},{"text":" ","type":"text"},{"text":"including production analytics middleware — is exercised in","type":"text"},{"text":" ","type":"text"},{"text":"the test and in production. ","type":"text"},{"code":"FlowTestStore","type":"codeVoice"},{"text":" reuses the","type":"text"},{"text":" ","type":"text"},{"code":"FlowStoreConfiguration","type":"codeVoice"},{"text":" callbacks, so the test can also verify","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that "},{"type":"codeVoice","code":"analytics.record(.flowPathChanged(...))"},{"type":"text","text":" fired exactly"},{"type":"text","text":" "},{"type":"text","text":"once per applied step."}],"type":"paragraph"},{"anchor":"Observed-wins","type":"heading","text":"Observed wins","level":2},{"inlineContent":[{"type":"text","text":"In a comparable TCA-modeled flow before the swap, the same"},{"type":"text","text":" "},{"type":"text","text":"feature carried:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"~340 lines of "},{"type":"codeVoice","code":"Reducer"},{"type":"text","text":" boilerplate for navigation actions"},{"type":"text","text":" "},{"type":"text","text":"alone (push \/ pop \/ present \/ dismiss \/ forward \/ hydrate)."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Three custom test harnesses to assert state restoration,"},{"type":"text","text":" "},{"type":"text","text":"deep-link replay, and entitlement gating in isolation."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A bespoke “is the queue stale?” check after every cancelled"},{"type":"text","text":" "},{"type":"text","text":"command because TCA’s "},{"type":"codeVoice","code":"@Presents"},{"type":"text","text":" carry-over isn’t governed"},{"type":"text","text":" "},{"type":"text","text":"by a policy at the framework level."}]}]}]},{"inlineContent":[{"text":"The InnoRouter version drops the navigation reducer","type":"text"},{"text":" ","type":"text"},{"text":"boilerplate entirely (the framework owns the state machine),","type":"text"},{"text":" ","type":"text"},{"text":"folds the three test harnesses into one ","type":"text"},{"code":"FlowTestStore","type":"codeVoice"},{"text":" ","type":"text"},{"text":"suite, and pushes the queue-coalesce decision into a single","type":"text"},{"text":" ","type":"text"},{"code":"FlowStoreConfiguration","type":"codeVoice"},{"text":" setting that participates in the","type":"text"},{"text":" ","type":"text"},{"text":"analytics middleware’s span ID without extra wiring.","type":"text"}],"type":"paragraph"},{"anchor":"When-this-composition-is-overkill","type":"heading","text":"When this composition is overkill","level":2},{"inlineContent":[{"type":"text","text":"For a single-screen flow with no entitlement gating and no deep"},{"type":"text","text":" "},{"type":"text","text":"link, drop straight to "},{"type":"codeVoice","code":"NavigationStore<R>"},{"type":"text","text":" + "},{"type":"codeVoice","code":"NavigationHost"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":" earns its surface specifically when:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Multiple steps need atomic deep-link rehydration.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"The modal authority is genuinely concurrent with the","type":"text"},{"text":" ","type":"text"},{"text":"navigation stack (sheets, covers).","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A coordinator-level result ("},{"code":"OnboardingResult","type":"codeVoice"},{"type":"text","text":") needs to"},{"type":"text","text":" "},{"type":"text","text":"bubble back to the parent."}]}]},{"content":[{"inlineContent":[{"text":"Middleware needs to gate or telemeter the entire flow.","type":"text"}],"type":"paragraph"}]}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/innorouterswiftui\/casestudy-onboardingflow"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Article","title":"Case study: shipping a 12-screen onboarding flow","role":"article","modules":[{"name":"InnoRouterTesting"}]},"references":{"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/InnoRouterSwiftUI":{"url":"\/documentation\/innorouterswiftui\/innorouterswiftui","type":"topic","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI","role":"collectionGroup","title":"InnoRouterSwiftUI","abstract":[{"type":"text","text":"SwiftUI hosts, stores, modal routing, coordinators, and environment intent dispatch for InnoRouter."}],"kind":"article"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterTesting":{"abstract":[],"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","type":"topic","title":"InnoRouterTesting","kind":"symbol","role":"collection","url":"\/documentation\/innoroutertesting"}}}