{"primaryContentSections":[{"content":[{"anchor":"Scenario","type":"heading","level":2,"text":"Scenario"},{"inlineContent":[{"type":"codeVoice","code":"myapp:\/\/order\/42"},{"type":"text","text":" should land the user on the order detail for"},{"type":"text","text":" "},{"type":"text","text":"order 42, but only when they’re signed in. If the link arrives"},{"type":"text","text":" "},{"type":"text","text":"while signed out, the app must remember it, route through the"},{"type":"text","text":" "},{"type":"text","text":"sign-in flow, and then replay it — without dropping the original"},{"type":"text","text":" "},{"type":"text","text":"URL context."}],"type":"paragraph"},{"anchor":"Modeling-the-routes","type":"heading","level":2,"text":"Modeling the routes"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["enum AppRoute: Route {","    case home","    case signIn","    case order(id: String)","}"]},{"anchor":"Wiring-the-pipeline","type":"heading","level":2,"text":"Wiring the pipeline"},{"inlineContent":[{"type":"codeVoice","code":"DeepLinkPipeline"},{"text":" owns the match-then-validate-then-authorize flow:","type":"text"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["let matcher = DeepLinkMatcher<AppRoute>(patterns: [","    .init(pattern: \"myapp:\/\/home\")                   { _ in .home },","    .init(pattern: \"myapp:\/\/signin\")                 { _ in .signIn },","    .init(pattern: \"myapp:\/\/order\/:id\")              { params in","        guard let id = params[\"id\"] else { return nil }","        return .order(id: id)","    },","])","","let policy: DeepLinkAuthenticationPolicy<AppRoute> = { route, isAuthenticated in","    switch route {","    case .home, .signIn:","        return .proceed","    case .order where !isAuthenticated:","        return .defer \/\/ the pipeline will queue a PendingDeepLink","    case .order:","        return .proceed","    }","}","","let pipeline = DeepLinkPipeline(matcher: matcher, policy: policy)"]},{"anchor":"Handling-a-URL","type":"heading","level":2,"text":"Handling a URL"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"DeepLinkEffectHandler","type":"codeVoice"},{"text":" bridges the pipeline output into","type":"text"},{"text":" ","type":"text"},{"code":"NavigationStore","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["@MainActor","final class AppCoordinator {","    let store: NavigationStore<AppRoute>","    let pipeline: DeepLinkPipeline<AppRoute>","    let effectHandler: DeepLinkEffectHandler<AppRoute>","","    func handle(_ url: URL, isAuthenticated: Bool) {","        let outcome = pipeline.process(url: url, isAuthenticated: isAuthenticated)","","        switch outcome {","        case .plan(let plan):","            _ = store.executeBatch(plan.commands)","        case .pending(let pending):","            effectHandler.retain(pending)","            store.send(.go(.signIn))","        case .rejected(let reason):","            Log.warning(\"deep link rejected: \\(reason)\")","        case .unhandled(let url):","            Log.warning(\"deep link unhandled: \\(url)\")","        }","    }","}"]},{"anchor":"Replaying-after-sign-in","type":"heading","level":2,"text":"Replaying after sign-in"},{"inlineContent":[{"type":"text","text":"Once the user signs in, the handler resumes any queued deep link:"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["func userDidSignIn() {","    effectHandler.resumePendingDeepLinkIfAllowed(","        isAuthenticated: true,","        executor: { plan in","            _ = store.executeBatch(plan.commands)","        }","    )","}"]},{"inlineContent":[{"text":"The handler consults the retained ","type":"text"},{"type":"codeVoice","code":"PendingDeepLink"},{"text":", re-evaluates","type":"text"},{"text":" ","type":"text"},{"text":"the authentication policy, and only commits the batch if the new","type":"text"},{"text":" ","type":"text"},{"text":"state now permits the original URL. Any stale pending link (one","type":"text"},{"text":" ","type":"text"},{"text":"the user cancelled or that no longer validates) is dropped.","type":"text"}],"type":"paragraph"},{"anchor":"Observing-the-reconciliation","type":"heading","level":2,"text":"Observing the reconciliation"},{"inlineContent":[{"type":"codeVoice","code":"NavigationStore.events"},{"type":"text","text":" exposes the full sequence of batch +"},{"type":"text","text":" "},{"type":"text","text":"path-mismatch events as a single stream, which is handy for"},{"type":"text","text":" "},{"type":"text","text":"diagnostics dashboards:"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["Task {","    for await event in store.events {","        switch event {","        case .batchExecuted(let result):","            analytics.track(\"deep_link_applied\", [","                \"routes\": result.stateAfter.path.map(String.init(describing:))","            ])","        case .pathMismatch(let event):","            analytics.track(\"deep_link_mismatch\", [","                \"policy\": event.policy.rawValue,","                \"old\": event.oldPath.map(String.init(describing:)),","                \"new\": event.newPath.map(String.init(describing:))","            ])","        default:","            continue","        }","    }","}"]},{"anchor":"Testing-the-chain","type":"heading","level":2,"text":"Testing the chain"},{"inlineContent":[{"type":"codeVoice","code":"NavigationTestStore"},{"type":"text","text":" (in "},{"type":"codeVoice","code":"InnoRouterTesting"},{"type":"text","text":") asserts the batch +"},{"type":"text","text":" "},{"type":"text","text":"side effects for each branch:"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["@Test","@MainActor","func signedOutDeepLinkDefersUntilSignIn() {","    let store = NavigationTestStore<AppRoute>()","    \/\/ ...pipeline + handler wired to `store.store`","    pipeline.handle(URL(string: \"myapp:\/\/order\/42\")!, isAuthenticated: false)","","    store.receiveChange { _, new in new.path == [.signIn] }","    \/\/ Pending deep link remains queued; no .batchExecuted yet.","}"]},{"anchor":"Next-steps","type":"heading","level":2,"text":"Next steps"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Read ","type":"text"},{"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-LoginOnboarding","type":"reference","isActive":true},{"text":" for how the sign-in flow that","type":"text"},{"text":" ","type":"text"},{"text":"replays this deep link is modelled.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Read "},{"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-MigratingFromNestedHosts","type":"reference","isActive":true},{"type":"text","text":" if the existing app"},{"type":"text","text":" "},{"type":"text","text":"still uses "},{"code":"ModalHost { NavigationHost { ... } }","type":"codeVoice"},{"type":"text","text":" pairs."}],"type":"paragraph"}]}]}],"kind":"content"}],"abstract":[{"type":"text","text":"Match a URL, apply an authentication policy, and produce a"},{"type":"text","text":" "},{"type":"codeVoice","code":"NavigationPlan"},{"type":"text","text":" that "},{"type":"codeVoice","code":"NavigationStore.executeBatch"},{"type":"text","text":" applies in one"},{"type":"text","text":" "},{"type":"text","text":"observable step. Queue the deep link while the user is signed out,"},{"type":"text","text":" "},{"type":"text","text":"replay it after sign-in, and surface cancellation reasons through"},{"type":"text","text":" "},{"type":"text","text":"typed outcomes."}],"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"identifier":{"url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-DeepLinkReconciliation","interfaceLanguage":"swift"},"sections":[],"variants":[{"paths":["\/documentation\/innorouterswiftui\/tutorial-deeplinkreconciliation"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"article","metadata":{"modules":[{"name":"InnoRouterTesting"}],"roleHeading":"Article","role":"article","title":"Reconciling Deep Links End-to-End"},"references":{"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/InnoRouterSwiftUI":{"url":"\/documentation\/innorouterswiftui\/innorouterswiftui","type":"topic","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI","role":"collectionGroup","title":"InnoRouterSwiftUI","abstract":[{"type":"text","text":"SwiftUI hosts, stores, modal routing, coordinators, and environment intent dispatch for InnoRouter."}],"kind":"article"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/Tutorial-LoginOnboarding":{"role":"article","abstract":[{"text":"Compose push, sheet, and cover steps into a single serializable flow with ","type":"text"},{"code":"FlowStore","type":"codeVoice"},{"text":", then scope the signup sub-flow through a ","type":"text"},{"code":"ChildCoordinator","type":"codeVoice"},{"text":" and await its result inline.","type":"text"}],"title":"Building a Login Onboarding Flow","kind":"article","url":"\/documentation\/innorouterswiftui\/tutorial-loginonboarding","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-LoginOnboarding","type":"topic"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterTesting":{"abstract":[],"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","type":"topic","title":"InnoRouterTesting","kind":"symbol","role":"collection","url":"\/documentation\/innoroutertesting"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/Tutorial-MigratingFromNestedHosts":{"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-MigratingFromNestedHosts","kind":"article","title":"Migrating from Nested Hosts to `FlowHost`","url":"\/documentation\/innorouterswiftui\/tutorial-migratingfromnestedhosts","type":"topic","abstract":[{"type":"text","text":"Replace manually composed "},{"type":"codeVoice","code":"ModalHost { NavigationHost { ... } }"},{"type":"text","text":" "},{"type":"text","text":"surfaces with a single "},{"type":"codeVoice","code":"FlowHost"},{"type":"text","text":" backed by "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":". Preserve"},{"type":"text","text":" "},{"type":"text","text":"existing "},{"type":"codeVoice","code":"NavigationStore"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"ModalStore"},{"type":"text","text":" configurations while"},{"type":"text","text":" "},{"type":"text","text":"unlocking a serializable "},{"type":"codeVoice","code":"[RouteStep<R>]"},{"type":"text","text":" path and"},{"type":"text","text":" "},{"type":"codeVoice","code":"FlowStore.apply(_:)"},{"type":"text","text":" for restoration + deep-link hydration."}],"role":"article"}}}