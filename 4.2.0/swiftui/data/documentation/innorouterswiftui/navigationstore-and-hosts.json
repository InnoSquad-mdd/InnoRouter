{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"What the store owns","anchor":"What-the-store-owns"},{"type":"paragraph","inlineContent":[{"code":"NavigationStore","type":"codeVoice"},{"type":"text","text":" owns:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"the current ","type":"text"},{"code":"RouteStack","type":"codeVoice"},{"text":" snapshot","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"command execution"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"batch execution"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"transactional execution","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"path reconciliation from ","type":"text"},{"type":"codeVoice","code":"NavigationStack(path:)"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"middleware registry orchestration"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"telemetry and lifecycle callbacks","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Configuration is centralized in "},{"type":"codeVoice","code":"NavigationStoreConfiguration"},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"Host responsibilities","anchor":"Host-responsibilities"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NavigationHost"},{"type":"text","text":" and "},{"type":"codeVoice","code":"CoordinatorHost"},{"type":"text","text":" connect SwiftUI navigation UI to the store or coordinator:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"render the root view","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"render destinations for pushed routes"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"inject environment in