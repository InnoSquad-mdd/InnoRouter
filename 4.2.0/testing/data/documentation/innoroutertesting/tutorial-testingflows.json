{"abstract":[{"text":"Assert the complete chain triggered by a single ","type":"text"},{"type":"codeVoice","code":"FlowIntent"},{"text":" —","type":"text"},{"text":" ","type":"text"},{"text":"navigation, modal, middleware cancellation, path reconciliation —","type":"text"},{"text":" ","type":"text"},{"text":"through a single FIFO receive queue, without mounting any SwiftUI","type":"text"},{"text":" ","type":"text"},{"text":"host.","type":"text"}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Setup","anchor":"Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add "},{"code":"InnoRouterTesting","type":"codeVoice"},{"type":"text","text":" to the test target only:"}]},{"type":"codeListing","code":[".testTarget(","    name: \"AppTests\",","    dependencies: [","        .product(name: \"InnoRouter\",        package: \"InnoRouter\"),","        .product(name: \"InnoRouterTesting\", package: \"InnoRouter\"),","    ]",")"],"syntax":"swift skip doc-fragment"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then import both modules alongside Swift Testing:"}]},{"type":"codeListing","code":["import Testing","import InnoRouter","import InnoRouterTesting"],"syntax":"swift skip doc-fragment"},{"type":"heading","level":2,"text":"The happy path","anchor":"The-happy-path"},{"type":"codeListing","code":["private enum AppRoute: Route {","    case welcome, preAuth, signup","}","","@Test","@MainActor","func pushingPreAuthEmitsNavigationAndPathChange() {","    let store = FlowTestStore<AppRoute>()","","    store.send(.push(.preAuth))","","    store.receiveNavigation { event in","        if case .changed(_, let to) = event { return to.path == [.preAuth] }","        return false","    }","    store.receivePathChanged { old, new in","        old.isEmpty && new == [.push(.preAuth)]","    }","    store.expectNoMoreEvents()","}"],"syntax":"swift skip doc-fragment"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"FlowTestStore"},{"type":"text","text":" owns a real "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":" and subscribes to every"},{"type":"text","text":" "},{"type":"text","text":"observation surface it exposes (flow, inner navigation, inner"},{"type":"text","text":" "},{"type":"text","text":"modal). Events land in one FIFO queue; "},{"type":"codeVoice","code":"receive*"},{"type":"text","text":" helpers dequeue"},{"type":"text","text":" "},{"text":"them in the order the production stores emit.","type":"text"}]},{"type":"heading","level":2,"text":"Modal + cancellation","anchor":"Modal-+-cancellation"},{"type":"paragraph","inlineContent":[{"code":"FlowTestStore","type":"codeVoice"},{"text":" surfaces cancellations as first-class events, so","type":"text"},{"text":" ","type":"text"},{"text":"tests can assert them precisely:","type":"text"}]},{"type":"codeListing","code":["@MainActor","private func blockSheetMiddleware() -> AnyModalMiddleware<AppRoute> {","    AnyModalMiddleware(willExecute: { command, _, _ in","        if case .present(let p) = command, p.style == .sheet {","            return .cancel(.middleware(debugName: nil, command: command))","        }","        return .proceed(command)","    })","}","","@Test","@MainActor","func sheetBlockingMiddlewareCancelsTheIntent() {","    let store = FlowTestStore<AppRoute>(","        configuration: .init(","            modal: .init(","                middlewares: [.init(middleware: blockSheetMiddleware(), debugName: \"BlockSheet\")]","            )","        )","    )","","    store.send(.presentSheet(.signup))","","    \/\/ The preview path never commits — only .intentRejected fires.","    store.receiveIntentRejected(","        intent: .presentSheet(.signup),","        reason: .middlewareRejected(debugName: \"BlockSheet\")","    )","    #expect(store.path.isEmpty)","    store.expectNoMoreEvents()","}"],"syntax":"swift skip doc-fragment"},{"type":"heading","level":2,"text":"Skipping and draining","anchor":"Skipping-and-draining"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"skipReceivedEvents()"},{"type":"text","text":" discards everything currently queued"},{"type":"text","text":" "},{"type":"text","text":"without asserting, which is useful when a test only cares about"},{"type":"text","text":" "},{"type":"text","text":"events "},{"type":"emphasis","inlineContent":[{"type":"text","text":"after"}]},{"type":"text","text":" a setup mutation:"}]},{"type":"codeListing","code":["store.send(.presentSheet(.signup)) \/\/ enqueues .modal + .pathChanged","store.skipReceivedEvents()         \/\/ we don't care about setup","","store.send(.push(.preAuth))","store.receiveIntentRejected(intent: .push(.preAuth), reason: .pushBlockedByModalTail)"],"syntax":"swift skip doc-fragment"},{"type":"heading","level":2,"text":"Exhaustivity","anchor":"Exhaustivity"},{"type":"paragraph","inlineContent":[{"text":"Default is ","type":"text"},{"code":"TestExhaustivity.strict","type":"codeVoice"},{"text":" — any unasserted event at","type":"text"},{"text":" ","type":"text"},{"code":"finish()","type":"codeVoice"},{"text":" (or at deinit of the test store) triggers a Swift","type":"text"},{"text":" ","type":"text"},{"text":"Testing ","type":"text"},{"code":"Issue.record","type":"codeVoice"},{"text":". This catches the common mistake of","type":"text"},{"text":" ","type":"text"},{"text":"“missed that the modal also fired a ","type":"text"},{"code":".presented","type":"codeVoice"},{"text":" after the","type":"text"},{"text":" ","type":"text"},{"text":"intended intent.”","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Opt out selectively:"}]},{"type":"codeListing","code":["let store = FlowTestStore<AppRoute>(exhaustivity: .off)"],"syntax":"swift skip doc-fragment"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".off"},{"type":"text","text":" preserves per-call assertions; only the end-of-life drain"},{"type":"text","text":" "},{"type":"text","text":"check is silenced. Useful when migrating a legacy test in stages."}]},{"type":"heading","level":2,"text":"Direct state inspection","anchor":"Direct-state-inspection"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"FlowTestStore"},{"type":"text","text":" exposes the projected "},{"type":"codeVoice","code":"path"},{"type":"text","text":" for occasional direct"},{"type":"text","text":" "},{"type":"text","text":"assertions:"}]},{"type":"codeListing","code":["#expect(store.path == [.push(.preAuth)])"],"syntax":"swift skip doc-fragment"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Prefer "},{"type":"codeVoice","code":"receive*"},{"type":"text","text":" for production assertions — they cover both"},{"type":"text","text":" "},{"type":"text","text":"state and the emission order — but escape hatches are useful for"},{"type":"text","text":" "},{"type":"text","text":"sanity checks. The inner "},{"type":"codeVoice","code":"NavigationStore"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"ModalStore"},{"type":"text","text":" behind a"},{"type":"text","text":" "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":" are SPI in 4.0; use public flow events and "},{"type":"codeVoice","code":"path"},{"type":"text","text":" unless"},{"type":"text","text":" "},{"type":"text","text":"you are writing focused package-internal invariant tests."}]},{"type":"heading","level":2,"text":"Testing middleware behaviour directly","anchor":"Testing-middleware-behaviour-directly"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modal-blocking example above tests middleware "},{"type":"emphasis","inlineContent":[{"text":"through","type":"text"}]},{"type":"text","text":" a flow"},{"type":"text","text":" "},{"type":"text","text":"store. Sometimes you want to test the middleware itself — does it"},{"type":"text","text":" "},{"type":"text","text":"correctly pass through, cancel, or rewrite commands for every input"},{"type":"text","text":" "},{"type":"text","text":"shape? "},{"type":"codeVoice","code":"NavigationTestStore"},{"type":"text","text":" + "},{"type":"codeVoice","code":"ModalTestStore"},{"type":"text","text":" let you do that"},{"type":"text","text":" "},{"type":"text","text":"without a FlowStore in the middle."}]},{"type":"codeListing","code":["@MainActor","private final class RecordingMiddleware: NavigationMiddleware {","    typealias RouteType = AppRoute","","    private(set) var seenCommands: [NavigationCommand<AppRoute>] = []","","    func willExecute(","        _ command: NavigationCommand<AppRoute>,","        state: RouteStack<AppRoute>","    ) -> NavigationInterception<AppRoute> {","        seenCommands.append(command)","        if case .push(let route) = command, route == .signup {","            return .cancel(.middleware(debugName: \"BlockSignup\", command: command))","        }","        return .proceed(command)","    }","","    func didExecute(","        _ command: NavigationCommand<AppRoute>,","        result: NavigationResult<AppRoute>,","        state: RouteStack<AppRoute>","    ) -> NavigationResult<AppRoute> {","        result","    }","}","","@Test","@MainActor","func middlewareCancelsSignupButNotWelcome() {","    let middleware = RecordingMiddleware()","    let store = NavigationTestStore<AppRoute>(","        configuration: .init(","            middlewares: [.init(middleware: middleware, debugName: \"Recorder\")]","        )","    )","","    store.send(.push(.welcome))","    store.receiveChange { _, to in to.path == [.welcome] }","","    store.send(.push(.signup))","    store.receiveIntercepted(reason: .middleware(debugName: \"BlockSignup\", command: .push(.signup)))","","    #expect(middleware.seenCommands.count == 2)","    store.expectNoMoreEvents()","}"],"syntax":"swift skip doc-fragment"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Recording middlewares work naturally with "},{"type":"codeVoice","code":"@MainActor final class"},{"type":"text","text":" "},{"type":"text","text":"and mutable state. Pair them with "},{"type":"codeVoice","code":"receiveIntercepted"},{"type":"text","text":" to assert"},{"type":"text","text":" "},{"type":"text","text":"which interceptions fired and in what order, and with direct"},{"type":"text","text":" "},{"type":"text","text":"reads on the middleware instance to assert which commands it saw."}]},{"type":"heading","level":2,"text":"Property-based test recipes","anchor":"Property-based-test-recipes"},{"type":"paragraph","inlineContent":[{"type":"text","text":"InnoRouter’s own property-based suites use"},{"type":"text","text":" "},{"type":"codeVoice","code":"Tests\/InnoRouterTests\/PropertyTestSupport.swift"},{"type":"text","text":". That helper lives"},{"type":"text","text":" "},{"type":"text","text":"in this repository’s test target, not in the shipped"},{"type":"text","text":" "},{"type":"codeVoice","code":"InnoRouterTesting"},{"type":"text","text":" product, so downstream apps should copy or adapt"},{"type":"text","text":" "},{"type":"text","text":"the pattern rather than expect "},{"type":"codeVoice","code":"@testable import InnoRouterTesting"},{"type":"text","text":" "},{"type":"text","text":"to expose "},{"type":"codeVoice","code":"SeededGenerator"},{"type":"text","text":", "},{"type":"codeVoice","code":"Arbitrary"},{"type":"text","text":", or "},{"type":"codeVoice","code":"FlowModelState"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The idiom is ","type":"text"},{"inlineContent":[{"text":"Swift Testing ","type":"text"},{"code":"@Test(arguments:)","type":"codeVoice"},{"text":" iterated over many","type":"text"},{"text":" ","type":"text"},{"text":"seeds","type":"text"}],"type":"strong"},{"text":", each seed driving a deterministic random intent stream:","type":"text"}]},{"type":"codeListing","code":["@Test(arguments: 0..<100)","@MainActor","func randomFlowIntentsPreserveInvariants(seed: UInt64) async {","    var rng = SeededGenerator(seed: seed)","    let store = FlowTestStore<AppRoute>(exhaustivity: .off)","","    for _ in 0..<30 {","        let intent = Arbitrary.flowIntent(","            rng: &rng,","            routes: [.welcome, .preAuth, .signup]","        )","        store.send(intent)","    }","","    \/\/ Invariant: modal-tail is always the final step, never in the middle.","    let modalIndices = store.path.indices.filter { store.path[$0].isModal }","    #expect(modalIndices.allSatisfy { $0 == store.path.count - 1 })","}"],"syntax":"swift skip doc-fragment"},{"type":"paragraph","inlineContent":[{"text":"Swift Testing runs the 100 parameterised cases in parallel by","type":"text"},{"text":" ","type":"text"},{"text":"default, so total wall-clock time stays close to a single iteration.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A pairs-with pattern: ","type":"text"},{"type":"strong","inlineContent":[{"text":"run the random stream through both the","type":"text"},{"text":" ","type":"text"},{"text":"real store and a reference model","type":"text"}]},{"text":", then assert they agree step by","type":"text"},{"text":" ","type":"text"},{"text":"step. That’s how ","type":"text"},{"code":"FlowStorePropertyBasedTests","type":"codeVoice"},{"text":" catches subtle","type":"text"},{"text":" ","type":"text"},{"text":"divergences between the journal-driven implementation and the","type":"text"},{"text":" ","type":"text"},{"text":"intended semantics. See this repository’s PropertyTestSupport source","type":"text"},{"text":" ","type":"text"},{"text":"for the model-driven ","type":"text"},{"code":"FlowModelState","type":"codeVoice"},{"text":" pattern.","type":"text"}]},{"type":"heading","level":2,"text":"Next steps","anchor":"Next-steps"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Read the "},{"type":"codeVoice","code":"Tutorial-LoginOnboarding"},{"type":"text","text":" guide in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"InnoRouterSwiftUI"},{"type":"text","text":" documentation catalog for the end-to-end flow"},{"type":"text","text":" "},{"type":"text","text":"being tested here."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Read the "},{"type":"codeVoice","code":"Tutorial-MiddlewareComposition"},{"type":"text","text":" guide in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"InnoRouterSwiftUI"},{"type":"text","text":" documentation catalog for the middleware"},{"type":"text","text":" "},{"type":"text","text":"surfaces the harness asserts against."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Cross-reference "},{"type":"codeVoice","code":"<doc:Rejection-Reasons>"},{"type":"text","text":" (in InnoRouterCore) for"},{"type":"text","text":" "},{"type":"text","text":"the full rejection taxonomy your "},{"type":"codeVoice","code":"receiveIntentRejected"},{"type":"text","text":" \/"},{"type":"text","text":" "},{"type":"codeVoice","code":"receiveIntercepted"},{"type":"text","text":" calls can pattern-match on."}],"type":"paragraph"}]}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.innosquad.innorouter.docs.testing\/documentation\/InnoRouterTesting\/Tutorial-TestingFlows"},"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.testing\/documentation\/InnoRouterMacros"],["doc:\/\/com.innosquad.innorouter.docs.testing\/documentation\/InnoRouterMacros","doc:\/\/com.innosquad.innorouter.docs.testing\/documentation\/InnoRouterTesting\/InnoRouterTesting"]]},"metadata":{"role":"article","roleHeading":"Article","modules":[{"name":"InnoRouterMacros"}],"title":"Testing Flows End-to-End with `FlowTestStore`"},"kind":"article","schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/innoroutertesting\/tutorial-testingflows"]}],"references":{"doc://com.innosquad.innorouter.docs.testing/documentation/InnoRouterMacros":{"type":"topic","role":"collection","abstract":[],"title":"InnoRouterMacros","kind":"symbol","identifier":"doc:\/\/com.innosquad.innorouter.docs.testing\/documentation\/InnoRouterMacros","url":"\/documentation\/innoroutermacros"},"doc://com.innosquad.innorouter.docs.testing/documentation/InnoRouterTesting/InnoRouterTesting":{"identifier":"doc:\/\/com.innosquad.innorouter.docs.testing\/documentation\/InnoRouterTesting\/InnoRouterTesting","abstract":[{"text":"Host-less, Swift-Testing native assertion harness for InnoRouter’s navigation, modal, and flow authorities.","type":"text"}],"kind":"article","title":"InnoRouterTesting","role":"collectionGroup","url":"\/documentation\/innoroutertesting\/innoroutertesting","type":"topic"}}}