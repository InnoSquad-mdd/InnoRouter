{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"aside","style":"note","content":[{"inlineContent":[{"text":"This is a synthesized case study against the public InnoRouter","type":"text"},{"text":" ","type":"text"},{"text":"surface (v4.0). It does not represent a specific shipped app","type":"text"},{"text":" ","type":"text"},{"text":"but is structured to match the shape of recurring requests","type":"text"},{"text":" ","type":"text"},{"text":"from teams evaluating the framework.","type":"text"}],"type":"paragraph"}],"name":"Note"},{"type":"heading","text":"The brief","level":2,"anchor":"The-brief"},{"type":"paragraph","inlineContent":[{"text":"The flow:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Launch screen.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Welcome + region picker."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Phone-number entry."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"SMS verification (modal sheet).","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Profile photo (skippable)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Display name.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Permission primer (one screen per permission requested)."}]}]},{"content":[{"inlineContent":[{"text":"Notification opt-in (system prompt, conditional next step).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Home location (skippable)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Work location (skippable)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Subscription pitch (modal sheet, conditional).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Welcome-home with feature tour."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Constraints:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Auth state is owned by an existing "},{"type":"codeVoice","code":"AuthClient"},{"type":"text","text":". The flow"},{"type":"text","text":" "},{"type":"text","text":"reads it but doesn’t own it."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Step ordering depends on user input (region → which"},{"type":"text","text":" "},{"type":"text","text":"permissions to request, region → subscription eligibility)."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The user can deep-link in via "},{"type":"codeVoice","code":"inno:\/\/onboarding\/profile"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"text","text":"resume mid-flow with prior steps already validated."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Analytics fires on every step entry. A push from outside the"},{"type":"text","text":" "},{"type":"text","text":"flow (e.g. a referral landing) shouldn’t double-fire entry"},{"type":"text","text":" "},{"type":"text","text":"events."}],"type":"paragraph"}]}]},{"type":"heading","text":"The composition","level":2,"anchor":"The-composition"},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@Routable","enum OnboardingRoute: Route, Codable {","    case launch","    case welcome","    case phoneNumber","    case profilePhoto","    case displayName","    case permissionPrimer(Permission)","    case homeLocation","    case workLocation","    case smsVerification(phoneNumber: String)","    case subscription(plan: SubscriptionPlan)","    case welcomeHome","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"One route type covers both push destinations and modal-only"},{"type":"text","text":" "},{"type":"text","text":"destinations. "},{"type":"codeVoice","code":"FlowStore<OnboardingRoute>"},{"type":"text","text":" exposes "},{"type":"codeVoice","code":"path: [RouteStep<OnboardingRoute>]"},{"type":"text","text":": "},{"type":"codeVoice","code":".push(...)"},{"type":"text","text":" steps drive the"},{"type":"text","text":" "},{"type":"text","text":"navigation stack, while "},{"type":"codeVoice","code":".sheet(...)"},{"type":"text","text":" and "},{"type":"codeVoice","code":".cover(...)"},{"type":"text","text":" steps"},{"type":"text","text":" "},{"type":"text","text":"drive modal presentation. Because the single route type is"},{"type":"text","text":" "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":", the entire flow state is serializable to a"},{"type":"text","text":" "},{"type":"codeVoice","code":"FlowPlan"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["store.send(.presentSheet(.smsVerification(phoneNumber: phoneNumber)))","","let rehydrationPlan: FlowPlan<OnboardingRoute> = .init(steps: [","    .push(.launch),","    .push(.welcome),","    .sheet(.subscription(plan: subscriptionPlan)),","])"]},{"text":"The driver","anchor":"The-driver","type":"heading","level":2},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@MainActor","final class OnboardingDriver: ChildCoordinator {","    typealias Route = OnboardingRoute","    typealias Result = OnboardingResult","","    let store: FlowStore<OnboardingRoute>","    private let auth: AuthClient","    private let analytics: AnalyticsClient","","    init(auth: AuthClient, analytics: AnalyticsClient) {","        self.auth = auth","        self.analytics = analytics","        self.store = FlowStore(","            configuration: FlowStoreConfiguration(","                navigation: NavigationStoreConfiguration(","                    middlewares: [","                        .init(middleware: AnalyticsMiddleware(analytics: analytics),","                              debugName: \"analytics\"),","                        .init(middleware: EntitlementGate(auth: auth),","                              debugName: \"entitlement\"),","                    ]","                ),","                onPathChanged: { [analytics] _, new in","                    analytics.record(.flowPathChanged(new))","                },","                queueCoalescePolicy: .dropQueued","            )","        )","    }","","    func start() {","        store.send(.replaceStack([.launch, .welcome]))","    }","","    func handleDeepLink(_ url: URL) async {","        guard let plan = OnboardingDeepLink.plan(from: url, auth: auth) else {","            store.send(.push(.welcome))","            return","        }","        _ = store.apply(plan)","    }","}"]},{"inlineContent":[{"type":"codeVoice","code":"ChildCoordinator"},{"type":"text","text":" returns an "},{"type":"codeVoice","code":"OnboardingResult"},{"type":"text","text":" to the parent"},{"type":"text","text":" "},{"type":"text","text":"when the flow finishes:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["enum OnboardingResult {","    case completed(profile: Profile)","    case abandoned(at: OnboardingRoute)","}"]},{"inlineContent":[{"text":"The parent calls","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"parent.push(child: onboardingDriver) -> Task<OnboardingResult?>"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"type":"codeVoice","code":"await"},{"text":"s the inline result, which threads cancellation back","type":"text"},{"text":" ","type":"text"},{"text":"through ","type":"text"},{"type":"codeVoice","code":"parentDidCancel()"},{"text":" if the user pulls down on the","type":"text"},{"text":" ","type":"text"},{"text":"sheet shell.","type":"text"}],"type":"paragraph"},{"text":"What the middlewares earn","anchor":"What-the-middlewares-earn","type":"heading","level":2},{"inlineContent":[{"code":"AnalyticsMiddleware","type":"codeVoice"},{"text":" records ","type":"text"},{"code":".willExecute","type":"codeVoice"},{"text":" and ","type":"text"},{"code":".didExecute","type":"codeVoice"},{"text":" ","type":"text"},{"text":"events for every navigation command, deduplicated against the","type":"text"},{"text":" ","type":"text"},{"code":"onPathChanged","type":"codeVoice"},{"text":" callback. Because middleware fires ","type":"text"},{"inlineContent":[{"type":"text","text":"before"}],"type":"strong"},{"text":" ","type":"text"},{"text":"state mutates, the analytics event always carries the intended","type":"text"},{"text":" ","type":"text"},{"text":"target route, not the post-cancellation snapshot.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"EntitlementGate","type":"codeVoice"},{"text":" reads ","type":"text"},{"code":"auth.isEligible(for: route)","type":"codeVoice"},{"text":" for each","type":"text"},{"text":" ","type":"text"},{"text":"navigation prefix. If the user is not yet eligible for a","type":"text"},{"text":" ","type":"text"},{"text":"branch, navigation middleware cancels the ","type":"text"},{"code":".replaceStack","type":"codeVoice"},{"text":" \/","type":"text"},{"text":" ","type":"text"},{"code":".reset","type":"codeVoice"},{"text":" command with a typed reason; the flow falls back to","type":"text"},{"text":" ","type":"text"},{"code":".dropQueued","type":"codeVoice"},{"text":" policy, dismissing any speculative modal state","type":"text"},{"text":" ","type":"text"},{"text":"that was queued behind the rejected navigation rewrite.","type":"text"},{"text":" ","type":"text"},{"code":"onIntentRejected","type":"codeVoice"},{"text":" records a structured","type":"text"},{"text":" ","type":"text"},{"code":".middlewareRejected(debugName: \"entitlement\")","type":"codeVoice"},{"text":" event so the","type":"text"},{"text":" ","type":"text"},{"text":"analytics layer can correlate with the same span ID.","type":"text"}],"type":"paragraph"},{"text":"What `FlowPlan` earns","anchor":"What-FlowPlan-earns","type":"heading","level":2},{"inlineContent":[{"text":"A deep link ","type":"text"},{"code":"inno:\/\/onboarding\/profile","type":"codeVoice"},{"text":" deserializes into:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["let plan: FlowPlan<OnboardingRoute> = .init(","    steps: [","        .push(.launch),","        .push(.welcome),","        .push(.phoneNumber),","        .push(.profilePhoto),","    ]",")"]},{"inlineContent":[{"code":"store.apply(plan)","type":"codeVoice"},{"text":" is atomic: every step previews against","type":"text"},{"text":" ","type":"text"},{"text":"middleware in order, and the entire plan rolls back if any","type":"text"},{"text":" ","type":"text"},{"text":"preview rejects. The user never sees a half-applied flow even","type":"text"},{"text":" ","type":"text"},{"text":"if the entitlement gate decides one of the intermediate steps","type":"text"},{"text":" ","type":"text"},{"text":"is currently unreachable.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Because "},{"type":"codeVoice","code":"OnboardingRoute"},{"type":"text","text":" is "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":", the same "},{"type":"codeVoice","code":"FlowPlan"},{"type":"text","text":" can"},{"type":"text","text":" "},{"type":"text","text":"be persisted to "},{"type":"codeVoice","code":"UserDefaults"},{"type":"text","text":" on "},{"type":"codeVoice","code":"scenePhase: .background"},{"type":"text","text":" "},{"type":"text","text":"and restored on the next cold launch via"},{"type":"text","text":" "},{"type":"codeVoice","code":"FlowPlan(validating:)"},{"type":"text","text":" — the validating constructor rejects"},{"type":"text","text":" "},{"type":"text","text":"invariant violations (e.g. two modal steps) before the"},{"type":"text","text":" "},{"type":"text","text":"authority sees them."}],"type":"paragraph"},{"text":"What `InnoRouterTesting` earns","anchor":"What-InnoRouterTesting-earns","type":"heading","level":2},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@Test","func onboardingResumesFromProfile() async throws {","    let auth = AuthClient.signedIn(region: .us)","    let analytics = RecordingAnalytics()","    let test = FlowTestStore<OnboardingRoute>(","        configuration: .init(","            navigation: .init(middlewares: [","                .init(middleware: EntitlementGate(auth: auth)),","            ])","        )","    )","","    test.send(.push(.launch))","    test.expect(navigation: [.launch])","    try await test.apply(","        FlowPlan(steps: [","            .push(.launch),","            .push(.welcome),","            .push(.phoneNumber),","            .push(.profilePhoto),","        ])","    )","    test.expect(navigation: [.launch, .welcome, .phoneNumber, .profilePhoto])","    test.expect(modal: nil)","}"]},{"inlineContent":[{"text":"No SwiftUI host in scope. The exact same store configuration —","type":"text"},{"text":" ","type":"text"},{"text":"including production analytics middleware — is exercised in","type":"text"},{"text":" ","type":"text"},{"text":"the test and in production. ","type":"text"},{"type":"codeVoice","code":"FlowTestStore"},{"text":" reuses the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"FlowStoreConfiguration"},{"text":" callbacks, so the test can also verify","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that "},{"type":"codeVoice","code":"analytics.record(.flowPathChanged(...))"},{"type":"text","text":" fired exactly"},{"type":"text","text":" "},{"type":"text","text":"once per applied step."}],"type":"paragraph"},{"text":"Observed wins","anchor":"Observed-wins","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"In a comparable TCA-modeled flow before the swap, the same"},{"type":"text","text":" "},{"type":"text","text":"feature carried:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"~340 lines of ","type":"text"},{"type":"codeVoice","code":"Reducer"},{"text":" boilerplate for navigation actions","type":"text"},{"text":" ","type":"text"},{"text":"alone (push \/ pop \/ present \/ dismiss \/ forward \/ hydrate).","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Three custom test harnesses to assert state restoration,","type":"text"},{"text":" ","type":"text"},{"text":"deep-link replay, and entitlement gating in isolation.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"A bespoke “is the queue stale?” check after every cancelled"},{"type":"text","text":" "},{"type":"text","text":"command because TCA’s "},{"type":"codeVoice","code":"@Presents"},{"type":"text","text":" carry-over isn’t governed"},{"type":"text","text":" "},{"type":"text","text":"by a policy at the framework level."}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"The InnoRouter version drops the navigation reducer"},{"type":"text","text":" "},{"type":"text","text":"boilerplate entirely (the framework owns the state machine),"},{"type":"text","text":" "},{"type":"text","text":"folds the three test harnesses into one "},{"type":"codeVoice","code":"FlowTestStore"},{"type":"text","text":" "},{"type":"text","text":"suite, and pushes the queue-coalesce decision into a single"},{"text":" ","type":"text"},{"code":"FlowStoreConfiguration","type":"codeVoice"},{"text":" setting that participates in the","type":"text"},{"text":" ","type":"text"},{"text":"analytics middleware’s span ID without extra wiring.","type":"text"}],"type":"paragraph"},{"anchor":"When-this-composition-is-overkill","type":"heading","level":2,"text":"When this composition is overkill"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For a single-screen flow with no entitlement gating and no deep"},{"type":"text","text":" "},{"type":"text","text":"link, drop straight to "},{"type":"codeVoice","code":"NavigationStore<R>"},{"type":"text","text":" + "},{"type":"codeVoice","code":"NavigationHost"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":" earns its surface specifically when:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Multiple steps need atomic deep-link rehydration."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The modal authority is genuinely concurrent with the"},{"type":"text","text":" "},{"type":"text","text":"navigation stack (sheets, covers)."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"A coordinator-level result ("},{"type":"codeVoice","code":"OnboardingResult"},{"type":"text","text":") needs to"},{"type":"text","text":" "},{"type":"text","text":"bubble back to the parent."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Middleware needs to gate or telemeter the entire flow."}]}]}]}]}],"kind":"article","abstract":[{"text":"A representative composition of ","type":"text"},{"type":"codeVoice","code":"FlowStore"},{"text":", ","type":"text"},{"type":"codeVoice","code":"ChildCoordinator"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"FlowPlan"},{"text":", and ","type":"text"},{"type":"codeVoice","code":"NavigationMiddleware"},{"text":" for a 12-screen","type":"text"},{"text":" ","type":"text"},{"text":"onboarding sequence with conditional branches, deep-link","type":"text"},{"text":" ","type":"text"},{"text":"resumption, and entitlement gating.","type":"text"}],"variants":[{"paths":["\/documentation\/innorouterswiftui\/casestudy-onboardingflow"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/CaseStudy-OnboardingFlow","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"InnoRouterTesting"}],"role":"article","title":"Case study: shipping a 12-screen onboarding flow","roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"sections":[],"references":{"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterTesting":{"type":"topic","kind":"symbol","url":"\/documentation\/innoroutertesting","role":"collection","title":"InnoRouterTesting","abstract":[],"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/InnoRouterSwiftUI":{"abstract":[{"text":"SwiftUI hosts, stores, modal routing, coordinators, and environment intent dispatch for InnoRouter.","type":"text"}],"kind":"article","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI","url":"\/documentation\/innorouterswiftui\/innorouterswiftui","title":"InnoRouterSwiftUI","type":"topic","role":"collectionGroup"}}}