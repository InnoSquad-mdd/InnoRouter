{"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Scenario","anchor":"Scenario"},{"type":"paragraph","inlineContent":[{"text":"Every ","type":"text"},{"type":"codeVoice","code":"NavigationCommand"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"ModalCommand"},{"text":" should be logged","type":"text"},{"text":" ","type":"text"},{"text":"before it executes. A feature-flagged screen must be gated behind","type":"text"},{"text":" ","type":"text"},{"text":"an entitlement check. An analytics call must fire after the","type":"text"},{"text":" ","type":"text"},{"text":"command commits — but only for middlewares that actually","type":"text"},{"text":" ","type":"text"},{"text":"participated in the ","type":"text"},{"type":"codeVoice","code":"willExecute"},{"text":" decision.","type":"text"}]},{"type":"heading","level":2,"text":"Modeling routes","anchor":"Modeling-routes"},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["enum AppRoute: Route {","    case home","    case premiumDetail","    case paywall","}"]},{"type":"heading","level":2,"text":"Logging middleware","anchor":"Logging-middleware"},{"type":"paragraph","inlineContent":[{"text":"Reuse the ","type":"text"},{"code":"AnyNavigationMiddleware","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"AnyModalMiddleware","type":"codeVoice"},{"text":" ","type":"text"},{"text":"closure initializers so a minimal shared logger composes without","type":"text"},{"text":" ","type":"text"},{"text":"boilerplate:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@MainActor","func loggingNavigationMiddleware() -> AnyNavigationMiddleware<AppRoute> {","    AnyNavigationMiddleware(","        willExecute: { command, _ in","            Log.debug(\"navigation command: \\(command)\")","            return .proceed(command)","        },","        didExecute: { command, _, result in","            Log.debug(\"navigation committed: \\(command) -> \\(result)\")","            return result","        }","    )","}","","@MainActor","func loggingModalMiddleware() -> AnyModalMiddleware<AppRoute> {","    AnyModalMiddleware(","        willExecute: { command, _, _ in","            Log.debug(\"modal command: \\(command)\")","            return .proceed(command)","        },","        didExecute: { command, _, _ in","            Log.debug(\"modal committed: \\(command)\")","        }","    )","}"]},{"type":"heading","level":2,"text":"Entitlement gating","anchor":"Entitlement-gating"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The gate is itself a middleware; denying a command is just"},{"type":"text","text":" "},{"type":"text","text":"returning "},{"type":"codeVoice","code":".cancel(reason)"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@MainActor","func entitlementGateNavigation(hasPremium: @escaping @MainActor () -> Bool) -> AnyNavigationMiddleware<AppRoute> {","    AnyNavigationMiddleware(willExecute: { command, _ in","        guard case .push(.premiumDetail) = command, !hasPremium() else {","            return .proceed(command)","        }","        return .cancel(.middleware(debugName: \"entitlement-gate\", command: command))","    })","}"]},{"type":"paragraph","inlineContent":[{"text":"The cancellation surfaces through","type":"text"},{"text":" ","type":"text"},{"code":"onCommandIntercepted(.cancelled(...))","type":"codeVoice"},{"text":" on the store and through","type":"text"},{"text":" ","type":"text"},{"code":"FlowRejectionReason.middlewareRejected(debugName: \"entitlement-gate\")","type":"codeVoice"},{"text":" ","type":"text"},{"text":"when used from ","type":"text"},{"code":"FlowStore","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"heading","level":2,"text":"Wiring it all","anchor":"Wiring-it-all"},{"code":["let navStore = NavigationStore<AppRoute>(","    configuration: .init(","        middlewares: [","            .init(middleware: loggingNavigationMiddleware(), debugName: \"logging\"),","            .init(middleware: entitlementGateNavigation(hasPremium: { EntitlementStore.shared.hasPremium }), debugName: \"entitlement-gate\"),","        ]","    )",")","","let modalStore = ModalStore<AppRoute>(","    configuration: .init(","        middlewares: [","            .init(middleware: loggingModalMiddleware(), debugName: \"logging\"),","        ]","    )",")"],"type":"codeListing","syntax":"swift skip doc-fragment"},{"type":"heading","level":2,"text":"Participant discipline","anchor":"Participant-discipline"},{"inlineContent":[{"text":"When a middleware cancels a command, only the middlewares that","type":"text"},{"text":" ","type":"text"},{"text":"already returned ","type":"text"},{"code":".proceed","type":"codeVoice"},{"text":" observe ","type":"text"},{"code":"didExecute","type":"codeVoice"},{"text":". The ones that","type":"text"},{"text":" ","type":"text"},{"text":"either didn’t run yet (because a predecessor cancelled) or that","type":"text"},{"text":" ","type":"text"},{"text":"themselves cancelled are not consulted.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"That guarantee is why the logger safely appears ","type":"text"},{"inlineContent":[{"text":"before","type":"text"}],"type":"emphasis"},{"text":" the","type":"text"},{"text":" ","type":"text"},{"text":"entitlement gate — the logger’s ","type":"text"},{"code":"didExecute","type":"codeVoice"},{"text":" fires even if the","type":"text"},{"text":" ","type":"text"},{"text":"gate cancels, so the cancellation is still recorded. Reordering","type":"text"},{"text":" ","type":"text"},{"text":"to ","type":"text"},{"code":"[entitlement-gate, logging]","type":"codeVoice"},{"text":" would skip the logger’s","type":"text"},{"text":" ","type":"text"},{"code":"didExecute","type":"codeVoice"},{"text":" on cancellation.","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"text":"Observing a cancellation end-to-end","anchor":"Observing-a-cancellation-end-to-end"},{"inlineContent":[{"code":"ModalStore.events","type":"codeVoice"},{"text":" surfaces ","type":"text"},{"code":".commandIntercepted(.cancelled(...))","type":"codeVoice"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"code":"NavigationStore.events","type":"codeVoice"},{"text":" surfaces the same through","type":"text"},{"text":" ","type":"text"},{"code":".pathMismatch","type":"codeVoice"},{"text":" (if the rewrite triggered a policy) plus the","type":"text"},{"text":" ","type":"text"},{"text":"direct cancellation. For a ","type":"text"},{"code":"FlowStore","type":"codeVoice"},{"text":" in particular,","type":"text"},{"text":" ","type":"text"},{"code":"FlowStore.events","type":"codeVoice"},{"text":" wraps both in ","type":"text"},{"code":".navigation(...)","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":".modal(...)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"cases so one subscriber sees the whole picture.","type":"text"}],"type":"paragraph"},{"code":["Task {","    for await event in flowStore.events {","        if case .modal(.commandIntercepted(_, .cancelled(let reason))) = event {","            Log.info(\"modal cancelled: \\(reason)\")","        }","        if case .intentRejected(_, .middlewareRejected(let name)) = event {","            Log.info(\"flow intent rejected by: \\(name ?? \"nil\")\")","        }","    }","}"],"type":"codeListing","syntax":"swift skip doc-fragment"},{"type":"heading","level":2,"text":"Testing middleware with FlowTestStore","anchor":"Testing-middleware-with-FlowTestStore"},{"inlineContent":[{"type":"codeVoice","code":"FlowTestStore"},{"type":"text","text":" (in "},{"type":"codeVoice","code":"InnoRouterTesting"},{"type":"text","text":") asserts the cancellation"},{"type":"text","text":" "},{"type":"text","text":"chain without mounting SwiftUI:"}],"type":"paragraph"},{"code":["@Test","@MainActor","func entitlementGateBlocksPremiumPush() {","    let store = FlowTestStore<AppRoute>(","        configuration: .init(","            navigation: .init(middlewares: [","                .init(middleware: entitlementGateNavigation(hasPremium: { false }), debugName: \"gate\")","            ])","        )","    )","","    store.send(.push(.premiumDetail))","","    store.receiveIntentRejected(","        intent: .push(.premiumDetail),","        reason: .middlewareRejected(debugName: \"gate\")","    )","    store.expectNoMoreEvents()","}"],"type":"codeListing","syntax":"swift skip doc-fragment"},{"type":"heading","level":2,"text":"Next steps","anchor":"Next-steps"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Read ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-LoginOnboarding","type":"reference"},{"text":" to see how middleware","type":"text"},{"text":" ","type":"text"},{"text":"interacts with a multi-step flow plus a child coordinator.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Read the ","type":"text"},{"type":"codeVoice","code":"Tutorial-TestingFlows"},{"text":" guide in the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"InnoRouterTesting"},{"text":" documentation catalog for the full host-less","type":"text"},{"text":" ","type":"text"},{"text":"test harness tour.","type":"text"}]}]}],"type":"unorderedList"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/innorouterswiftui\/tutorial-middlewarecomposition"]}],"sections":[],"abstract":[{"type":"text","text":"Install logging, entitlement gating, and analytics middleware on"},{"type":"text","text":" "},{"type":"text","text":"both "},{"type":"codeVoice","code":"NavigationStore"},{"type":"text","text":" and "},{"type":"codeVoice","code":"ModalStore"},{"type":"text","text":". Inspect the participant"},{"type":"text","text":" "},{"type":"text","text":"discipline that guarantees "},{"type":"codeVoice","code":"didExecute"},{"type":"text","text":" only runs for middlewares"},{"type":"text","text":" "},{"type":"text","text":"that accepted the command."}],"metadata":{"role":"article","modules":[{"name":"InnoRouterTesting"}],"title":"Composing Middleware Across Navigation and Modal","roleHeading":"Article"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-MiddlewareComposition"},"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","references":{"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterTesting":{"type":"topic","kind":"symbol","url":"\/documentation\/innoroutertesting","role":"collection","title":"InnoRouterTesting","abstract":[],"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/Tutorial-LoginOnboarding":{"kind":"article","type":"topic","role":"article","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-LoginOnboarding","url":"\/documentation\/innorouterswiftui\/tutorial-loginonboarding","title":"Building a Login Onboarding Flow","abstract":[{"type":"text","text":"Compose push, sheet, and cover steps into a single serializable flow with "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":", then scope the signup sub-flow through a "},{"type":"codeVoice","code":"ChildCoordinator"},{"type":"text","text":" and await its result inline."}]},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/InnoRouterSwiftUI":{"abstract":[{"text":"SwiftUI hosts, stores, modal routing, coordinators, and environment intent dispatch for InnoRouter.","type":"text"}],"kind":"article","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI","url":"\/documentation\/innorouterswiftui\/innorouterswiftui","title":"InnoRouterSwiftUI","type":"topic","role":"collectionGroup"}}}