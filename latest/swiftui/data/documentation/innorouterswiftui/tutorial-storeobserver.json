{"sections":[],"abstract":[{"type":"codeVoice","code":"StoreObserver"},{"text":" is a thin protocol adapter over the ","type":"text"},{"type":"codeVoice","code":"events"},{"text":" ","type":"text"},{"type":"codeVoice","code":"AsyncStream"},{"text":" that every InnoRouter store publishes. Use it when","type":"text"},{"text":" ","type":"text"},{"text":"protocol dispatch reads clearer than a ","type":"text"},{"type":"codeVoice","code":"for await"},{"text":" loop — typically","type":"text"},{"text":" ","type":"text"},{"text":"in AppDelegate wiring, analytics adapters, or anywhere you want","type":"text"},{"text":" ","type":"text"},{"text":"static methods instead of iterator plumbing.","type":"text"}],"primaryContentSections":[{"content":[{"text":"Scenario","level":2,"anchor":"Scenario","type":"heading"},{"inlineContent":[{"type":"text","text":"An analytics adapter wants to react to every navigation change,"},{"type":"text","text":" "},{"type":"text","text":"modal present, and flow path rewrite. Writing three "},{"code":"for await","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"loops, one per store, reads noisy. "},{"code":"StoreObserver","type":"codeVoice"},{"type":"text","text":" lets the adapter"},{"type":"text","text":" "},{"type":"text","text":"implement three typed "},{"code":"handle(_:)","type":"codeVoice"},{"type":"text","text":" methods and subscribe once per"},{"type":"text","text":" "},{"type":"text","text":"store."}],"type":"paragraph"},{"text":"Implementation","level":2,"anchor":"Implementation","type":"heading"},{"syntax":"swift skip doc-fragment","code":["@MainActor","final class AnalyticsObserver: StoreObserver {","    typealias RouteType = AppRoute","","    func handle(_ event: NavigationEvent<AppRoute>) {","        if case .changed(_, let to) = event {","            Analytics.track(\"nav_change\", [\"path\": to.path.description])","        }","    }","","    func handle(_ event: ModalEvent<AppRoute>) {","        if case .presented(let presentation) = event {","            Analytics.track(\"modal_open\", [\"route\": \"\\(presentation.route)\"])","        }","    }","","    func handle(_ event: FlowEvent<AppRoute>) {","        if case .intentRejected(_, let reason) = event {","            Analytics.track(\"flow_rejected\", [\"reason\": \"\\(reason)\"])","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"Any subset of the three ","type":"text"},{"type":"codeVoice","code":"handle(_:)"},{"text":" methods is fine — the others","type":"text"},{"text":" ","type":"text"},{"text":"default to no-ops via a protocol extension.","type":"text"}],"type":"paragraph"},{"text":"Attaching","level":2,"anchor":"Attaching","type":"heading"},{"syntax":"swift skip doc-fragment","code":["let observer = AnalyticsObserver()","let navSubscription = navigationStore.observe(observer)","let modalSubscription = modalStore.observe(observer)","let flowSubscription = flowStore.observe(observer)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Each "},{"type":"codeVoice","code":"observe(_:)"},{"type":"text","text":" returns a "},{"type":"codeVoice","code":"StoreObserverSubscription"},{"type":"text","text":". Keep it"},{"type":"text","text":" "},{"type":"text","text":"around for the observer’s lifetime; when the"},{"type":"text","text":" "},{"type":"codeVoice","code":"StoreObserverSubscription"},{"type":"text","text":" itself is deinitialized it auto-cancels"},{"type":"text","text":" "},{"type":"text","text":"via "},{"type":"codeVoice","code":"isolated deinit"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"To stop observing early:","type":"text"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","code":["navSubscription.cancel()"],"type":"codeListing"},{"inlineContent":[{"text":"Subsequent store events are not delivered to the observer.","type":"text"}],"type":"paragraph"},{"level":2,"text":"FlowStore routing","anchor":"FlowStore-routing","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"FlowStore.observe(_:)"},{"type":"text","text":" is special: it iterates the flow’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"events"},{"type":"text","text":" stream (which already wraps inner navigation \/ modal"},{"type":"text","text":" "},{"type":"text","text":"emissions) and routes them through the observer’s matching typed"},{"type":"text","text":" "},{"type":"codeVoice","code":"handle(_:)"},{"type":"text","text":" overload. One subscription covers all three authorities"},{"type":"text","text":" "},{"type":"text","text":"on a flow surface."}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","code":["let flowSubscription = flowStore.observe(observer)","\/\/ observer.handle(.navigation(.changed(…))) → observer.handle(_:NavigationEvent)","\/\/ observer.handle(.modal(.presented(…)))    → observer.handle(_:ModalEvent)","\/\/ observer.handle(.pathChanged(…))          → observer.handle(_:FlowEvent)"],"type":"codeListing"},{"level":2,"text":"When to reach for `for await` instead","anchor":"When-to-reach-for-for-await-instead","type":"heading"},{"inlineContent":[{"type":"text","text":"Use the raw "},{"type":"codeVoice","code":"events"},{"type":"text","text":" stream when:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"cancellation flow needs to compose with other async sequences"},{"type":"text","text":" "},{"type":"text","text":"(combine, merge, retry, …)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"the handler body wants to ","type":"text"},{"type":"codeVoice","code":"await"},{"text":" inside an event (e.g. log to","type":"text"},{"text":" ","type":"text"},{"text":"a remote service and gate subsequent events on the response)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"events feed a structured concurrency pipeline with explicit task","type":"text"},{"text":" ","type":"text"},{"text":"lifetimes","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"StoreObserver"},{"type":"text","text":" when:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"the adapter is a long-lived object (analytics, crash reporting)","type":"text"},{"text":" ","type":"text"},{"text":"and protocol methods read clearer than an iterator loop","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"multiple stores feed the same observer with typed dispatch"}]}]}],"type":"unorderedList"},{"level":2,"text":"Multiple observers","anchor":"Multiple-observers","type":"heading"},{"inlineContent":[{"type":"text","text":"Every "},{"code":"observe(_:)","type":"codeVoice"},{"type":"text","text":" call creates an independent subscription, so"},{"type":"text","text":" "},{"type":"text","text":"multiple observers on the same store all receive the same events."},{"type":"text","text":" "},{"type":"text","text":"Fan-out is free — the underlying "},{"code":"events","type":"codeVoice"},{"type":"text","text":" "},{"code":"AsyncStream","type":"codeVoice"},{"type":"text","text":" multicasts"},{"type":"text","text":" "},{"type":"text","text":"through "},{"code":"EventBroadcaster","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"text":"Next steps","anchor":"Next-steps","type":"heading"},{"items":[{"content":[{"inlineContent":[{"text":"See ","type":"text"},{"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-Throttling","isActive":true,"type":"reference"},{"text":" for one more use case — observing","type":"text"},{"text":" ","type":"text"},{"text":"throttle cancellations through the same protocol dispatch.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-MiddlewareComposition"},{"text":" for pre-execution hooks","type":"text"},{"text":" ","type":"text"},{"text":"that complement post-execution observation.","type":"text"}]}]}],"type":"unorderedList"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/innorouterswiftui\/tutorial-storeobserver"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-StoreObserver"},"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"metadata":{"modules":[{"name":"InnoRouterTesting"}],"roleHeading":"Article","title":"Observing Stores via Protocol Adapters","role":"article"},"references":{"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterTesting":{"type":"topic","kind":"symbol","url":"\/documentation\/innoroutertesting","role":"collection","title":"InnoRouterTesting","abstract":[],"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/Tutorial-MiddlewareComposition":{"abstract":[{"text":"Install logging, entitlement gating, and analytics middleware on","type":"text"},{"text":" ","type":"text"},{"text":"both ","type":"text"},{"code":"NavigationStore","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"ModalStore","type":"codeVoice"},{"text":". Inspect the participant","type":"text"},{"text":" ","type":"text"},{"text":"discipline that guarantees ","type":"text"},{"code":"didExecute","type":"codeVoice"},{"text":" only runs for middlewares","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that accepted the command."}],"url":"\/documentation\/innorouterswiftui\/tutorial-middlewarecomposition","role":"article","kind":"article","title":"Composing Middleware Across Navigation and Modal","type":"topic","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-MiddlewareComposition"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/Tutorial-Throttling":{"type":"topic","title":"Throttling Rapid Navigation Taps","url":"\/documentation\/innorouterswiftui\/tutorial-throttling","kind":"article","role":"article","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-Throttling","abstract":[{"type":"text","text":"Rate-limit navigation commands without threading timestamps through"},{"type":"text","text":" "},{"type":"text","text":"every call site. "},{"code":"ThrottleNavigationMiddleware","type":"codeVoice"},{"type":"text","text":" cancels commands that"},{"type":"text","text":" "},{"type":"text","text":"arrive within a minimum interval of a previously accepted command"},{"type":"text","text":" "},{"type":"text","text":"sharing the same key."}]},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/InnoRouterSwiftUI":{"abstract":[{"text":"SwiftUI hosts, stores, modal routing, coordinators, and environment intent dispatch for InnoRouter.","type":"text"}],"kind":"article","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI","url":"\/documentation\/innorouterswiftui\/innorouterswiftui","title":"InnoRouterSwiftUI","type":"topic","role":"collectionGroup"}}}