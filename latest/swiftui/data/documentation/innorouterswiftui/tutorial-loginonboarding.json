{"abstract":[{"type":"text","text":"Compose push, sheet, and cover steps into a single serializable flow with "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":", then scope the signup sub-flow through a "},{"type":"codeVoice","code":"ChildCoordinator"},{"type":"text","text":" and await its result inline."}],"variants":[{"paths":["\/documentation\/innorouterswiftui\/tutorial-loginonboarding"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-LoginOnboarding"},"sections":[],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Scenario","anchor":"Scenario"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The app launches on a welcome screen. Tapping "},{"type":"emphasis","inlineContent":[{"text":"Continue","type":"text"}]},{"type":"text","text":" pushes a"},{"type":"text","text":" "},{"type":"text","text":"pre-auth detail screen. Tapping "},{"type":"emphasis","inlineContent":[{"text":"Create account","type":"text"}]},{"type":"text","text":" presents a signup"},{"type":"text","text":" "},{"type":"text","text":"sheet. When the signup finishes (or is cancelled) the parent flow"},{"type":"text","text":" "},{"type":"text","text":"resumes — either navigating to "},{"type":"codeVoice","code":".home(user)"},{"text":" or staying put.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Modeling this with raw "},{"type":"codeVoice","code":"NavigationStore"},{"type":"text","text":" + "},{"type":"codeVoice","code":"ModalStore"},{"type":"text","text":" means two"},{"type":"text","text":" "},{"type":"text","text":"authority objects, two view-layer hosts, and hand-rolled"},{"type":"text","text":" "},{"type":"text","text":"continuation plumbing to surface the sheet result back to the"},{"type":"text","text":" "},{"type":"text","text":"parent. "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":" + "},{"type":"codeVoice","code":"ChildCoordinator"},{"type":"text","text":" collapse this to a single"},{"type":"text","text":" "},{"type":"text","text":"store and one "},{"type":"codeVoice","code":"await"},{"type":"text","text":"."}]},{"level":2,"type":"heading","text":"Routes","anchor":"Routes"},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["enum AppRoute: Route {","    case welcome","    case preAuth","    case signup","    case home(UserID)","}"]},{"level":2,"type":"heading","text":"Wiring the flow host","anchor":"Wiring-the-flow-host"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"FlowHost"},{"type":"text","text":" composes an inner "},{"type":"codeVoice","code":"ModalHost"},{"type":"text","text":" over a "},{"type":"codeVoice","code":"NavigationHost"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"text","text":"exposes both authorities through a single "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":":"}]},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["@main","struct DemoApp: App {","    @State private var flow = FlowStore<AppRoute>(initial: [.push(.welcome)])","","    var body: some Scene {","        WindowGroup {","            FlowHost(","                store: flow,","                destination: destination,","                root: { WelcomeRootView() }","            )","        }","    }","","    @ViewBuilder","    private func destination(_ route: AppRoute) -> some View {","        switch route {","        case .welcome:","            WelcomeRootView()","        case .preAuth:","            PreAuthDetailView()","        case .signup:","            SignUpView()","        case .home(let id):","            HomeView(userID: id)","        }","    }","}"]},{"level":2,"type":"heading","text":"Emitting intents from views","anchor":"Emitting-intents-from-views"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Views never mutate "},{"code":"FlowStore.path","type":"codeVoice"},{"type":"text","text":" directly; they emit"},{"type":"text","text":" "},{"code":"FlowIntent","type":"codeVoice"},{"type":"text","text":" values through the environment dispatcher so"},{"type":"text","text":" "},{"type":"text","text":"middleware and telemetry observe every step:"}]},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["struct WelcomeRootView: View {","    @EnvironmentFlowIntent<AppRoute> private var flow","","    var body: some View {","        VStack {","            Button(\"Continue\") {","                flow.send(.push(.preAuth))","            }","            Button(\"Create account\") {","                flow.send(.presentSheet(.signup))","            }","        }","    }","}"]},{"level":2,"type":"heading","text":"Awaiting a signup sub-flow","anchor":"Awaiting-a-signup-sub-flow"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The signup sheet opens its own "},{"type":"codeVoice","code":"Coordinator"},{"type":"text","text":" that owns the step"},{"type":"text","text":" "},{"type":"text","text":"progression (email → password → confirmation). The outer"},{"type":"text","text":" "},{"type":"text","text":"onboarding coordinator launches it via "},{"type":"codeVoice","code":"push(child:)"},{"type":"text","text":" and "},{"type":"codeVoice","code":"await"},{"type":"text","text":"s"},{"type":"text","text":" "},{"type":"text","text":"the final "},{"type":"codeVoice","code":"UserID"},{"type":"text","text":":"}]},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["@MainActor","final class SignUpCoordinator: ChildCoordinator {","    typealias Result = UserID","    typealias RouteType = AppRoute","","    \/\/ ...step state + methods omitted","","    func userDidCreateAccount(_ userID: UserID) {","        onFinish(userID)   \/\/ emits the result back to the parent","    }","","    func userCancelled() {","        onCancel()          \/\/ parent sees nil","    }","}","","@MainActor","final class OnboardingCoordinator: Coordinator {","    typealias RouteType = AppRoute","    let navigationStore: NavigationStore<AppRoute>","","    func startSignUpFlow() async {","        let result = await push(child: SignUpCoordinator())","        if let userID = result {","            navigationStore.send(.go(.home(userID)))","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"push(child:)"},{"type":"text","text":" installs the child’s "},{"type":"codeVoice","code":"onFinish"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"onCancel"},{"type":"text","text":" "},{"type":"text","text":"callbacks synchronously, so the child can emit a result at any"},{"type":"text","text":" "},{"type":"text","text":"point — even before the parent’s "},{"type":"codeVoice","code":"await"},{"type":"text","text":" suspends — without a"},{"type":"text","text":" "},{"type":"codeVoice","code":"@MainActor"},{"type":"text","text":" re-entrancy deadlock. See"},{"type":"text","text":" "},{"identifier":"..\/..\/..\/..\/..\/Docs\/design-child-coordinator-handoff.md","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"for the design rationale."}]},{"level":2,"type":"heading","text":"Verifying the flow host-lessly","anchor":"Verifying-the-flow-host-lessly"},{"type":"paragraph","inlineContent":[{"code":"FlowTestStore","type":"codeVoice"},{"text":" (in ","type":"text"},{"code":"InnoRouterTesting","type":"codeVoice"},{"text":") exercises the full chain","type":"text"},{"text":" ","type":"text"},{"text":"in a unit test without mounting any SwiftUI host:","type":"text"}]},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["@Test","@MainActor","func signUpCompletesOnboarding() {","    let store = FlowTestStore<AppRoute>(initial: [.push(.welcome)])","","    store.send(.presentSheet(.signup))","    store.receiveModal { if case .presented = $0 { return true }; return false }","    store