,{"text":", ","type":"text"},{"type":"codeVoice","code":"delegate"},{"text":" ","type":"text"},{"text":"actions, ","type":"text"},{"type":"codeVoice","code":".dismiss"},{"text":" from the parent.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"View binding","type":"text"}]},{"text":" — ","type":"text"},{"type":"codeVoice","code":"NavigationStackStore"},{"text":" translates child","type":"text"},{"text":" ","type":"text"},{"text":"stores into ","type":"text"},{"type":"codeVoice","code":"NavigationLink"},{"text":"s.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"inlineContent":[{"text":"InnoRouter takes ownership of (1) and (3) and replaces (2)","type":"text"},{"text":" ","type":"text"},{"text":"with a typed ","type":"text"},{"code":"NavigationIntent","type":"codeVoice"},{"text":" enum that flows through the","type":"text"},{"text":" ","type":"text"},{"text":"SwiftUI environment. The reducer surface shrinks because the","type":"text"},{"text":" ","type":"text"},{"text":"parent reducer no longer needs to forward navigation actions","type":"text"},{"text":" ","type":"text"},{"text":"into ","type":"text"},{"code":"StackState","type":"codeVoice"},{"text":" mutations.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"The-minimal-swap","text":"The minimal swap","type":"heading"},{"inlineContent":[{"type":"text","text":"A canonical TCA navigation feature looks like this:"}],"type":"paragraph"},{"syntax":"swift skip doc-fragment","code":["@Reducer","struct AppFeature {","    @ObservableState","    struct State: Equatable {","        var path = StackState<Path.State>()","    }","","    enum Action {","        case path(StackActionOf<Path>)","    }","","    @Reducer","    struct Path {","        enum State: Equatable { case detail(DetailFeature.State) }","        enum Action { case detail(DetailFeature.Action) }","        var body: some ReducerOf<Self> {","            Scope(state: \\.detail, action: \\.detail) { DetailFeature() }","        }","    }","","    var body: some ReducerOf<Self> {","        Reduce { state, action in \/* business logic *\/ }","            .forEach(\\.path, action: \\.path) { Path() }","    }","}","","struct AppView: View {","    @Bindable var store: StoreOf<AppFeature>","","    var body: some View {","        NavigationStackStore(store.scope(state: \\.path, action: \\.path)) {","            RootView(store: store)","        } destination: { store in","            switch store.state {","            case .detail:","                if let detail = store.scope(state: \\.detail, action: \\.detail) {","                    DetailView(store: detail)","                }","            }","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"After migration:","type":"text"}]},{"code":["@Routable","enum AppRoute: Route {","    case detail(DetailFeature.State.ID)","}","","@Reducer","struct AppFeature {","    @ObservableState","    struct State: Equatable { \/* business state only *\/ }","","    enum Action { \/* business actions only *\/ }","","    var body: some ReducerOf<Self> {","        Reduce { state, action in \/* business logic *\/ }","    }","}","","struct AppView: View {","    @Bindable var store: StoreOf<AppFeature>","    @State private var navigationStore = NavigationStore<AppRoute>()","","    var body: some View {","        NavigationHost(store: navigationStore) {","            RootView(store: store)","        } destination: { route in","            switch route {","            case .detail(let id):","                DetailView(\/* hydrate from id *\/)","            }","        }","    }","}"],"type":"codeListing","syntax":"swift skip doc-fragment"},{"type":"paragraph","inlineContent":[{"text":"Three things changed:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"The reducer’s "},{"type":"codeVoice","code":"path: StackState<Path.State>"},{"type":"text","tex