{"identifier":{"url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-MigratingFromNestedHosts","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Replace manually composed "},{"type":"codeVoice","code":"ModalHost { NavigationHost { ... } }"},{"type":"text","text":" "},{"type":"text","text":"surfaces with a single "},{"type":"codeVoice","code":"FlowHost"},{"type":"text","text":" backed by "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":". Preserve"},{"type":"text","text":" "},{"type":"text","text":"existing "},{"type":"codeVoice","code":"NavigationStore"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"ModalStore"},{"type":"text","text":" configurations while"},{"type":"text","text":" "},{"type":"text","text":"unlocking a serializable "},{"type":"codeVoice","code":"[RouteStep<R>]"},{"type":"text","text":" path and"},{"type":"text","text":" "},{"type":"codeVoice","code":"FlowStore.apply(_:)"},{"type":"text","text":" for restoration + deep-link hydration."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/innorouterswiftui\/tutorial-migratingfromnestedhosts"]}],"metadata":{"roleHeading":"Article","modules":[{"name":"InnoRouterTesting"}],"title":"Migrating from Nested Hosts to `FlowHost`","role":"article"},"kind":"article","primaryContentSections":[{"content":[{"type":"heading","text":"Starting point","anchor":"Starting-point","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"An app that shipped before "},{"code":"FlowStore","type":"codeVoice"},{"type":"text","text":" landed typically has:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@main","struct LegacyApp: App {","    @State private var nav = NavigationStore<AppRoute>()","    @State private var modal = ModalStore<AppRoute>()","","    var body: some Scene {","        WindowGroup {","            ModalHost(store: modal, destination: destination) {","                NavigationHost(store: nav, destination: destination) {","                    RootView()","                }","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Two stores. Two hosts. Path + modal state cannot be round-tripped","type":"text"},{"text":" ","type":"text"},{"text":"as one value — the app can’t persist “user is 3 screens deep","type":"text"},{"text":" ","type":"text"},{"text":"inside a presented sheet” without hand-serializing both halves.","type":"text"}]},{"type":"heading","text":"Target shape","anchor":"Target-shape","level":2},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@main","struct MigratedApp: App {","    @State private var flow = FlowStore<AppRoute>()","","    var body: some Scene {","        WindowGroup {","            FlowHost(","                store: flow,","                destination: destination,","                root: { RootView() }","            )","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"One store. One host. ","type":"text"},{"code":"flow.path: [RouteStep<AppRoute>]","type":"codeVoice"},{"text":" is the","type":"text"},{"text":" ","type":"text"},{"text":"single source of truth; push + sheet + cover are three cases of","type":"text"},{"text":" ","type":"text"},{"text":"the same enum.","type":"text"}]},{"type":"heading","text":"Migration steps","anchor":"Migration-steps","level":2},{"type":"heading","text":"1. Swap the host layering","anchor":"1-Swap-the-host-layering","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Replace the nested host pair with "},{"type":"codeVoice","code":"FlowHost"},{"type":"text","text":". "},{"type":"codeVoice","code":"FlowHost"},{"type":"text","text":" owns the"},{"type":"text","text":" "},{"type":"text","text":"same "},{"type":"codeVoice","code":"ModalHost"},{"type":"text","text":" + "},{"type":"codeVoice","code":"NavigationHost"},{"type":"text","text":" composition internally —"},{"type":"text","text":" "},{"type":"text","text":"external observable behavior is unchanged — but views now resolve"},{"type":"text","text":" "},{"type":"text","text":"intents through a "},{"type":"codeVoice","code":"FlowIntent"},{"type":"text","text":" dispatcher in the SwiftUI"},{"type":"text","text":" "},{"type":"text","text":"environment."}]},{"type":"heading","text":"2. Route view intents through `FlowIntent`","anchor":"2-Route-view-intents-through-FlowIntent","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Old:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["navigationStore.send(.go(.detail))","modalStore.present(.sheet, style: .sheet)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"New:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@EnvironmentFlowIntent<AppRoute> private var flow","\/\/ ...","flow.send(.push(.detail))","flow.send(.presentSheet(.sheet))"]},{"type":"paragraph","inlineContent":[{"code":"FlowStore.send","type":"codeVoice"},{"text":" still delegates to the inner","type":"text"},{"text":" ","type":"text"},{"code":"NavigationStore.send","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"ModalStore.present","type":"codeVoice"},{"text":", so any middleware","type":"text"},{"text":" ","type":"text"},{"text":"or telemetry attached to those stores continues to run.","type":"text"}]},{"type":"heading","text":"3. Port store configuration through `FlowStoreConfiguration`","anchor":"3-Port-store-configuration-through-FlowStoreConfiguration","level":3},{"type":"paragraph","inlineContent":[{"code":"FlowStoreConfiguration","type":"codeVoice"},{"text":" composes ","type":"text"},{"code":"NavigationStoreConfiguration","type":"codeVoice"},{"text":" +","type":"text"},{"text":" ","type":"text"},{"code":"ModalStoreConfiguration","type":"codeVoice"},{"text":", so existing configs port 1:1:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["let flow = FlowStore<AppRoute>(","    configuration: .init(","        navigation: legacyNavigationConfiguration,","        modal: legacyModalConfiguration,","        onPathChanged: { old, new in Log.debug(\"flow path: \\(old) -> \\(new)\") },","        onIntentRejected: { intent, reason in Log.info(\"flow rejected \\(intent): \\(reason)\") }","    )",")"]},{"type":"heading","text":"4. Handle the two new invariant-violation paths","anchor":"4-Handle-the-two-new-invariant-violation-paths","level":3},{"type":"paragraph","inlineContent":[{"code":"FlowStore","type":"codeVoice"},{"text":" rejects intents that would violate its invariants:","type":"text"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Intent situation","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Reason emitted"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".push","type":"codeVoice"},{"text":" while a modal tail is active","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":".pushBlockedByModalTail"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".reset([.sheet, .push])"},{"type":"text","text":" (modal not at tail)"}],"type":"paragraph"}],[{"inlineContent":[{"code":".invalidResetPath","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Any intent cancelled by middleware","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"code":".middlewareRejected(debugName:)","type":"codeVoice"}],"type":"paragraph"}]]]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Subscribe to "},{"type":"codeVoice","code":"flow.events"},{"type":"text","text":" (case "},{"type":"codeVoice","code":".intentRejected"},{"type":"text","text":") — or keep the"},{"type":"text","text":" "},{"type":"codeVoice","code":"onIntentRejected"},{"type":"text","text":" closure — and handle each case. The legacy"},{"type":"text","text":" "},{"type":"text","text":"stores never had this signal; before the migration, a push attempt"},{"type":"text","text":" "},{"type":"text","text":"during a sheet presentation silently no-opped or tripped up the"},{"type":"text","text":" "},{"type":"text","text":"app in subtle ways."}]},{"type":"heading","text":"5. Adopt `apply(_:)` for deep links and restoration","anchor":"5-Adopt-apply-for-deep-links-and-restoration","level":3},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"FlowPlan<R>.steps"},{"type":"text","text":" is "},{"type":"codeVoice","code":"[RouteStep<R>]"},{"type":"text","text":", so once your routes opt"},{"type":"text","text":" "},{"type":"text","text":"into "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["extension AppRoute: Codable {}"]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"StatePersistence<AppRoute>"},{"type":"text","text":" round-trips the whole flow state:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["let persistence = StatePersistence<AppRoute>()","","\/\/ On app background","try persistence.encode(FlowPlan(steps: flow.path)).write(to: url)","","\/\/ On launch","if let data = try? Data(contentsOf: url) {","    flow.apply(try persistence.decode(data))","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Deep-link resolvers can emit a "},{"type":"codeVoice","code":"FlowPlan"},{"type":"text","text":" directly and hand it to"},{"type":"text","text":" "},{"type":"codeVoice","code":"flow.apply(_:)"},{"type":"text","text":" to hydrate a push + sheet terminal URL in one"},{"type":"text","text":" "},{"type":"text","t