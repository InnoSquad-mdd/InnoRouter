xt","text":" \/ "},{"code":"events","type":"codeVoice"},{"type":"text","text":" event surfaces at the"},{"type":"text","text":" "},{"type":"text","text":"end. Use it for analytics-clean compound actions (“complete"},{"type":"text","text":" "},{"type":"text","text":"checkout: replace stack + dismiss modal”)."}]},{"type":"paragraph","inlineContent":[{"code":"executeTransaction","type":"codeVoice"},{"text":" is an ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"atomicity mode"}]},{"text":". The store applies","type":"text"},{"text":" ","type":"text"},{"text":"each command to a shadow stack, journals what middleware accepted","type":"text"},{"text":" ","type":"text"},{"text":"or rejected, and only commits if every step succeeds. On failure,","type":"text"},{"text":" ","type":"text"},{"text":"the journal walks back through the discarded acceptances so","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"middleware see consistent before\/after states. Use it for"},{"type":"text","text":" "},{"type":"text","text":"correctness-critical compound actions (“if any step rejects, the"},{"type":"text","text":" "},{"type":"text","text":"user sees no half-applied state”)."}]},{"type":"heading","anchor":"Worked-examples","level":2,"text":"Worked examples"},{"type":"heading","anchor":"Compose-a-single-command-that-drives-a-deep-link-plan","level":3,"text":"Compose a single command that drives a deep link plan"},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["let plan = NavigationPlan<AppRoute>(commands: [","    .replace([.home]),","    .push(.detail(id))","])","\/\/ Pass the plan to a single .sequence — the engine evaluates each","\/\/ component and reports `.multiple([...])` results.","let result = store.execute(.sequence(plan.commands))"]},{"type":"paragraph","inlineContent":[{"text":"Use when the deep-link planner already represents the path as a","type":"text"},{"text":" ","type":"text"},{"text":"sequence of ","type":"text"