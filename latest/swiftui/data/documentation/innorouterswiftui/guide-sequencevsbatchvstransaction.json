":"paragraph","inlineContent":[{"text":"Use when the user is generating commands faster than the","type":"text"},{"text":" ","type":"text"},{"text":"navigation surface should react.","type":"text"}]},{"type":"heading","anchor":"Anti-patterns","level":2,"text":"Anti-patterns"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Wrapping "},{"type":"codeVoice","code":"executeBatch"},{"type":"text","text":" in another "},{"type":"codeVoice","code":"executeBatch"},{"type":"text","text":" to “compose”"},{"type":"text","text":" "},{"type":"text","text":"events."}]},{"type":"text","text":" Use "},{"type":"codeVoice","code":".sequence"},{"type":"text","text":" inside one batch instead."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Calling "},{"type":"codeVoice","code":"executeTransaction"},{"type":"text","text":" for analytics-clean grouping."}],"type":"strong"},{"type":"text","text":" "},{"type":"text","text":"The shadow-state cost is wasted; reach for "},{"type":"codeVoice","code":"executeBatch"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Driving a debounce window from a middleware."}],"type":"strong"},{"text":" Middleware","type":"text"},{"text":" ","type":"text"},{"text":"cannot reliably re-dispatch the deferred command; that is what","type":"text"},{"text":" ","type":"text"},{"code":"DebouncingNavigator","type":"codeVoice"},{"text":" exists for.","type":"text"}]}]}]},{"type":"heading","anchor":"See-also","level":2,"text":"See also"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NavigationStore"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"NavigationCommand","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"code":"ThrottleNavigationMiddleware","type":"codeVoice"}],"type":"