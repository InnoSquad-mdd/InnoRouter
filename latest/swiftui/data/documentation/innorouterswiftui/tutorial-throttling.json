{"kind":"article","metadata":{"role":"article","roleHeading":"Article","title":"Throttling Rapid Navigation Taps","modules":[{"name":"InnoRouterTesting"}]},"abstract":[{"type":"text","text":"Rate-limit navigation commands without threading timestamps through"},{"type":"text","text":" "},{"type":"text","text":"every call site. "},{"type":"codeVoice","code":"ThrottleNavigationMiddleware"},{"type":"text","text":" cancels commands that"},{"type":"text","text":" "},{"type":"text","text":"arrive within a minimum interval of a previously accepted command"},{"type":"text","text":" "},{"type":"text","text":"sharing the same key."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Scenario","type":"heading","level":2,"text":"Scenario"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Users double-tap a “Buy” button. The first tap pushes the purchase"},{"type":"text","text":" "},{"type":"text","text":"screen; the second should be silently dropped. Rolling that logic"},{"type":"text","text":" "},{"type":"text","text":"into every button is noise — middleware is the right layer."}]},{"anchor":"Installation","type":"heading","level":2,"text":"Installation"},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["let store = NavigationStore<AppRoute>(","    configuration: NavigationStoreConfiguration(","        middlewares: [","            .init(","                middleware: AnyNavigationMiddleware(","                    ThrottleNavigationMiddleware<AppRoute>(","                        interval: .milliseconds(300)","                    )","                ),","                debugName: \"throttle\"","            )","        ]","    )",")"]},{"type":"paragraph","inlineContent":[{"text":"The default initializer uses ","type":"text"},{"type":"codeVoice","code":"ContinuousClock"},{"text":" and groups all","type":"text"},{"text":" ","type":"text"},{"text":"commands under a single global window. Within 300 ms of a previous","type":"text"},{"text":" ","type":"text"},{"text":"successfully executed command, the next one is cancelled. If the","type":"text"},{"text":" ","type":"text"},{"text":"middleware is registered with ","type":"text"},{"type":"codeVoice","code":"debugName: \"throttle\""},{"text":", the surfaced","type":"text"},{"text":" ","type":"text"},{"text":"reason becomes ","type":"text"},{"type":"codeVoice","code":".cancelled(.middleware(debugName: \"throttle\", command: …))"},{"text":".","type":"text"}]},{"anchor":"Per-command-keys","type":"heading","level":2,"text":"Per-command keys"},{"type":"paragraph","inlineContent":[{"text":"Group throttle windows by the command’s identity or shape:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["AnyNavigationMiddleware(","    ThrottleNavigationMiddleware<AppRoute>(interval: .milliseconds(300)) { command in","        if case .push(let route) = command {","            return \"push-\\(route)\"   \/\/ each push route gets its own window","        }","        return nil                    \/\/ other commands pass through","    }",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Return "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to opt a command out of throttling entirely."}]},{"anchor":"Testing-with-an-injected-clock","type":"heading","level":2,"text":"Testing with an injected clock"},{"type":"paragraph","inlineContent":[{"text":"The middleware is generic over ","type":"text"},{"code":"Clock","type":"codeVoice"},{"text":", so tests can drive time","type":"text"},{"text":" ","type":"text"},{"text":"deterministically:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["let clock = TestClock()","let throttle = ThrottleNavigationMiddleware<AppRoute, TestClock>(","    interval: .milliseconds(300),","    clock: clock,","    key: { _ in \"all\" }",")","store.addMiddleware(AnyNavigationMiddleware(throttle), debugName: \"throttle\")","","store.send(.go(.home))","clock.advance(by: .milliseconds(50))","store.send(.go(.detail))         \/\/ cancelled — within window","","clock.advance(by: .milliseconds(400))","store.send(.go(.settings))       \/\/ accepted — beyond window"]},{"anchor":"Composing-with-whenCancelled","type":"heading","level":2,"text":"Composing with `.whenCancelled`"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A throttle cancel surfaces as "},{"type":"codeVoice","code":".cancelled"},{"type":"text","text":", so"},{"type":"text","text":" "},{"type":"codeVoice","code":".whenCancelled(primary, fallback:)"},{"type":"text","text":" treats a throttled command the"},{"type":"text","text":" "},{"type":"text","text":"same as any other cancelled command:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["store.execute(","    .whenCancelled(","        .push(.detail),","        fallback: .push(.home)","    )",")"]},{"type":"paragraph","inlineContent":[{"text":"If the throttle middleware cancels the ","type":"text"},{"code":".push(.detail)","type":"codeVoice"},{"text":", the","type":"text"},{"text":" ","type":"text"},{"text":"fallback ","type":"text"},{"code":".push(.home)","type":"codeVoice"},{"text":" is attempted next. ","type":"text"},{"code":"NavigationStore","type":"codeVoice"},{"text":" ","type":"text"},{"text":"routes that fallback back through the full middleware chain, so a","type":"text"},{"text":" ","type":"text"},{"text":"global throttle key can cancel the fallback too if it still lands","type":"text"},{"text":" ","type":"text"},{"text":"inside the same throttle window.","type":"text"}]},{"anchor":"Debounce","type":"heading","level":2,"text":"Debounce?"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Debounce semantics — “wait N ms, then fire the latest” — live in"},{"type":"text","text":" "},{"code":"DebouncingNavigator","type":"codeVoice"},{"type":"text","text":", not in "},{"code":"NavigationCommand","type":"codeVoice"},{"type":"text","text":". That keeps the"},{"type":"text","text":" "},{"type":"text","text":"engine synchronous while the async wrapper owns the timer,"},{"type":"text","text":" "},{"type":"text","text":"cancellation, and "},{"code":"Clock","type":"codeVoice"},{"type":"text","text":" injection needed for deterministic tests."},{"type":"text","text":" "},{"type":"text","text":"Use throttle middleware for synchronous “reject too soon” behavior"},{"type":"text","text":" "},{"type":"text","text":"and "},{"code":"DebouncingNavigator","type":"codeVoice"},{"type":"text","text":" for delayed “latest wins” behavior."}]},{"anchor":"Next-steps","type":"heading","level":2,"text":"Next steps"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"See ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-StoreObserver"},{"text":" for a protocol-style adapter","type":"text"},{"text":" ","type":"text"},{"text":"that can observe throttle cancellations via","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NavigationStore.events"},{"text":" without threading callbacks.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-MiddlewareComposition","isActive":true},{"text":" for the broader","type":"text"},{"text":" ","type":"text"},{"text":"middleware composition story (logging, entitlement gating,","type":"text"},{"text":" ","type":"text"},{"text":"analytics).","type":