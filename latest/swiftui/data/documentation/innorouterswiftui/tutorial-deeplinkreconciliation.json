{"variants":[{"paths":["\/documentation\/innorouterswiftui\/tutorial-deeplinkreconciliation"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Match a URL, apply an authentication policy, and produce a","type":"text"},{"text":" ","type":"text"},{"code":"NavigationPlan","type":"codeVoice"},{"text":" that ","type":"text"},{"code":"NavigationStore.executeBatch","type":"codeVoice"},{"text":" applies in one","type":"text"},{"text":" ","type":"text"},{"text":"observable step. Queue the deep link while the user is signed out,","type":"text"},{"text":" ","type":"text"},{"text":"replay it after sign-in, and surface cancellation reasons through","type":"text"},{"text":" ","type":"text"},{"text":"typed outcomes.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-DeepLinkReconciliation"},"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"role":"article","roleHeading":"Article","modules":[{"name":"InnoRouterTesting"}],"title":"Reconciling Deep Links End-to-End"},"primaryContentSections":[{"content":[{"anchor":"Scenario","level":2,"text":"Scenario","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"myapp:\/\/order\/42"},{"type":"text","text":" should land the user on the order detail for"},{"type":"text","text":" "},{"type":"text","text":"order 42, but only when they’re signed in. If the link arrives"},{"type":"text","text":" "},{"type":"text","text":"while signed out, the app must remember it, route through the"},{"type":"text","text":" "},{"type":"text","text":"sign-in flow, and then replay it — without dropping the original"},{"type":"text","text":" "},{"type":"text","text":"URL context."}],"type":"paragraph"},{"anchor":"Modeling-the-routes","level":2,"text":"Modeling the routes","type":"heading"},{"code":["enum AppRoute: Route {","    case home","    case signIn","    case order(id: String)","}"],"syntax":"swift skip doc-fragment","type":"codeListing"},{"anchor":"Wiring-the-pipeline","level":2,"text":"Wiring the pipeline","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"DeepLinkPipeline"},{"type":"text","text":" owns the match-then-validate-then-authorize flow:"}],"type":"paragraph"},{"code":["let matcher = DeepLinkMatcher<AppRoute>(patterns: [","    .init(pattern: \"myapp:\/\/home\")                   { _ in .home },","    .init(pattern: \"myapp:\/\/signin\")                 { _ in .signIn },","    .init(pattern: \"myapp:\/\/order\/:id\")              { params in","        guard let id = params[\"id\"] else { return nil }","        return .order(id: id)","    },","])","","let policy: DeepLinkAuthenticationPolicy<AppRoute> = { route, isAuthenticated in","    switch route {","    case .home, .signIn:","        return .proceed","    case .order where !isAuthenticated:","        return .defer \/\/ the pipeline will queue a PendingDeepLink","    case .order:","        return .proceed","    }","}","","let pipeline = DeepLinkPipeline(matcher: matcher, policy: policy)"],"syntax":"swift skip doc-fragment","type":"codeListing"},{"anchor":"Handling-a-URL","level":2,"text":"Handling a URL","type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"code":"DeepLinkEffectHandler","type":"codeVoice"},{"type":"text","text":" bridges the pipeline output into"},{"type":"text","text":" "},{"code":"NavigationStore","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["@MainActor","final class AppCoordinator {","    let store: NavigationStore<AppRoute>","    let pipeline: DeepLinkPipeline<AppRoute>","    let effectHandler: DeepLinkEffectHandler<AppRoute>","","    func handle(_ url: URL, isAuthenticated: Bool) {","        let outcome = pipeline.process(url: url, isAuthenticated: isAuthenticated)","","        switch outcome {","        case .plan(let plan):","            _ = store.executeBatch(plan.commands)","        case .pending(let pending):","            effectHandler.retain(pending)","            store.send(.go(.signIn))","        case .rejected(let reason):","            Log.warning(\"deep link rejected: \\(reason)\")","        case .unhandled(let url):","            Log.warning(\"deep link unhandled: \\(url)\")","        }","    }","}"],"syntax":"swift skip doc-fragment","type":"codeListing"},{"anchor":"Replaying-after-sign-in","level":2,"text":"Replaying after sign-in","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once the user signs in, the handler resumes any queued deep link:"}]},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["func userDidSignIn() {","    effectHandler.resumePendingDeepLinkIfAllowed(","        isAuthenticated: true,","        executor: { plan in","            _ = store.executeBatch(plan.commands)","        }","    )","}"]},{"type":"paragraph","inlineContent":[{"text":"The handler consults the retained ","type":"text"},{"code":"PendingDeepLink","type":"codeVoice"},{"text":", re-evaluates","type":"text"},{"text":" ","type":"text"},{"text":"the authentication policy, and only commits the batch if the new","type":"text"},{"text":" ","type":"text"},{"text":"state now permits the original URL. Any stale pending link (one","type":"text"},{"text":" ","type":"text"},{"text":"the user cancelled or that no longer validates) is dropped.","type":"text"}]},{"anchor":"Observing-the-reconciliation","type":"heading","level":2,"text":"Observing the reconciliation"},{"type":"paragraph","inlineContent":[{"code":"NavigationStore.events","type":"codeVoice"},{"text":" exposes the full sequence of batch +","type":"text"},{"text":" ","type":"text"},{"text":"path-mismatch events as a single stream, which is handy for","type":"text"},{"text":" ","type":"text"},{"text":"diagnostics dashboards:","type":"text"}]},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["Task {","    for await event in store.events {","        switch event {","        case .batchExecuted(let result):","            analytics.track(\"deep_link_applied\", [","                \"routes\": result.stateAfter.path.map(String.init(describing:))","            ])","        case .pathMismatch(let event):","            analytics.track(\"deep_link_mismatch\", [","                \"policy\": event.policy.rawValue,","                \"old\": event.oldPath.map(String.init(describing:)),","                \"new\": event.newPath.map(String.init(describing:))","            ])","        default:","            continue","        }","    }","}"]},{"anchor":"Testing-the-chain","type":"heading","level":2,"text":"Testing the chain"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NavigationTestStore"},{"text":" (in ","type":"text"},{"type":"codeVoice","code":"InnoRouterTesting"},{"text":") asserts the batch +","type":"text"},{"text":" ","type":"text"},{"text":"side effects for each branch:","type":"text"}]},{"syntax":"swift skip doc-fragment","type":"codeListing","code":["@Test","@MainActor","func signedOutDeepLinkDefersUntilSignIn() {","    let store = NavigationTestStore<AppRoute>()","    \/\/ ...pipeline + handler wired to `store.store`","    pipeline.handle(URL(string: \"myapp:\/\/order\/42\")!, isAuthenticated: false)","","    store.receiveChange { _, new in new.path == [.signIn] }","    \/\/ Pending deep link remains queued; no .batchExecuted yet.","}"]},{"anchor":"Next-steps","type":"heading","level":2,"text":"Next steps"},{"items":[{"content":[{"inlineContent":[{"text":"Read ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-LoginOnboarding","type":"reference"},{"text":" for how the sign-in flow that","type":"text"},{"text":" ","type":"text"},{"text":"replays this deep link is modelled.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Read "},{"type":"reference","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-MigratingFromNestedHosts","isActive":true},{"type":"text","text":" if the existing app"},{"type":"text","text":" "},{"type":"text","text":"still uses "},{"type":"codeVoice","code":"ModalHost { NavigationHost { ... } }"},{"type":"text","text":" pairs."}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"kind":"article","sections":[],"references":{"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterTesting":{"type":"topic","kind":"symbol","url":"\/documentation\/innoroutertesting","role":"collection","title":"InnoRouterTesting","abstract":[],"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/Tutorial-LoginOnboarding":{"kind":"article","type":"topic","role":"article","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-LoginOnboarding","url":"\/documentation\/innorouterswiftui\/tutorial-loginonboarding","title":"Building a Login Onboarding Flow","abstract":[{"type":"text","text":"Compose push, sheet, and cover steps into a single serializable flow with "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":", then scope the signup sub-flow through a "},{"type":"codeVoice","code":"ChildCoordinator"},{"type":"text","text":" and await its result inline."}]},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/Tutorial-MigratingFromNestedHosts":{"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/Tutorial-MigratingFromNestedHosts","url":"\/documentation\/innorouterswift