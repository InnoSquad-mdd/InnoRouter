"},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" by design because it is a shared authority object, not ephemeral view state."}]},{"type":"heading","level":2,"text":"Environment intent","anchor":"Environment-intent"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"EnvironmentNavigationIntent"},{"type":"text","text":" and "},{"type":"codeVoice","code":"EnvironmentModalIntent"},{"type":"text","text":" are the primary view-facing APIs."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This keeps view code declarative:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"child views do not need a direct store reference"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"fail-fast behavior catches host wiring mistakes early"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"multi-host trees can keep separate routing authorities in the same hierarchy"}]}]}]},{"type":"heading","level":3,"text":"Sibling hosts and duplicate registration","anchor":"Sibling-hosts-and-duplicate-registration"},{"type":"paragraph","inlineContent":[{"text":"Each ","type":"text"},{"code":"NavigationHost","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"ModalHost","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"FlowHost","type":"codeVoice"},{"text":" owns its own","type":"text"},{"text":" ","type":"text"},{"code":"*EnvironmentStorage","type":"codeVoice"},{"text":" instance through ","type":"text"},{"code":"@State","type":"codeVoice"},{"text":", so SwiftUI scopes the","type":"text"},{"text":" ","type":"text"},{"text":"handler table to the host’s view subtree. Re-registering the","type":"text"},{"text":" ","type":"text"},{"text":"same routing authority is allowed across SwiftUI updates, even when","type":"text"},{"text":" ","type":"text"},{"text":"the forwarding closure is freshly allocated. A sibling host with a","type":"text"},{"text":" ","type":"text"},{"text":"different authority that registers against the same ","type":"text"},{"code":"Route","type":"codeVoice"},{"text":" type in","type":"text"},{"text":" ","type":"text"},{"text":"the same environment scope is treated as a wiring bug: in Debug","type":"text"},{"text":" ","type":"text"},{"text":"builds the storage setter traps with ","type":"text"},{"code":"assertionFailure","type":"codeVoice"},{"text":", and in","type":"text"},{"text":" ","type":"text"},{"text":"Release it logs an error through the ","type":"text"},{"code":"duplicate-dispatcher","type":"codeVoice"},{"text":" ","type":"text"},{"code":"os_log","type":"codeVoice"},{"text":" category before letting the overwrite proceed (preserving","type":"text"},{"text":" ","type":"text"},{"text":"prior behaviour for production cold-starts).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If two surfaces legitimately need different routing authorities,","type":"text"},{"text":" ","type":"text"},{"text":"either give them distinct ","type":"text"},{"code":"Route","type":"codeVoice"},{"text":" types or scope them with separate","type":"text"},{"text":" ","type":"text"},{"text":"environment subtrees so each host gets its own storage.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Low-level tests or custom integrations that write directly into an"},{"type":"text","text":" "},{"type":"text","text":"environment storage should either assign a handler once per storage"},{"type":"text","text":" "},{"type":"text","text":"instance, or call the explicit owner registration helper with a stable"},{"type":"text","text":" "},{"type":"text","text":"store \/ coordinator identity. The host modifiers do this for normal"},{"type":"text","text":" "},{"type":"codeVoice","code":"NavigationHost"},{"type":"text","text":", "},{"type":"codeVoice","code":"ModalHost"},{"type":"text","text":", and "},{"type":"codeVoice","code":"FlowHost"},{"type":"text","text":" usage."}]},{"type":"heading","level":2,"text":"Flow and tab coordinators","anchor":"Flow-and-tab-coordinators"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"FlowCoordinator"},{"type":"text","text":" and "},{"type":"codeVoice","code":"TabCoordinator"},{"type":"text","text":" complement "},{"type":"codeVoice","code":"NavigationStore"},{"type":"text","text":"; they do not replace it."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Recommended mental model:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"NavigationStore","type":"codeVoice"},{"text":" owns route-stack authority","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"TabCoordinator"},{"type":"text","text":" owns shell tab state"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"FlowCoordinator","type":"codeVoice"},{"text":" owns local step state inside a destination","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use composition rather than trying to collapse all three responsibilities into one type."}]}],"kind":"content"}],"references":{"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterSwiftUI/InnoRouterSwiftUI":{"abstract":[{"text":"SwiftUI hosts, stores, modal routing, coordinators, and environment intent dispatch for InnoRouter.","type":"text"}],"kind":"article","identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterSwiftUI\/InnoRouterSwiftUI","url":"\/documentation\/innorouterswiftui\/innorouterswiftui","title":"InnoRouterSwiftUI","type":"topic","role":"collectionGroup"},"doc://com.innosquad.innorouter.docs.swiftui/documentation/InnoRouterTesting":{"type":"topic","kind":"symbol","url":"\/documentation\/innoroutertesting","role":"collection","title":"InnoRouterTesting","abstract":[],"identifier":"doc:\/\/com.innosquad.innorouter.docs.swiftui\/documentation\/InnoRouterTesting"}}}