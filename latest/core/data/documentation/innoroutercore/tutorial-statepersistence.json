{"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"InnoRouter models a running flow as a single value ("},{"code":"FlowPlan<R>","type":"codeVoice"},{"type":"text","text":" \/"},{"type":"text","text":" "},{"code":"RouteStack<R>","type":"codeVoice"},{"type":"text","text":"). When both the routes ("},{"code":"R","type":"codeVoice"},{"type":"text","text":") and the containing types"},{"type":"text","text":" "},{"type":"text","text":"are "},{"code":"Codable","type":"codeVoice"},{"type":"text","text":", the entire state can round-trip through JSON. That is"},{"type":"text","text":" "},{"type":"text","text":"enough for state restoration, deep-link payloads, and offline replay."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"StatePersistence<R>"},{"type":"text","text":" bundles a "},{"type":"codeVoice","code":"JSONEncoder"},{"type":"text","text":" and "},{"type":"codeVoice","code":"JSONDecoder"},{"type":"text","text":" so"},{"type":"text","text":" "},{"type":"text","text":"call sites don’t have to redeclare them:"}],"type":"paragraph"},{"code":["let persistence = StatePersistence<AppRoute>()","","\/\/ At checkpoint time (e.g. scene will deactivate):","let plan = try FlowPlan(validating: flowStore.path)","let data = try persistence.encode(plan)","try data.write(to: restorationURL, options: .atomic)","","\/\/ At launch time:","if let data = try? Data(contentsOf: restorationURL) {","    let restored = try persistence.decode(data)","    flowStore.apply(restored)","}"],"syntax":"swift skip doc-fragment","type":"codeListing"},{"inlineContent":[{"type":"text","text":"SwiftUI apps can wrap the value-level helper with"},{"type":"text","text":" "},{"type":"codeVoice","code":"StateRestorationAdapter"},{"type":"text","text":" from "},{"type":"codeVoice","code":"InnoRouterSwiftUI"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["let adapter = StateRestorationAdapter<AppRoute> { failure in","    diagnostics.record(failure)","}","","try adapter.snapshotNavigationStack(from: navigationStore)","_ = adapter.restoreFlowPlan(from: data, into: flowStore)"],"syntax":"swift skip doc-fragment","type":"codeListing"},{"inlineContent":[{"text":"The adapter supports navigation-stack and flow-plan snapshots. Decode","type":"text"},{"text":" ","type":"text"},{"text":"or apply failures are reported through the restoration failure callback","type":"text"},{"text":" ","type":"text"},{"text":"and leave the existing store state untouched instead of falling back to","type":"text"},{"text":" ","type":"text"},{"text":"an empty path.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Validation on decode","type":"heading","anchor":"Validation-on-decode"},{"inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"FlowPlan"},{"type":"text","text":" always satisfies the FlowStore invariants:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"At most one modal step.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"A modal step only at the tail of ","type":"text"},{"code":"steps","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"All other steps are "},{"code":".push","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"codeVoice","code":"FlowPlan(validating:)"},{"type":"text","text":" and "},{"type":"codeVoice","code":"FlowPlan.validate(_:)"},{"type":"text","text":" enforce these"},{"type":"text","text":" "},{"type":"text","text":"invariants up front and throw "},{"type":"codeVoice","code":"FlowPlanValidationError"},{"type":"text","text":" on"},{"type":"text","text":" "},{"type":"text","text":"violation. Codable decode runs the same validator and converts a"},{"type":"text","text":" "},{"type":"text","text":"violation into "},{"type":"codeVoice","code":"DecodingError.dataCorruptedError"},{"type":"text","text":", so a"},{"type":"text","text":" "},{"type":"codeVoice","code":"FlowPlan"},{"type":"text","text":" round-tripped through disk or network can no longer"},{"type":"text","text":" "},{"type":"text","text":"silently produce a value that "},{"type":"codeVoice","code":"apply(_:)"},{"type":"text","text":" will reject later. If"},{"type":"text","text":" "},{"type":"text","text":"the snapshot format on disk drifts (older builds, hand-edited"},{"type":"text","text":" "},{"type":"text","text":"JSON, schema migration mid-flight), the decode call surfaces the"},{"type":"text","text":" "},{"type":"text","text":"error at restoration time — not at the next user action."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The permissive "},{"type":"codeVoice","code":"FlowPlan(steps:)"},{"type":"text","text":" initializer remains available"},{"type":"text","text":" "},{"type":"text","text":"for internal builders that already trust the origin of "},{"type":"codeVoice","code":"steps"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"heading","text":"Scope","anchor":"Scope","level":2},{"inlineContent":[{"text":"The helper intentionally covers only the typed ","type":"text"},{"type":"codeVoice","code":"Data ↔ value"},{"text":" bridge.","type":"text"},{"text":" ","type":"text"},{"text":"Out of scope, by design:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Where the encoded bytes live (","type":"text"},{"code":"UserDefaults","type":"codeVoice"},{"text":", a file URL, iCloud,","type":"text"},{"text":" ","type":"text"},{"text":"a database) — that is app policy.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When snapshots are taken — tie the call into "},{"code":"ScenePhase","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"UIScene","type":"codeVoice"},{"type":"text","text":" lifecycle, or a custom trigger."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Version-aware migration from older snapshot formats — add a","type":"text"},{"text":" ","type":"text"},{"text":"wrapper struct around ","type":"text"},{"code":"FlowPlan","type":"codeVoice"},{"text":" if the underlying routes evolve.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Selective field redaction — encode only the fragments the app is","type":"text"},{"text":" ","type":"text"},{"text":"willing to persist.","type":"text"}]}]}]},{"type":"heading","text":"Customising the encoder","anchor":"Customising-the-encoder","level":2},{"inlineContent":[{"type":"text","text":"Any "},{"type":"codeVoice","code":"JSONEncoder"},{"type":"text","text":" and "},{"type":"codeVoice","code":"JSONDecoder"},{"type":"text","text":" are acceptable inputs. Pass a"},{"type":"text","text":" "},{"type":"text","text":"preconfigured pair to the initializer for deterministic output, date"},{"type":"text","text":" "},{"type":"text","text":"strategies, or custom key coding:"}],"type":"paragraph"},{"code":["let encoder = JSONEncoder()","encoder.outputFormatting = [.sortedKeys, .prettyPrinted]","","let decoder = JSONDecoder()","decoder.dateDecodingStrategy = .iso8601","","let persistence = StatePersistence<AppRoute>(encoder: encoder, decoder: decoder)"],"type":"codeListing","syntax":"swift skip doc-fragment"},{"type":"heading","text":"Error surface","anchor":"Error-surface","level":2},{"inlineContent":[{"type":"text","text":"Both "},{"type":"codeVoice","code":"encode(_:)"},{"type":"text","text":" and "},{"type":"codeVoice","code":"decode(_:)"},{"type":"text","text":" re-throw the underlying"},{"type":"text","text":" "},{"type":"codeVoice","code":"EncodingError"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"DecodingError"},{"type":"text","text":" so call sites keep the diagnostic"},{"type":"text","text":" "},{"type":"text","text":"context needed to distinguish schema drift from I\/O failures."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/InnoRouterCore"]]},"abstract":[{"type":"codeVoice","code":"StatePersistence"},{"type":"text","text":" is a thin helper that serializes "},{"type":"codeVoice","code":"FlowPlan"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"RouteStack"},{"type":"text","text":" values to "},{"type":"codeVoice","code":"Data"},{"type":"text","text":" for launch-time restoration. It deliberately"},{"type":"text","text":" "},{"type":"text","text":"stops at the value boundary so apps keep full control over where — and"},{"type":"text","text":" "},{"type":"text","text":"when — snapshots are written."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/innoroutercore\/tutorial-statepersistence"]}],"sections":[],"kind":"article","identifier":{"url":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/Tutorial-StatePersistence","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"InnoRouterTesting"}],"role":"article","roleHeading":"Article","title":"State Persistence and Restoration"},"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://com.innosquad.innorouter.docs.core/documentation/InnoRouterTesting":{"role":"collection","identifier":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterTesting","url":"\/documentation\/innoroutertesting","kind":"symbol","title":"InnoRouterTesting","type":"topic","abstract":[]},"doc://com.innosquad.innorouter.docs.core/documentation/InnoRouterCore/InnoRouterCore":{"title":"InnoRouterCore","type":"topic","kind":"article","url":"\/documentation\/innoroutercore\/innoroutercore","abstract":[{"type":"text","text":"State, command, result, and execution primitives for InnoRouter."}],"identifier":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/InnoRouterCore","role":"collectionGroup"}}}