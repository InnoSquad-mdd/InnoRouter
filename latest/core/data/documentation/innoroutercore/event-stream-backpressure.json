{"sections":[],"metadata":{"title":"Event Stream Backpressure","role":"article","roleHeading":"Article","modules":[{"name":"InnoRouterTesting"}]},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Every ","type":"text"},{"code":"NavigationStore","type":"codeVoice"},{"text":", ","type":"text"},{"code":"ModalStore","type":"codeVoice"},{"text":", ","type":"text"},{"code":"FlowStore","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"SceneStore","type":"codeVoice"},{"text":" ","type":"text"},{"text":"publishes an ","type":"text"},{"code":"events: AsyncStream","type":"codeVoice"},{"text":" that fans every observation event","type":"text"},{"text":" ","type":"text"},{"text":"out to every subscriber. The fan-out is implemented as a per-subscriber","type":"text"},{"text":" ","type":"text"},{"code":"AsyncStream.Continuation","type":"codeVoice"},{"text":", which means a slow or cancelled subscriber","type":"text"},{"text":" ","type":"text"},{"text":"that never drains its stream would otherwise retain every event","type":"text"},{"text":" ","type":"text"},{"text":"indefinitely — behaving as an unbounded leak when the broadcaster","type":"text"},{"text":" ","type":"text"},{"text":"outlives all consumers.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To bound that growth, every store accepts an","type":"text"},{"text":" ","type":"text"},{"code":"EventBufferingPolicy","type":"codeVoice"},{"text":" in its configuration.","type":"text"}]},{"type":"heading","level":2,"text":"Default policy","anchor":"Default-policy"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default is "},{"type":"codeVoice","code":"EventBufferingPolicy.default"},{"type":"text","text":", which is"},{"type":"text","text":" "},{"type":"codeVoice","code":".bufferingNewest(1024)"},{"type":"text","text":". The number is sized for realistic navigation"},{"type":"text","text":" "},{"type":"text","text":"bursts (a few hundred events for the longest deep-link replay we have"},{"type":"text","text":" "},{"type":"text","text":"measured) while keeping the retained working set bounded so a stuck"},{"type":"text","text":" "},{"type":"text","text":"subscriber cannot balloon memory in production."}]},{"type":"heading","level":2,"text":"Choosing a policy","anchor":"Choosing-a-policy"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Policy"}]}],[{"type":"paragraph","inlineContent":[{"text":"Behaviour","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"When to use","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".bufferingNewest(N)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Retain at most "},{"type":"codeVoice","code":"N"},{"type":"text","text":" most-recently-broadcast events per subscriber, dropping older events when the buffer fills."}]}],[{"type":"paragraph","inlineContent":[{"text":"Production code that prefers loss-of-history over memory growth under contention. The default.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".bufferingOldest(N)"}]}],[{"type":"paragraph","inlineContent":[{"text":"Retain at most ","type":"text"},{"code":"N","type":"codeVoice"},{"text":" oldest-broadcast events per subscriber, dropping newer events when the buffer fills.","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Audit pipelines that care about the "},{"type":"emphasis","inlineContent":[{"text":"first","type":"text"}]},{"type":"text","text":" burst more than the latest tail (rare)."}]}]],[[{"inlineContent":[{"type":"codeVoice","code":".unbounded"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Buffer every event until the subscriber drains it.","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Test harnesses or short-lived subscribers where you control lifetime and require deterministic, lossless ordering."}],"type":"paragraph"}]]]},{"type":"heading","level":2,"text":"Configuring per store","anchor":"Configuring-per-store"},{"type":"paragraph","inlineContent":[{"text":"The policy is set per store at construction time via its configuration:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["let store = try NavigationStore<HomeRoute>(","    initialPath: [.list],","    configuration: NavigationStoreConfiguration(","        eventBufferingPolicy: .bufferingNewest(2048)","    )",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Modal and Flow stores expose the same knob, with one policy per"},{"type":"text","text":" "},{"type":"text","text":"published stream:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NavigationStoreConfiguration.eventBufferingPolicy"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"ModalStoreConfiguration.eventBufferingPolicy","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"FlowStoreConfiguration.eventBufferingPolicy"},{"text":" for the flow-level","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"FlowStore.events"},{"text":" fan-out","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"FlowStoreConfiguration.navigation.eventBufferingPolicy"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"FlowStoreConfiguration.modal.eventBufferingPolicy"},{"type":"text","text":" for the wrapped"},{"type":"text","text":" "},{"type":"text","text":"inner store streams"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Drop semantics under load","level":2,"anchor":"Drop-semantics-under-load","type":"heading"},{"inlineContent":[{"type":"text","text":"Under sustained backpressure, the store keeps emitting events. Whether"},{"type":"text","text":" "},{"type":"text","text":"the event reaches a slow subscriber depends on the policy chosen for"},{"type":"text","text":" "},{"type":"text","text":"that subscriber’s store:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":".bufferingNewest(N)"},{"type":"text","text":": oldest events are dropped silently. The"},{"type":"text","text":" "},{"type":"text","text":"subscriber sees a contiguous tail of the most recent N events the"},{"type":"text","text":" "},{"type":"text","text":"store emitted."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":".bufferingOldest(N)","type":"codeVoice"},{"text":": newer events are dropped silently after the","type":"text"},{"text":" ","type":"text"},{"text":"buffer fills. The subscriber sees the first N events emitted after","type":"text"},{"text":" ","type":"text"},{"text":"it started subscribing.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".unbounded"},{"type":"text","text":": nothing is dropped, but the per-subscriber queue can"},{"type":"text","text":" "},{"type":"text","text":"grow without bound while the subscriber falls behind."}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Drops are not surfaced as an event. If your analytics pipeline must"},{"type":"text","text":" "},{"type":"text","text":"distinguish “no event happened” from “an event was buffered out”, use"},{"type":"text","text":" "},{"type":"codeVoice","code":".unbounded"},{"type":"text","text":" for that subscriber and rely on your own pacing rather"},{"type":"text","text":" "},{"type":"text","text":"than the broadcaster."}],"type":"paragraph"},{"text":"Lifetime contract","level":2,"anchor":"Lifetime-contract","type":"heading"},{"inlineContent":[{"type":"text","text":"Each subscriber owns one "},{"code":"AsyncStream","type":"codeVoice"},{"type":"text","text":". When the subscriber’s"},{"type":"text","text":" "},{"type":"text","text":"iterator goes out of scope, "},{"code":"AsyncStream.Continuation.onTermination","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"fires and the broadcaster releases its slot. Stores also finish all"},{"type":"text","text":" "},{"type":"text","text":"outstanding continuations on "},{"code":"isolated deinit","type":"codeVoice"},{"type":"text","text":", so "},{"code":"for await","type":"codeVoice"},{"type":"text","text":" loops"},{"type":"text","text":" "},{"type":"text","text":"terminate naturally when their store is released — no manual cleanup"},{"type":"text","text":" "},{"type":"text","text":"required."}],"type":"paragraph"},{"type":"heading","text":"Related","anchor":"Related","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/Middleware-and-Cancellation","type":"reference"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/Rejection-Reasons","type":"reference","isActive":true}]}]}]}]}],"identifier":{"url":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/Event-Stream-Backpressure","interfaceLanguage":"swift"},"kind":"article","schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/innoroutercore\/event-stream-backpressure"]}],"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/InnoRouterCore"]]},"abstract":[{"text":"How the ","type":"text"},{"code":"events","type":"codeVoice"},{"text":" stream of every store handles slow or stuck subscribers.","type":"text"}],"references":{"doc://com.innosqu