{"metadata":{"roleHeading":"Article","title":"Command, batch, and transaction semantics","modules":[{"name":"InnoRouterTesting"}],"role":"article"},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/Command-Batch-and-Transaction-Semantics","interfaceLanguage":"swift"},"abstract":[{"text":"InnoRouter exposes three different execution semantics on purpose.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Single-command-execution","type":"heading","level":2,"text":"Single-command execution"},{"inlineContent":[{"code":"NavigationCommand","type":"codeVoice"},{"text":" models one navigation transition or a recursive command composition.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Important cases:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":".push"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":".pushAll","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":".pop"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":".popCount"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".popToRoot"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".popTo"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":".replace","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":".sequence"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":".whenCancelled","type":"codeVoice"}]}]}],"type":"unorderedList"},{"inlineContent":[{"code":"NavigationEngine","type":"codeVoice"},{"text":" executes these commands against a ","type":"text"},{"code":"RouteStack","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Sequence-semantics","type":"heading","level":2,"text":"Sequence semantics"},{"inlineContent":[{"type":"codeVoice","code":".sequence"},{"type":"text","text":" is command algebra, not a transaction."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"That means:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"commands execute left-to-right"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"earlier successful steps stay applied even if a later step fails","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"later steps still run unless the sequence itself has no more elements","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"the final result is "},{"type":"codeVoice","code":"NavigationResult.multiple(_:)"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":".sequence"},{"type":"text","text":" when partial success is acceptable and the command stream itself is the point."}],"type":"paragraph"},{"anchor":"Fallback-semantics","type":"heading","level":2,"text":"Fallback semantics"},{"inlineContent":[{"type":"codeVoice","code":".whenCancelled(primary, fallback:)"},{"type":"text","text":" is also command algebra."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"That means:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"primary"},{"text":" runs first","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"if ","type":"text"},{"code":"primary","type":"codeVoice"},{"text":" reports anything other than success, the store restores the snapshot and runs ","type":"text"},{"code":"fallback","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"both legs still pass through middleware recursively","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"single-command execution only emits the committed state change","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"transaction execution keeps public middleware observation commit-only, while discarded preview legs run internal cleanup"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Use "},{"code":".whenCancelled","type":"codeVoice"},{"type":"text","text":" when rollback-to-fallback semantics belong to one logical command."}],"type":"paragraph"},{"anchor":"Batch-semantics","type":"heading","level":2,"text":"Batch semantics"},{"inlineContent":[{"type":"codeVoice","code":"NavigationBatchExecutor.executeBatch(_:stopOnFailure:)"},{"text":" is for observation batching.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Batch execution still runs commands one step at a time, but it lets higher layers coalesce observation:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"step middleware still runs","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"stopOnFailure: false","type":"codeVoice"},{"text":" keeps later commands running after a failure","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"stopOnFailure: true"},{"type":"text","text":" stops the batch after the first failed step"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"the store can emit one aggregated callback"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"the caller gets a structured ","type":"text"},{"type":"codeVoice","code":"NavigationBatchResult"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Use batch execution when the caller wants one “transition event” while still preserving per-step execution.","type":"text"}],"type":"paragraph"},{"anchor":"Transaction-semantics","type":"heading","level":2,"text":"Transaction semantics"},{"inlineContent":[{"code":"NavigationTransactionExecutor.executeTransaction(_:)","type":"codeVoice"},{"text":" is the atomic option.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Transactions:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"preview commands on a shadow stack","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"abort on the first failure or cancellation","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"leave the real state unchanged on failure"}]}]},{"content":[{"inlineContent":[{"text":"commit the final state all at once on success","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"surface public ","type":"text"},{"code":"didExecute","type":"codeVoice"},{"text":" \/ transaction observation only for committed leaves","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"run internal discard cleanup for previewed leaves that never commit","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Use transactions when all-or-nothing semantics are required."}],"type":"paragraph"},{"anchor":"Typed-failures","type":"heading","level":2,"text":"Typed failures"},{"inlineContent":[{"text":"Core legality failures stay in typed results instead of exceptions:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"NavigationResult.emptyStack"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NavigationResult.invalidPopCount(_:)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NavigationResult.insufficientStackDepth(requested:available:)"}]}]},{"content":[{"inlineContent":[{"code":"NavigationResult.routeNotFound(_:)","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"NavigationResult.cancelled(_:)","type":"codeVoice"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"This keeps navigation failure in normal control flow and makes policy handling easy to pattern-match.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/InnoRouterCore"]]},"variants":[{"paths":["\/documentation\/innoroutercore\/command-batch-and-transaction-semantics"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","sections":[],"references":{"doc://com.innosquad.innorouter.docs.core/documentation/InnoRouterCore/InnoRouterCore":{"title":"InnoRouterCore","type":"topic","kind":"article","url":"\/documentation\/innoroutercore\/innoroutercore","abstract":[{"type":"text","text":"State, command, result, and execution primitives for InnoRouter."}],"identifier":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterCore\/InnoRouterCore","role":"collectionGroup"},"doc://com.innosquad.innorouter.docs.core/documentation/InnoRouterTesting":{"role":"collection","identifier":"doc:\/\/com.innosquad.innorouter.docs.core\/documentation\/InnoRouterTesting","url":"\/documentation\/innoroutertesting","kind":"symbol","title":"InnoRouterTesting","type":"topic","abstract":[]}}}