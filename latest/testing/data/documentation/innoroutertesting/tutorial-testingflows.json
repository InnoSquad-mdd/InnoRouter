{"identifier":{"url":"doc:\/\/com.innosquad.innorouter.docs.testing\/documentation\/InnoRouterTesting\/Tutorial-TestingFlows","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Setup","text":"Setup"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add "},{"type":"codeVoice","code":"InnoRouterTesting"},{"type":"text","text":" to the test target only:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":[".testTarget(","    name: \"AppTests\",","    dependencies: [","        .product(name: \"InnoRouter\",        package: \"InnoRouter\"),","        .product(name: \"InnoRouterTesting\", package: \"InnoRouter\"),","    ]",")"]},{"type":"paragraph","inlineContent":[{"text":"Then import both modules alongside Swift Testing:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["import Testing","import InnoRouter","import InnoRouterTesting"]},{"type":"heading","level":2,"anchor":"The-happy-path","text":"The happy path"},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["private enum AppRoute: Route {","    case welcome, preAuth, signup","}","","@Test","@MainActor","func pushingPreAuthEmitsNavigationAndPathChange() {","    let store = FlowTestStore<AppRoute>()","","    store.send(.push(.preAuth))","","    store.receiveNavigation { event in","        if case .changed(_, let to) = event { return to.path == [.preAuth] }","        return false","    }","    store.receivePathChanged { old, new in","        old.isEmpty && new == [.push(.preAuth)]","    }","    store.expectNoMoreEvents()","}"]},{"type":"paragraph","inlineContent":[{"code":"FlowTestStore","type":"codeVoice"},{"type":"text","text":" owns a real "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":" and subscribes to every"},{"type":"text","text":" "},{"type":"text","text":"observation surface it exposes (flow, inner navigation, inner"},{"type":"text","text":" "},{"type":"text","text":"modal). Events land in one FIFO queue; "},{"type":"codeVoice","code":"receive*"},{"type":"text","text":" helpers dequeue"},{"type":"text","text":" "},{"text":"them in the order the production stores emit.","type":"text"}]},{"type":"heading","level":2,"anchor":"Modal-+-cancellation","text":"Modal + cancellation"},{"type":"paragraph","inlineContent":[{"code":"FlowTestStore","type":"codeVoice"},{"type":"text","text":" surfaces cancellations as first-class events, so"},{"type":"text","text":" "},{"type":"text","text":"tests can assert them precisely:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@MainActor","private func blockSheetMiddleware() -> AnyModalMiddleware<AppRoute> {","    AnyModalMiddleware(willExecute: { command, _, _ in","        if case .present(let p) = command, p.style == .sheet {","            return .cancel(.middleware(debugName: nil, command: command))","        }","        return .proceed(command)","    })","}","","@Test","@MainActor","func sheetBlockingMiddlewareCancelsTheIntent() {","    let store = FlowTestStore<AppRoute>(","        configuration: .init(","            modal: .init(","                middlewares: [.init(middleware: blockSheetMiddleware(), debugName: \"BlockSheet\")]","            )","        )","    )","","    store.send(.presentSheet(.signup))","","    \/\/ The preview path never commits — only .intentRejected fires.","    store.receiveIntentRejected(","        intent: .presentSheet(.signup),","        reason: .middlewareRejected(debugName: \"BlockSheet\")","    )","    #expect(store.path.isEmpty)","    store.expectNoMoreEvents()","}"]},{"type":"heading","level":2,"anchor":"Skipping-and-draining","text":"Skipping and draining"},{"type":"paragraph","inlineContent":[{"code":"skipReceivedEvents()","type":"codeVoice"},{"text":" discards everything currently queued","type":"text"},{"text":" ","type":"text"},{"text":"without asserting, which is useful when a test only cares about","type":"text"},{"text":" ","type":"text"},{"text":"events ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"after"}]},{"text":" a setup mutation:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["store.send(.presentSheet(.signup)) \/\/ enqueues .modal + .pathChanged","store.skipReceivedEvents()         \/\/ we don't care about setup","","store.send(.push(.preAuth))","store.receiveIntentRejected(intent: .push(.preAuth), reason: .pushBlockedByModalTail)"]},{"type":"heading","level":2,"anchor":"Exhaustivity","text":"Exhaustivity"},{"type":"paragraph","inlineContent":[{"text":"Default is ","type":"text"},{"type":"codeVoice","code":"TestExhaustivity.strict"},{"text":" — any unasserted event at","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"finish()"},{"text":" (or at deinit of the test store) triggers a Swift","type":"text"},{"text":" ","type":"text"},{"text":"Testing ","type":"text"},{"type":"codeVoice","code":"Issue.record"},{"text":". This catches the common mistake of","type":"text"},{"text":" ","type":"text"},{"text":"“missed that the modal also fired a ","type":"text"},{"type":"codeVoice","code":".presented"},{"text":" after the","type":"text"},{"text":" ","type":"text"},{"text":"intended intent.”","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Opt out selectively:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["let store = FlowTestStore<AppRoute>(exhaustivity: .off)"]},{"type":"paragraph","inlineContent":[{"code":".off","type":"codeVoice"},{"text":" preserves per-call assertions; only the end-of-life drain","type":"text"},{"text":" ","type":"text"},{"text":"check is silenced. Useful when migrating a legacy test in stages.","type":"text"}]},{"type":"heading","level":2,"anchor":"Direct-state-inspection","text":"Direct state inspection"},{"type":"paragraph","inlineContent":[{"code":"FlowTestStore","type":"codeVoice"},{"text":" exposes the projected ","type":"text"},{"code":"path","type":"codeVoice"},{"text":" for occasional direct","type":"text"},{"text":" ","type":"text"},{"text":"assertions:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["#expect(store.path == [.push(.preAuth)])"]},{"type":"paragraph","inlineContent":[{"text":"Prefer ","type":"text"},{"code":"receive*","type":"codeVoice"},{"text":" for production assertions — they cover both","type":"text"},{"text":" ","type":"text"},{"text":"state and the emission order — but escape hatches are useful for","type":"text"},{"text":" ","type":"text"},{"text":"sanity checks. The inner ","type":"text"},{"code":"NavigationStore","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"ModalStore","type":"codeVoice"},{"text":" behind a","type":"text"},{"text":" ","type":"text"},{"code":"FlowStore","type":"codeVoice"},{"text":" are SPI in 4.0; use public flow events and ","type":"text"},{"code":"path","type":"codeVoice"},{"text":" unless","type":"text"},{"text":" ","type":"text"},{"text":"you are writing focused package-internal invariant tests.","type":"text"}]},{"type":"heading","level":2,"anchor":"Testing-middleware-behaviour-directly","text":"Testing middleware behaviour directly"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modal-blocking example above tests middleware "},{"inlineContent":[{"type":"text","text":"through"}],"type":"emphasis"},{"type":"text","text":" a flow"},{"type":"text","text":" "},{"type":"text","text":"store. Sometimes you want to test the middleware itself — does it"},{"type":"text","text":" "},{"type":"text","text":"correctly pass through, cancel, or rewrite commands for every input"},{"type":"text","text":" "},{"type":"text","text":"shape? "},{"code":"NavigationTestStore","type":"codeVoice"},{"type":"text","text":" + "},{"code":"ModalTestStore","type":"codeVoice"},{"type":"text","text":" let you do that"},{"type":"text","text":" "},{"type":"text","text":"without a FlowStore in the middle."}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@MainActor","private final class RecordingMiddleware: NavigationMiddleware {","    typealias RouteType = AppRoute","","    private(set) var seenCommands: [NavigationCommand<AppRoute>] = []","","    func willExecute(","        _ command: NavigationCommand<AppRoute>,","        state: RouteStack<AppRoute>","    ) -> NavigationInterception<AppRoute> {","        seenCommands.append(command)","        if case .push(let route) = command, route == .signup {","            return .cancel(.middleware(debugName: \"BlockSignup\", command: command))","        }","        return .proceed(command)","    }","","    func didExecute(","        _ command: NavigationCommand<AppRoute>,","        result: NavigationResult<AppRoute>,","        state: RouteStack<AppRoute>","    ) -> NavigationResult<AppRoute> {","        result","    }","}","","@Test","@MainActor","func middlewareCancelsSignupButNotWelcome() {","    let middleware = RecordingMiddleware()","    let store = NavigationTestStore<AppRoute>(","        configuration: .init(","            middlewares: [.init(middleware: middleware, debugName: \"Recorder\")]","        )","    )","","    store.send(.push(.welcome))","    store.receiveChange { _, to in to.path == [.welcome] }","","    store.send(.push(.signup))","    store.receiveIntercepted(reason: .middleware(debugName: \"BlockSignup\", command: .push(.signup)))","","    #expect(middleware.seenCommands.count == 2)","    store.expectNoMoreEvents()","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Recording middlewares work naturally with "},{"type":"codeVoice","code":"@MainActor final class"},{"type":"text","text":" "},{"type":"text","text":"and mutable state. Pair them with "},{"type":"codeVoice","code":"receiveIntercepted"},{"type":"text","text":" to assert"},{"type":"text","text":" "},{"type":"text","text":"which interceptions fired and in what order, and with direct"},{"type":"text","text":" "},{"type":"text","text":"reads on the middleware instance to assert which commands it saw."}]},{"type":"heading","level":2,"anchor":"Property-based-test-recipes","text":"Property-based test recipes"},{"type":"paragraph","inlineContent":[{"text":"InnoRouter’s own property-based suites use","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Tests\/InnoRouterTests\/PropertyTestSupport.swift"},{"text":". That helper lives","type":"text"},{"text":" ","type":"text"},{"text":"in this repository’s test target, not in the shipped","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"InnoRouterTesting"},{"text":" product, so downstream apps should copy or adapt","type":"text"},{"text":" ","type":"text"},{"text":"the pattern rather than expect ","type":"text"},{"type":"codeVoice","code":"@testable import InnoRouterTesting"},{"text":" ","type":"text"},{"text":"to expose ","type":"text"},{"type":"codeVoice","code":"SeededGenerator"},{"text":", ","type":"text"},{"type":"codeVoice","code":"Arbitrary"},{"text":", or ","type":"text"},{"type":"codeVoice","code":"FlowModelState"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The idiom is "},{"type":"strong","inlineContent":[{"type":"text","text":"Swift Testing "},{"code":"@Test(arguments:)","type":"codeVoice"},{"type":"text","text":" iterated over many"},{"type":"text","text":" "},{"type":"text","text":"seeds"}]},{"type":"text","text":", each seed driving a deterministic random intent stream:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@Test(arguments: 0..<100)","@MainActor","func randomFlowIntentsPreserveInvariants(seed: UInt64) async {","    var rng = SeededGenerator(seed: seed)","    let store = FlowTestStore<AppRoute>(exhaustivity: .off)","","    for _ in 0..<30 {","        let intent = Arbitrary.flowIntent(","            rng: &rng,","            routes: [.welcome, .preAuth, .signup]","        )","        store.send(intent)","    }","","    \/\/ Invariant: modal-tail is always the final step, never in the middle.","    let modalIndices = store.path.indices.filter { store.path[$0].isModal }","    #expect(modalIndices.allSatisfy { $0 == store.path.count - 1 })","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Swift Testing runs the 100 parameterised cases in parallel by"},{"type":"text","text":" "},{"type":"text","text":"default, so total wall-clock time stays close to a single iteration."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A pairs-with pattern: "},{"type":"strong","inlineContent":[{"type":"text","text":"run the random stream through both the"},{"type":"text","text":" "},{"type":"text","text":"real store and a reference model"}]},{"type":"text","text":", then assert they agree step by"},{"type":"text","text":" "},{"type":"text","text":"step. That’s how "},{"code":"FlowStorePropertyBasedTests","type":"codeVoice"},{"type":"text","text":" catches subtle"},{"type":"text","text":" "},{"type":"text","text":"divergences between the journal-driven implementation and the"},{"type":"text","text":" "},{"type":"text","text":"intended semantics. See this repository’s PropertyTestSupport source"},{"type":"text","text":" "},{"type":"text","text":"for the model-driven "},{"code":"FlowModelState","type":"codeVoice"},{"type":"text","text":" pattern."}]},{"type":"heading","level":2,"anchor":"Next-steps","text":"Next steps"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Read the "},{"type":"codeVoice","code":"Tutorial-LoginOnboarding"},{"type":"text","text":" guide in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"InnoRouterSwiftUI"},{"type":"text","text":" documentation catalog for the end-to-end flow"},{"type":"text","text":" "},{"type":"text","text":"being tested here."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Read the "},{"code":"Tutorial-MiddlewareComposition","type":"codeVoice"},{"type":"text","text":" guide in the"},{"type":"text","text":" "},{"code":"InnoRouterSwiftUI","type":"codeVoice"},{"type":"text","text":" documentation catalog for the middleware"},{"type":"text","text":" "},{"type":"text","text":"surfaces the harness asserts against."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Cross-reference "},{"type":"codeVoice","code":"<doc:Rejection-Reasons>"},{"type":"text","text":" (in InnoRouterCore) for"},{"type":"text","text":" "},{"type":"text","text":"the full rejection taxonomy your "},{"type":"codeVoice","code":"receiveIntentRejected"},{"type":"text","text":" \/"},{"type":"text","text":" "},{"type":"codeVoice","code":"receiveIntercepted"},{"type":"text","text":" calls can pattern-match on."}],"type":"paragraph"}]}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/innoroutertesting\/tutorial-testingflows"]}],"kind":"article","metadata":{"modules":[{"name":"InnoRouterMacros"}],"role":"article","title":"Testing Flows End-to-End with `FlowTestStore`","roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.testing\/documentation\/InnoRouterMacros"],["doc:\/\/com.innosquad.innorouter.docs.testing\/documentation\/InnoRouterMacros","doc:\/\/com.innosquad.innorouter.docs.testing\/documentation\/InnoRouterTesting\/InnoRouterTesting"]]},"abstract":[{"text":"Assert the complete chain triggered by a single ","type":"text"},{"code":"FlowIntent","type":"codeVoice"},{"text":" —","type":"text"},{"text":" ","type":"text"},{"text":"navigation, modal, middleware cancellation, path reconciliation —","type":"text"},{"text":" ","type":"text"},{"text":"through a single FIFO receive queue, without mounting any SwiftUI","type":"text"},{"text":" ","type":"text"},{"text":"host.","type":"text"}],"sections":[],"references":{"doc://com.innosquad.innorouter.docs.testing/documentation/InnoRouterTesting/InnoRouterTesting":{"abstract":[{"text":"Host-less, Swift-Testing native assertion harness for InnoRouter’s navigation, modal, and flow authorities.","type":"text"}],"role":"collectionGroup","type":"topic","url":"\/documentation\/innoroutertesting\/innoroutertesting","kind":"article","identifier":"doc:\/\/com.innosquad.innorouter.docs.testing\/documentation\/InnoRouterTesting\/InnoRouterTesting","title":"InnoRouterTesting"},"doc://com.innosquad.innorouter.docs.testing/documentation/InnoRouterMacros":{"identifier":"doc:\/\/com.innosquad.innorouter.docs.testing\/documentation\/InnoRouterMacros","abstract":[],"url":"\/documentation\/innoroutermacros","role":"collection","kind":"symbol","type":"topic","title":"InnoRouterMacros"}}}