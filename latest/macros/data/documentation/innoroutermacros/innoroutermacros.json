{"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterMacros\/InnoRouterMacros"},"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterTesting"]]},"abstract":[{"text":"Route and case-path convenience macros for InnoRouter.","type":"text"}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"InnoRouterMacros"},{"type":"text","text":" reduces route boilerplate without changing runtime semantics."}]},{"type":"paragraph","inlineContent":[{"text":"It currently exposes:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"@Routable"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"@CasePathable","type":"codeVoice"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"These macros are optional. Everything in InnoRouter can still be written manually with plain Swift types.","type":"text"}]},{"level":2,"type":"heading","anchor":"Imports","text":"Imports"},{"type":"paragraph","inlineContent":[{"type":"text","text":"InnoRouter intentionally ships the macros as a distinct product from"},{"type":"text","text":" "},{"type":"text","text":"the main umbrella so apps can opt into macro expansion per-file."},{"type":"text","text":" "},{"type":"text","text":"That means "},{"type":"strong","inlineContent":[{"text":"different imports pull different surfaces into scope","type":"text"}]},{"type":"text","text":":"}]},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"import InnoRouterMacros"},{"type":"text","text":" is required to use "},{"type":"codeVoice","code":"@Routable"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"@CasePathable"},{"type":"text","text":" on a declaration. The umbrella "},{"type":"codeVoice","code":"InnoRouter"},{"type":"text","text":" does"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" re-export the macros — this is deliberate so non-macro"},{"type":"text","text":" "},{"type":"text","text":"files don’t pay the macro-plugin resolution cost."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"import InnoRouter"},{"type":"text","text":" (or "},{"type":"codeVoice","code":"import InnoRouterSwiftUI"},{"type":"text","text":" directly) is"},{"type":"text","text":" "},{"type":"text","text":"enough for everything else — stores, hosts, intents, events,"},{"type":"text","text":" "},{"type":"codeVoice","code":"@EnvironmentNavigationIntent"},{"type":"text","text":", "},{"type":"codeVoice","code":"@EnvironmentModalIntent"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"innoRouterSceneHost"},{"type":"text","text":", "},{"type":"codeVoice","code":"innoRouterOrnament"},{"type":"text","text":", and the Core types."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A file that uses both macros and runtime symbols imports both:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["import InnoRouter","import InnoRouterMacros","","@Routable","enum HomeRoute {","    case list","    case detail","}","","struct HomeListView: View {","    @EnvironmentNavigationIntent(HomeRoute.self) private var navigationIntent","    \/\/ ...","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A file that only consumes the routing runtime (for example a plain"},{"type":"text","text":" "},{"type":"text","text":"view that reads "},{"code":"@EnvironmentNavigationIntent","type":"codeVoice"},{"type":"text","text":" for an already-declared"},{"type":"text","text":" "},{"type":"text","text":"route) doesn’t need "},{"code":"import InnoRouterMacros","type":"codeVoice"},{"type":"text","text":" at all."}]}],"kind":"content"}],"metadata":{"modules":[{"name":"InnoRouterTesting"}],"title":"InnoRouterMacros","role":"collectionGroup"},"kind":"article","sections":[],"topicSections":[{"anchor":"Essentials","identifiers":["doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterMacros\/Routable-and-CasePathable"],"title":"Essentials"},{"anchor":"Guides","identifiers":["doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterMacros\/Guide-MacroVisibility"],"title":"Guides"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/innoroutermacros\/innoroutermacros"]}],"references":{"doc://com.innosquad.innorouter.docs.macros/documentation/InnoRouterTesting":{"kind":"symbol","type":"topic","title":"InnoRouterTesting","identifier":"doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterTesting","role":"collection","abstract":[],"url":"\/documentation\/innoroutertesting"},"doc://com.innosquad.innorouter.docs.macros/documentation/InnoRouterMacros/Guide-MacroVisibility":{"role":"article","kind":"article","identifier":"doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterMacros\/Guide-MacroVisibility","url":"\/documentation\/innoroutermacros\/guide-macrovisibility","abstract":[{"type":"text","text":"Starting in 4.0.0 the "},{"type":"codeVoice","code":"@Routable"},{"type":"text","text":" and "},{"type":"codeVoice","code":"@CasePathable"},{"type":"text","text":" macros"},{"type":"text","text":" "},{"type":"text","text":"infer the access level of every generated member from the"},{"type":"text","text":" "},{"type":"text","text":"enclosing enum. The previous behaviour emitted everything as"},{"type":"text","text":" "},{"type":"codeVoice","code":"public"},{"type":"text","text":", which leaked CasePath surface for "},{"type":"codeVoice","code":"internal"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"private"},{"type":"text","text":" enums that never intended that visibility."}],"type":"topic","title":"`@Routable` \/ `@CasePathable` access level inference"},"doc://com.innosquad.innorouter.docs.macros/documentation/InnoRouterMacros/Routable-and-CasePathable":{"kind":"article","url":"\/documentation\/innoroutermacros\/routable-and-casepathable","title":"Routable and CasePathable","abstract":[{"text":"Use macros when you want concise route declarations in user-facing code and examples.","type":"text"}],"identifier":"doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterMacros\/Routable-and-CasePathable","type":"topic","role":"article"}}}