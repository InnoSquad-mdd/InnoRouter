{"kind":"article","sections":[],"abstract":[{"type":"text","text":"Starting in 4.0.0 the "},{"type":"codeVoice","code":"@Routable"},{"type":"text","text":" and "},{"type":"codeVoice","code":"@CasePathable"},{"type":"text","text":" macros"},{"type":"text","text":" "},{"type":"text","text":"infer the access level of every generated member from the"},{"type":"text","text":" "},{"type":"text","text":"enclosing enum. The previous behaviour emitted everything as"},{"type":"text","text":" "},{"type":"codeVoice","code":"public"},{"type":"text","text":", which leaked CasePath surface for "},{"type":"codeVoice","code":"internal"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"private"},{"type":"text","text":" enums that never intended that visibility."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterMacros\/Guide-MacroVisibility","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterMacros\/InnoRouterMacros"]]},"variants":[{"paths":["\/documentation\/innoroutermacros\/guide-macrovisibility"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"`@Routable` \/ `@CasePathable` access level inference","modules":[{"name":"InnoRouterTesting"}],"role":"article","roleHeading":"Article"},"primaryContentSections":[{"content":[{"type":"heading","anchor":"What-gets-generated-and-at-what-level","text":"What gets generated, and at what level","level":2},{"type":"paragraph","inlineContent":[{"text":"For every ","type":"text"},{"code":"@Routable","type":"codeVoice"},{"text":" (or ","type":"text"},{"code":"@CasePathable","type":"codeVoice"},{"text":") enum the macros emit:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"enum Cases { … }"},{"type":"text","text":" containing one "},{"type":"codeVoice","code":"static let"},{"type":"text","text":" per case."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"func is(_ casePath:) -> Bool","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"subscript(case:) -> Value?","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The access keyword applied to all four is inferred from the"},{"type":"text","text":" "},{"type":"text","text":"enclosing enum:"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Enum modifier","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Generated members","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"public enum Foo"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"public"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"package enum Foo"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"package"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"internal enum Foo"},{"type":"text","text":" (or no modifier)"}],"type":"paragraph"}],[{"inlineContent":[{"code":"internal","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"fileprivate enum Foo","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"fileprivate"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"private enum Foo"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"fileprivate"},{"type":"text","text":" (lowest level the macro can emit while still letting same-file "},{"type":"codeVoice","code":"is(_:)"},{"type":"text","text":" and "},{"type":"codeVoice","code":"subscript(case:)"},{"type":"text","text":" callers reach the cases)"}],"type":"paragraph"}]]]},{"type":"paragraph","inlineContent":[{"text":"Each case ","type":"text"},{"code":"static let","type":"codeVoice"},{"text":" also receives any ","type":"text"},{"code":"@available(...)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"attribute attached to the enum case, so a case gated on an OS","type":"text"},{"text":" ","type":"text"},{"text":"version no longer produces a CasePath member with a wider","type":"text"},{"text":" ","type":"text"},{"text":"availability than the underlying case.","type":"text"}]},{"type":"heading","anchor":"Compatibility-for-pre-OSS-snapshots","text":"Compatibility for pre-OSS snapshots","level":2},{"type":"paragraph","inlineContent":[{"text":"Before the 4.0.0 OSS release, internal macro snapshots always emitted","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"public"},{"text":". Teams that tested those snapshots should check three","type":"text"},{"text":" ","type":"text"},{"text":"patterns:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Enum and CasePath usage already match."}]},{"type":"text","text":" No action — the"},{"type":"text","text":" "},{"type":"text","text":"generated members tighten to "},{"type":"codeVoice","code":"internal"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"fileprivate"},{"type":"text","text":" \/"},{"type":"text","text":" "},{"type":"codeVoice","code":"fileprivate"},{"type":"text","text":" matching the enum and the consumer code keeps"},{"type":"text","text":" "},{"type":"text","text":"compiling because it was within the same module already."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Enum is not "},{"code":"public","type":"codeVoice"},{"type":"text","text":" but a sibling module reads the"},{"type":"text","text":" "},{"type":"text","text":"generated CasePath members."}],"type":"strong"},{"text":" Mark the enum ","type":"text"},{"code":"public","type":"codeVoice"},{"text":". The","type":"text"},{"text":" ","type":"text"},{"text":"pre-OSS behaviour was effectively widening the surface for you;","type":"text"},{"text":" ","type":"text"},{"text":"4.0.0 makes the boundary explicit.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Enum cases are gated on "},{"type":"codeVoice","code":"@available(...)"},{"type":"text","text":"."}]},{"type":"text","text":" The generated"},{"type":"text","text":" "},{"type":"text","text":"CasePath members now carry the same availability. If a"},{"type":"text","text":" "},{"type":"text","text":"downstream call site compiled under a wider availability"},{"type":"text","text":" "},{"type":"text","text":"window before, narrow the enclosing function or branch on"},{"type":"text","text":" "},{"type":"codeVoice","code":"if #available(...)"},{"type":"text","text":" to match."}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Why-private-enums-emit-fileprivate","text":"Why `private` enums emit `fileprivate`","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Swift does not let an extension method (the macro emits"},{"type":"text","text":" "},{"type":"codeVoice","code":"is(_:)"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"subscript(case:)"},{"type":"text","text":" as members on the enum itself,"},{"type":"text","text":" "},{"type":"text","text":"not on a generated extension) reference a "},{"type":"codeVoice","code":"private"},{"type":"text","text":" "},{"type":"text","text":"declaration in its own scope when that declaration came from"},{"type":"text","text":" "},{"type":"text","text":"a distinct macro plugin call. Falling back to "},{"type":"codeVoice","code":"fileprivate"},{"type":"text","text":" "},{"type":"text","text":"gives the same effective scope for any caller in the same file"},{"type":"text","text":" "},{"type":"text","text":"without breaking the macro expansion."}]},{"type":"heading","anchor":"Opt-out","text":"Opt-out","level":2},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"@Routable(visibility: .public)"},{"text":" argument is on the v4.x","type":"text"},{"text":" ","type":"text"},{"text":"roadmap for consumers that intentionally want the wider surface","type":"text"},{"text":" ","type":"text"},{"text":"without making the enclosing enum public. Until then, mark the","type":"text"},{"text":" ","type":"text"},{"text":"enum ","type":"text"},{"type":"codeVoice","code":"public"},{"text":" to widen the generated members.","type":"text"}]}],"kind":"content"}],"references":{"doc://com.innosquad.innorouter.docs.macros/documentation/InnoRouterMacros/InnoRouterMacros":{"url":"\/documentation\/innoroutermacros\/innoroutermacros","abstract":[{"type":"text","text":"Route and case-path convenience macros for InnoRouter."}],"identifier":"doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterMacros\/InnoRouterMacros","role":"collectionGroup","type":"topic","kind":"article","title":"InnoRouterMacros"},"doc://com.innosquad.innorouter.docs.macros/documentation/InnoRouterTesting":{"kind":"symbol","type":"topic","title":"InnoRouterTesting","identifier":"doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterTesting","role":"collection","abstract":[],"url":"\/documentation\/innoroutertesting"}}}