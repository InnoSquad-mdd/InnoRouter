{"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterMacros\/InnoRouterMacros"]]},"kind":"article","abstract":[{"text":"Use macros when you want concise route declarations in user-facing code and examples.","type":"text"}],"sections":[],"metadata":{"roleHeading":"Article","role":"article","title":"Routable and CasePathable","modules":[{"name":"InnoRouterTesting"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterMacros\/Routable-and-CasePathable"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/innoroutermacros\/routable-and-casepathable"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Routable","text":"`@Routable`"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"@Routable"},{"type":"text","text":" removes the manual "},{"type":"codeVoice","code":"Route"},{"type":"text","text":" conformance declaration for route enums."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is the preferred style for:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"README examples"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"DocC snippets","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"human-facing examples in ","type":"text"},{"code":"Examples\/","type":"codeVoice"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"anchor":"CasePathable","text":"`@CasePathable`"},{"type":"paragraph","inlineContent":[{"code":"@CasePathable","type":"codeVoice"},{"text":" generates lightweight case-path support for enum extraction and composition.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This is useful when:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"feature code needs ergonomic enum matching"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"a route hierarchy should expose reusable extraction helpers","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"anchor":"Examples-vs-smoke-fixtures","text":"Examples vs smoke fixtures"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The repository intentionally splits examples:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"Examples\/","type":"codeVoice"},{"text":" uses macros and the most idiomatic API surface","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"ExamplesSmoke\/"},{"text":" uses compiler-stable fixtures for CI","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"That split keeps public-facing docs modern without making CI depend on every macro edge case.","type":"text"}]},{"type":"heading","level":2,"anchor":"Limitations-generic-enums","text":"Limitations: generic enums"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both "},{"type":"codeVoice","code":"@Routable"},{"type":"text","text":" and "},{"type":"codeVoice","code":"@CasePathable"},{"type":"text","text":" reject generic enum declarations with an"},{"type":"text","text":" "},{"type":"text","text":"explicit compiler error:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@Routable","enum Generic<T> { case detail(T) } \/\/ ❌ error: @Routable does not support generic enum declarations"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The generated "},{"type":"codeVoice","code":"enum Cases"},{"type":"text","text":" would need to materialise "},{"type":"codeVoice","code":"CasePath<Self, T>"},{"type":"text","text":" "},{"type":"text","text":"members for each generic instantiation, but Swift does not propagate the"},{"type":"text","text":" "},{"type":"text","text":"parent’s generic parameters into a nested type that way. Diagnostic ID"},{"type":"text","text":" "},{"type":"codeVoice","code":"InnoRouterMacros.unsupportedGenericEnum"},{"type":"text","text":" is emitted on the generic"},{"type":"text","text":" "},{"type":"text","text":"parameter clause."}]},{"type":"paragraph","inlineContent":[{"text":"If you need a generic shape, separate the generic case into a non-generic","type":"text"},{"text":" ","type":"text"},{"text":"wrapper:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@Routable","enum AppRoute: Route {","    case home","    case detail(DetailRoute) \/\/ wrap a concrete payload type","}","","\/\/ Keep the generic carrier outside the route enum.","struct DetailRoute<T>: Hashable { let payload: T }"]}],"kind":"content"}],"references":{"doc://com.innosquad.innorouter.docs.macros/documentation/InnoRouterTesting":{"kind":"symbol","type":"topic","title":"InnoRouterTesting","identifier":"doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterTesting","role":"collection","abstract":[],"url":"\/documentation\/innoroutertesting"},"doc://com.innosquad.innorouter.docs.macros/documentation/InnoRouterMacros/InnoRouterMacros":{"url":"\/documentation\/innoroutermacros\/innoroutermacros","abstract":[{"type":"text","text":"Route and case-path convenience macros for InnoRouter."}],"identifier":"doc:\/\/com.innosquad.innorouter.docs.macros\/documentation\/InnoRouterMacros\/InnoRouterMacros","role":"collectionGroup","type":"topic","kind":"article","title":"InnoRouterMacros"}}}