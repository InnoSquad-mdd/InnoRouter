:"When authentication is required but not currently satisfied, the pipeline returns "},{"code":"DeepLinkDecision.pending(_:)","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"This is deliberate:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"the route that triggered authentication deferral is preserved","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"the navigation plan is preserved","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"replay responsibility remains explicit at the app boundary"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"That keeps auth transitions and navigation transitions separate instead of blending them into one hidden side effect."}],"type":"paragraph"},{"text":"Planning","anchor":"Planning","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The planner converts a route into the exact command list that should run after acceptance. This makes deep-link execution deterministic and testable."}],"type":"paragraph"},{"inlineContent":[{"text":"Authentication checks the routes referenced by the produced","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"NavigationPlan"},{"text":", including nested sequences and fallback commands.","type":"text"},{"text":" ","type":"text"},{"text":"If a custom planner returns no route-bearing commands, the pipeline","type":"text"},{"text":" ","type":"text"},{"text":"falls back to the originally resolved route.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Effect handlers and coordinator bridges validate a produced"},{"type":"text","text":" "},{"type":"codeVoice","code":"NavigationPlan"},{"type":"text","text":" against the current "},{"type":"codeVoice","code":"RouteStack"},{"type":"text","text":" before executing it."},{"type":"text","text":" "},{"type":"text","text":"Plans that are obviously impossible, such as "},{"type":"codeVoice","code":".pop"},{"type":"text","text":" on an empty stack,"},{"type":"text","text":" "},{"type":"text","text":"surface as typed application rejections instead of partially running."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://com.innosquad.innorouter.docs.deeplink/documentation/InnoRouterTesting":{"kind":"symbol","identifier":"doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterTesting","url":"\/documentation\/innoroutertesting","abstract":[],"title":"InnoRouterTesting","type":"topic","role":"collection"},"doc://com.innosquad.innorouter.docs.deeplink/documentation/InnoRouterDeepLink/InnoRouterDeepLink":{"abstract":[{"text":"Pattern matching, pipeline planning, and pending deep-link handling for InnoRouter.","type":"text"}],"title":"InnoRouterDeepLink","role":"collectionGroup","url":"\/documentation\/innorouterdeeplink\/innorouterdeeplink","identifier":"doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterDeepLink\/InnoRouterDeepLink","kind":"article","type":"topic"}}}