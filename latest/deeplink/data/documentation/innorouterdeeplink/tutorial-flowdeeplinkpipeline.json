{"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Map a URL to a "},{"code":"FlowPlan","type":"codeVoice"},{"type":"text","text":" with push prefix and optional modal"},{"type":"text","text":" "},{"type":"text","text":"terminal step, run it through authentication gating, and replay the"},{"type":"text","text":" "},{"type":"text","text":"deferred link through "},{"code":"FlowDeepLinkEffectHandler","type":"codeVoice"},{"type":"text","text":" — all in one"},{"type":"text","text":" "},{"type":"text","text":"atomic "},{"code":"FlowStore.apply(_:)","type":"codeVoice"},{"type":"text","text":"."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/innorouterdeeplink\/tutorial-flowdeeplinkpipeline"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterDeepLink\/InnoRouterDeepLink"]]},"metadata":{"modules":[{"name":"InnoRouterTesting"}],"title":"Rehydrating Composite Flows from a URL","roleHeading":"Article","role":"article"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterDeepLink\/Tutorial-FlowDeepLinkPipeline"},"primaryContentSections":[{"content":[{"anchor":"Scenario","level":2,"type":"heading","text":"Scenario"},{"type":"paragraph","inlineContent":[{"code":"myapp:\/\/app\/home\/detail\/42","type":"codeVoice"},{"type":"text","text":" should land the user on the order detail"},{"type":"text","text":" "},{"type":"text","text":"for order 42. "},{"code":"myapp:\/\/app\/onboarding\/privacy","type":"codeVoice"},{"type":"text","text":" should open a privacy"},{"type":"text","text":" "},{"type":"text","text":"sheet over the current screen. Authenticated routes like"},{"type":"text","text":" "},{"code":"myapp:\/\/app\/secure","type":"codeVoice"},{"type":"text","text":" defer until sign-in completes, then replay."}]},{"type":"paragraph","inlineContent":[{"text":"Push-only pipelines (","type":"text"},{"type":"codeVoice","code":"DeepLinkPipeline"},{"text":" → ","type":"text"},{"type":"codeVoice","code":"NavigationPlan<R>"},{"text":") can’t","type":"text"},{"text":" ","type":"text"},{"text":"express a URL that terminates on a modal. ","type":"text"},{"type":"codeVoice","code":"FlowDeepLinkPipeline"},{"text":" ","type":"text"},{"text":"solves that by emitting ","type":"text"},{"type":"codeVoice","code":"FlowPlan"},{"text":" — a single value holding both","type":"text"},{"text":" ","type":"text"},{"text":"the navigation prefix and the tail sheet\/cover.","type":"text"}]},{"anchor":"Routes","level":2,"type":"heading","text":"Routes"},{"code":["enum AppRoute: Route {","    case home","    case detail(id: String)","    case comments(id: String)","    case privacyPolicy","    case secure","}"],"type":"codeListing","syntax":"swift skip doc-fragment"},{"anchor":"Defining-the-matcher","level":2,"type":"heading","text":"Defining the matcher"},{"type":"paragraph","inlineContent":[{"code":"FlowDeepLinkMapping","type":"codeVoice"},{"text":" handlers return a ","type":"text"},{"inlineContent":[{"type":"text","text":"complete"}],"type":"strong"},{"text":" ","type":"text"},{"code":"FlowPlan","type":"codeVoice"},{"text":" so","type":"text"},{"text":" ","type":"text"},{"text":"multi-segment URLs expand atomically. Pattern syntax matches","type":"text"},{"text":" ","type":"text"},{"code":"DeepLinkMapping","type":"codeVoice"},{"text":": ","type":"text"},{"type":"codeVoice","code":":parameter"},{"type":"text","text":" for captures, terminal "},{"type":"codeVoice","code":"*"},{"type":"text","text":" wildcard,"},{"type":"text","text":" "},{"type":"text","text":"path-only (host and scheme are filtered separately by the pipeline)."},{"type":"text","text":" "},{"type":"text","text":"Non-terminal wildcards such as "},{"code":"\/store\/*\/receipt","type":"codeVoice"},{"type":"text","text":" are invalid and"},{"type":"text","text":" "},{"type":"text","text":"surface diagnostics instead of matching."}]},{"code":["let matcher = FlowDeepLinkMatcher<AppRoute> {","    FlowDeepLinkMapping(\"\/home\") { _ in","        FlowPlan(steps: [.push(.home)])","    }","    FlowDeepLinkMapping(\"\/home\/detail\/:id\") { params in","        guard let id = params.firstValue(forName: \"id\") else { return nil }","        return FlowPlan(steps: [.push(.home), .push(.detail(id: id))])","    }","    FlowDeepLinkMapping(\"\/home\/detail\/:id\/comments\/:cid\") { params in","        guard let id = params.firstValue(forName: \"id\"),","              let cid = params.firstValue(forName: \"cid\") else { return nil }","        return FlowPlan(steps: [","            .push(.home),","            .push(.detail(id: id)),","            .push(.comments(id: cid))","        ])","    }","    FlowDeepLinkMapping(\"\/onboarding\/privacy\") { _ in","        FlowPlan(steps: [.sheet(.privacyPolicy)])","    }","    FlowDeepLinkMapping(\"\/secure\") { _ in","        FlowPlan(steps: [.push(.secure)])","    }","}"],"type":"codeListing","syntax":"swift skip doc-fragment"},{"type":"heading","level":2,"text":"Wiring the pipeline","anchor":"Wiring-the-pipeline"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"FlowDeepLinkPipeline"},{"type":"text","text":" composes scheme\/host validation,"},{"type":"text","text":" "},{"type":"codeVoice","code":"DeepLinkAuthenticationPolicy"},{"type":"text","text":" (reused from the push-only surface),"},{"type":"text","text":" "},{"type":"text","text":"and the matcher:"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["let pipeline = FlowDeepLinkPipeline<AppRoute>(","    allowedSchemes: [\"myapp\"],","    allowedHosts: [\"app\"],","    matcher: matcher,","    authenticationPolicy: .required(","        shouldRequireAuthentication: { route in","            if case .secure = route { return true }","            return false","        },","        isAuthenticated: { SessionStore.shared.isAuthenticated }","    )",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For unguarded apps pass "},{"type":"codeVoice","code":".notRequired"},{"type":"text","text":" (the default) and skip the"},{"type":"text","text":" "},{"type":"text","text":"policy closure entirely."}]},{"type":"heading","level":2,"text":"Applying through FlowStore","anchor":"Applying-through-FlowStore"},{"type":"paragraph","inlineContent":[{"code":"FlowDeepLinkEffectHandler","type":"codeVoice"},{"text":" bridges the pipeline output into any","type":"text"},{"text":" ","type":"text"},{"code":"FlowPlanApplier","type":"codeVoice"},{"text":". It also owns the pending slot, so keep the handler","type":"text"},{"text":" ","type":"text"},{"text":"in a stable owner rather than rebuilding it inside a SwiftUI body.","type":"text"},{"text":" ","type":"text"},{"code":"FlowStore","type":"codeVoice"},{"text":" already conforms:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["import Foundation","import SwiftUI","import InnoRouter","import InnoRouterDeepLinkEffects","","private final class SessionStore {","    static let shared = SessionStore()","","    private let lock = NSLock()","    private var signedIn = false","","    var isAuthenticated: Bool {","        lock.withLock { signedIn }","    }","","    func markAuthenticated() {","        lock.withLock { signedIn = true }","    }","}","","@MainActor","private final class DeepLinkCoordinator {","    let flow: FlowStore<AppRoute>","    let handler: FlowDeepLinkEffectHandler<AppRoute>","    private let session: SessionStore","","    init(session: SessionStore = .shared) {","        self.session = session","        let flow = FlowStore<AppRoute>()","        self.flow = flow","","        let matcher = FlowDeepLinkMatcher<AppRoute> {","            FlowDeepLinkMapping(\"\/home\") { _ in","                FlowPlan(steps: [.push(.home)])","            }","            FlowDeepLinkMapping(\"\/onboarding\/privacy\") { _ in","                FlowPlan(steps: [.sheet(.privacyPolicy)])","            }","            FlowDeepLinkMapping(\"\/secure\") { _ in","                FlowPlan(steps: [.push(.secure)])","            }","        }","        let pipeline = FlowDeepLinkPipeline(","            allowedSchemes: [\"myapp\"],","            allowedHosts: [\"app\"],","            matcher: matcher,","            authenticationPolicy: .required(","                shouldRequireAuthentication: { route in","                    if case .secure = route { return true }","                    return false","                },","                isAuthenticated: { session.isAuthenticated }","            )","        )","        self.handler = FlowDeepLinkEffectHandler(","            pipeline: pipeline,","            applier: flow","        )","    }","","    func userDidSignIn() {","        session.markAuthenticated()","        _ = handler.resumePendingDeepLink()","    }","}","","@main","struct DemoApp: App {","    @State private var coordinator = DeepLinkCoordinator()","","    var body: some Scene {","        WindowGroup {","            FlowHost(","                store: coordinator.flow,","                destination: { route in","                    switch route {","                    case .home:","                        Text(\"Home\")","                    case .detail(let id):","                        Text(\"Detail \\(id)\")","                    case .comments(let id):","                        Text(\"Comments \\(id)\")","                    case .privacyPolicy:","                        Text(\"Privacy\")","                    case .secure:","                        Text(\"Secure\")","                    }","                },","                root: { Text(\"Root\") }","            )","            .onOpenURL { url in","                _ = coordinator.handler.handle(url)","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A single "},{"type":"codeVoice","code":"handler.handle(url)"},{"type":"text","text":" call:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Runs scheme\/host validation."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Walks the matcher for a "},{"type":"codeVoice","code":"FlowPlan"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Runs the authentication policy across the plan until it finds the"},{"type":"text","text":" "},{"type":"text","text":"first protected route."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Either applies the plan through "},{"type":"codeVoice","code":"flow.apply(_:)"},{"type":"text","text":" or stores it as"},{"type":"text","text":" "},{"type":"text","text":"a "},{"type":"codeVoice","code":"FlowPendingDeepLink"},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Replaying after sign-in","anchor":"Replaying-after-sign-in"},{"type":"paragraph","inlineContent":[{"text":"Once the user signs in, resume the pending deep link:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["func userDidSignIn() {","    coordinator.userDidSignIn()","}"]},{"type":"paragraph","inlineContent":[{"text":"The handler re-consults the authentication policy (now returning","type":"text"},{"text":" ","type":"text"},{"code":"true","type":"codeVoice"},{"text":"), drops the pending reference, and applies the plan atomically.","type":"text"},{"text":" ","type":"text"},{"text":"For an async gate (e.g. token refresh), use:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["await coordinator.handler.resumePendingDeepLinkIfAllowed { pending in","    \/\/ Return true once the refresh has produced a live session.","    await AuthService.shared.refreshTokenIfNeeded()","}"]},{"type":"paragraph","inlineContent":[{"text":"The handler keeps a single pending slot:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"a newly deferred URL replaces the older pending link","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"clearPendingDeepLink()","type":"codeVoice"},{"text":" drops the slot explicitly","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"stale pending links (ones the user replaced by opening a different"},{"type":"text","text":" "},{"type":"text","text":"URL) are therefore dropped automatically"}]}]}]},{"type":"heading","level":2,"text":"Observing the chain","anchor":"Observing-the-chain"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All three authorities surface on "},{"type":"codeVoice","code":"FlowStore.events"},{"type":"text","text":" as one"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncStream"},{"type":"text","text":". A single subscriber sees the batch execution on the"},{"type":"text","text":" "},{"type":"text","text":"navigation store, the modal presentation (if any), and the"},{"type":"text","text":" "},{"type":"text","text":"settled FlowStore-level event as one chain. "},{"type":"codeVoice","code":"FlowStore"},{"type":"text","text":" wraps inner"},{"type":"text","text":" "},{"type":"text","text":"navigation \/ modal callbacks synchronously before emitting the"},{"type":"text","text":" "},{"type":"text","text":"flow-level event, so one subscriber can assert the same ordering the"},{"type":"text","text":" "},{"type":"text","text":"matching configuration callbacks observe."}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["Task {","    for await event in flow.events {","        switch event {","        case .navigation(.batchExecuted(let result)):","            analytics.track(\"deep_link_applied\", [","                \"routes\": result.stateAfter.path.map(String.init(describing:))","            ])","        case .modal(.presented(let presentation)):","            analytics.track(\"deep_link_opened_modal\", [","                \"route\": String(describing: presentation.route)","            ])","        case .pathChanged(_, let new):","            analytics.track(\"flow_path\", [","                \"steps\": new.map(String.init(describing:))","            ])","        default:","            continue","        }","    }","}"]},{"type":"heading","level":2,"text":"Host-less testing","anchor":"Host-less-testing"},{"type":"paragraph","inlineContent":[{"code":"FlowTestStore","type":"codeVoice"},{"text":" wraps the same ","type":"text"},{"code":"flowStore.apply","type":"codeVoice"},{"text":" path:","type":"text"}]},{"type":"codeListing","syntax":"swift skip doc-fragment","code":["@Test","@MainActor","func multiSegmentURLRehydrates() {","    let store = FlowTestStore<AppRoute>()","    let handler = FlowDeepLinkEffectHandler(pipeline: pipeline, applier: store.store)","","    _ = handler.handle(URL(string: \"myapp:\/\/app\/home\/detail\/42\")!)","","    store.receiveNavigation { event in","        if case .batchExecuted = event { return true }","        return false","    }","    store.receivePathChanged { _, new in","        new == [.push(.home), .push(.detail(id: \"42\"))]","    }","}"]},{"type":"heading","level":2,"text":"Next steps","anchor":"Next-steps"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"See the push-only "},{"code":"Tutorial-DeepLinkReconciliation","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"walk-through in the "},{"code":"InnoRouterSwiftUI","type":"codeVoice"},{"type":"text","text":" catalog for apps that"},{"type":"text","text":" "},{"type":"text","text":"don’t yet need modal-terminal URLs."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Read the ","type":"text"},{"code":"Tutorial-LoginOnboarding","type":"codeVoice"},{"text":" guide in the","type":"text"},{"text":" ","type":"text"},{"code":"InnoRouterSwiftUI","type":"codeVoice"},{"text":" documentation catalog to see how the","type":"text"},{"text":" ","type":"text"},{"text":"authenticated-replay loop fits a greenfield flow that uses","type":"text"},{"text":" ","type":"text"},{"code":"ChildCoordinator","type":"codeVoice"},{"text":" for a sign-up sheet.","type":"text"}],"type":"paragraph"}]}]}],"kind":"content"}],"references":{"doc://com.innosquad.innorouter.docs.deeplink/documentation/InnoRouterDeepLink/InnoRouterDeepLink":{"abstract":[{"text":"Pattern matching, pipeline planning, and pending deep-link handling for InnoRouter.","type":"text"}],"title":"InnoRouterDeepLink","role":"collectionGroup","url":"\/documentation\/innorouterdeeplink\/innorouterdeeplink","identifier":"doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterDeepLink\/InnoRouterDeepLink","kind":"article","type":"topic"},"doc://com.innosquad.innorouter.docs.deeplink/documentation/InnoRouterTesting":{"kind":"symbol","identifier":"doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterTesting","url":"\/documentation\/innoroutertesting","abstract":[],"title":"InnoRouterTesting","type":"topic","role":"collection"}}}