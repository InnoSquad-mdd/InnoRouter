{"variants":[{"paths":["\/documentation\/innorouterdeeplink\/matcher-and-diagnostics"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"role":"article","roleHeading":"Article","modules":[{"name":"InnoRouterTesting"}],"title":"Matcher and diagnostics"},"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"codeVoice","code":"DeepLinkMatcher"},{"type":"text","text":" and "},{"type":"codeVoice","code":"FlowDeepLinkMatcher"},{"type":"text","text":" are the URL-pattern front doors for deep-link routing."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterTesting"],["doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterTesting","doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterDeepLink\/InnoRouterDeepLink"]]},"primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"Pattern-model","text":"Pattern model"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Patterns support:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"literal segments","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"named parameters such as "},{"code":":id","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"text":"terminal wildcard ","type":"text"},{"code":"*","type":"codeVoice"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This keeps matching simple and predictable for app routing."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Wildcards are terminal-only. A pattern like "},{"code":"\/api\/*\/users","type":"codeVoice"},{"type":"text","text":" is invalid:"},{"type":"text","text":" "},{"type":"text","text":"it produces a "},{"code":".nonTerminalWildcard(pattern:index:)","type":"codeVoice"},{"type":"text","text":" diagnostic and does"},{"type":"text","text":" "},{"type":"text","text":"not match runtime paths."}]},{"type":"paragraph","inlineContent":[{"text":"Captured values stay available as strings through ","type":"text"},{"type":"codeVoice","code":"firstValue(forName:)"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"type":"codeVoice","code":"values(forName:)"},{"text":". For common scalar types, use the typed overloads:","type":"text"}]},{"type":"codeListing","code":["let id = parameters.firstValue(forName: \"id\", as: UUID.self)","let page = parameters.firstValue(forName: \"page\", as: Int.self)","let selectedTags = parameters.values(forName: \"tag\", as: String.self)"],"syntax":"swift skip doc-fragment"},{"level":2,"type":"heading","anchor":"Match-precedence","text":"Match precedence"},{"type":"paragraph","inlineContent":[{"text":"Match precedence remains declaration-order based.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"That means:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"earlier patterns win","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"diagnostics do not change runtime behavior"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"ordering is still part of the matcher contract","type":"text"}],"type":"paragraph"}]}]},{"level":2,"type":"heading","anchor":"Diagnostics","text":"Diagnostics"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"DeepLinkMatcherConfiguration"},{"type":"text","text":" can surface diagnostics for common authoring mistakes:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"duplicate patterns"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"wildcard shadowing"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"non-terminal wildcards"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"invalid parameter names; parameter names must match"},{"type":"text","text":" "},{"type":"codeVoice","code":"^[A-Za-z_][A-Za-z0-9_]*$"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"parameter-heavy patterns that subsume more specific later patterns"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Diagnostics are available on both push-only and flow matchers. They"},{"type":"text","text":" "},{"type":"text","text":"are intended to catch ambiguous authoring early without changing the"},{"type":"text","text":" "},{"type":"text","text":"matcher’s runtime semantics."}]},{"type":"paragraph","inlineContent":[{"text":"For release-readiness gates, use the throwing strict initializers:","type":"text"},{"text":" ","type":"text"},{"code":"DeepLinkMatcher(strict:)","type":"codeVoice"},{"text":" for push-only mappings and","type":"text"},{"text":" ","type":"text"},{"code":"FlowDeepLinkMatcher(strict:)","type":"codeVoice"},{"text":" for mappings that expand into a","type":"text"},{"text":" ","type":"text"},{"code":"FlowPlan","type":"codeVoice"},{"text":". Strict initializers throw ","type":"text"},{"code":"DeepLinkMatcherStrictError","type":"codeVoice"},{"text":" with","type":"text"},{"text":" ","type":"text"},{"text":"the full diagnostic list instead of only logging warnings, and accept","type":"text"},{"text":" ","type":"text"},{"text":"the same ","type":"text"},{"code":"DeepLinkInputLimits","type":"codeVoice"},{"text":" guardrails used by non-strict matchers.","type":"text"}]},{"level":2,"type":"heading","anchor":"Input-limits","text":"Input limits"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"DeepLinkInputLimits"},{"text":" guards runtime URLs before matching. Configure it","type":"text"},{"text":" ","type":"text"},{"text":"on ","type":"text"},{"type":"codeVoice","code":"DeepLinkMatcherConfiguration"},{"text":", ","type":"text"},{"type":"codeVoice","code":"DeepLinkPipeline"},{"text":", or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"FlowDeepLinkPipeline"},{"text":" to cap absolute URL length, path segment count,","type":"text"},{"text":" ","type":"text"},{"text":"and query item count. Direct matcher calls still return ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" because","type":"text"},{"text":" ","type":"text"},{"text":"their public contract is optional. Pipeline and effect-handler paths","type":"text"},{"text":" ","type":"text"},{"text":"surface limit violations as typed","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"DeepLinkRejectionReason.inputLimitExceeded"},{"text":" rejections instead of","type":"text"},{"text":" ","type":"text"},{"text":"“no match” outcomes.","type":"text"}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterDeepLink\/Matcher-and-Diagnostics"},"kind":"article","references":{"doc://com.innosquad.innorouter.docs.deeplink/documentation/InnoRouterTesting":{"kind":"symbol","identifier":"doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterTesting","url":"\/documentation\/innoroutertesting","abstract":[],"title":"InnoRouterTesting","type":"topic","role":"collection"},"doc://com.innosquad.innorouter.docs.deeplink/documentation/InnoRouterDeepLink/InnoRouterDeepLink":{"abstract":[{"text":"Pattern matching, pipeline planning, and pending deep-link handling for InnoRouter.","type":"text"}],"title":"InnoRouterDeepLink","role":"collectionGroup","url":"\/documentation\/innorouterdeeplink\/innorouterdeeplink","identifier":"doc:\/\/com.innosquad.innorouter.docs.deeplink\/documentation\/InnoRouterDeepLink\/InnoRouterDeepLink","kind":"article","type":"topic"}}}